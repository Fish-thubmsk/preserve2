# .env.example
# 复制此文件为 .env 并填入你的实际登录态信息
# 警告：.env 文件包含敏感信息，切勿提交到 Git 仓库

# 从浏览器复制的完整 Cookie 字符串
# 操作步骤：在浏览器中登录图书馆座位系统 → F12 开发者工具
#           → Network 标签 → 任意请求 → Headers → Cookie
# 示例（请替换为你自己的 Cookie 值）：
CX_COOKIE="JSESSIONID=xxxxx.reserve_web_127; route=xxxxx; fid=499; _uid=YOUR_UID; _d=YOUR_TIMESTAMP; UID=YOUR_UID; vc3=xxxxx; uf=xxxxx; cx_p_token=xxxxx; p_auth_token=eyJ..."

# JWT Token（p_auth_token 的值，通常已包含在 CX_COOKIE 中）
# 如果 Cookie 中已含 p_auth_token，此项可留空
CX_P_AUTH_TOKEN=""
