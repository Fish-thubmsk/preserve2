                    popup.alert('签到时间已过', '确认', function () {
                      location.reload()
                    })
                    return
                  }
                }
              }
              if (data.status === 3 || data.status === 5) {
                if (moment(data.expireTime).isBefore(now)) {
                  popup.alert('落座时间已过')
                  location.reload()
                  return
                }
              }
              if (_this.showCode) {
                getQrcode(_this, data)
