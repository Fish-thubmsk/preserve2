                    break
                  case 124841:
                    thirdAppUtils.barcode.scan().then(function (res) {
                      location.href = res + '&num=' + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId
                    })
                    break
                  case 23677:
                    thirdAppUtils.barcode.lzcsScan().then(function (res) {
                      location.href = res + '&num=' + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId
                    })
                    break
                  case 33155:
                    setTimeout(function () {
                      if (_this.initJrxyApiSuccess) {
                        JrxyUtils.scan($.Deferred()).done(function (res) {
                          if (res.success) {
                            location.href = res.url + '&num=' + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId
                          } else {
                            popup.alert('扫码失败')
                          }
                        })
                      } else {
                        popup.alert('今日校园环境初始化失败，请刷新页面重试')
                      }
                    }, 1000)
                    break
                  default:
                    break
                }
              } else if (data.isPosition === 3 || data.isPosition === 7) {//扫统一二维码
                switch (scannerType) {
                  case 0:
                    wx.scanQRCode({
                      needResult: 1,
                      desc: 'scanQRCode desc',
                      success: function (res) {
                        var qrUrl = res.resultStr
                        if (qrUrl != undefined && qrUrl != null && qrUrl != '' && qrUrl.indexOf('front/apps/seat/unified/code') != -1) {
