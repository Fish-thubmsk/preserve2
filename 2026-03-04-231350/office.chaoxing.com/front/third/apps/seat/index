<body>
<div class="seat_index" v-cloak>
  <div class="page_header">
    <div class="user_login">
      <div class="user_login_info" v-if="seatConfig.thirdpartLoginoutShow!=2">
        <div class="user_login_avatar"><img :src="photoDomain + '/p/'+userInfo.uid+'_50'" alt=""/></div>
        <span class="user_login_name">{{userInfo.uname}}</span>
      </div>
      <div class="user_login_info" v-else>
        <span class="user_login_name">{{userInfo.uname}}</span>
        <span class="user_login_name" style="margin-left: 10px; max-width: 5rem;"> {{userInfo.sno}}</span>
      </div>
      <div class="user_login_operate" v-if="seatConfig.thirdpartLoginoutShow!=2">
        <div class="user_login_btn" v-if="roleChangeBtnShow" @click="goManagePage">切换身份</div>
        <div class="user_login_btn" v-if="!hideLoginOut && seatConfig.thirdpartLoginoutShow!=0" @click="logOutShow=true">退出登录</div>
      </div>
    </div>
  </div>
  <ul class="sind_top">
    <li class="sind_top_btn" @click="toSeatListPage" v-if="reservationEntrance.defaultReserve">
      <img src="https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_yuyue.png" alt="" class="sind_top_icon"/>
      <p class="sind_top_word">预约选座</p>
    </li>
    <li class="sind_top_btn" @click="sceneChoseSeat" v-if="reservationEntrance.liveReserve">
      <img src="https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_xinachang.png" alt="" class="sind_top_icon"/>
      <p class="sind_top_word">快速选座</p>
    </li>
    <li class="sind_top_btn" @click="toReserveListPage">
      <img src="https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_jilu.png" alt="" class="sind_top_icon"/>
      <p class="sind_top_word">预约记录</p>
    </li>
    <li class="sind_top_btn" @click="goNotice()" v-if="customNoticeShow">
      <img v-if="seatConfig.deptId != 23278" src="https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_xitong.png" alt="" class="sind_top_icon"/>
      
      <img v-else src="https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/icon_data.png" alt="" class="sind_top_icon"/>
