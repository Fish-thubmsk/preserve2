    </li>
    <li class="sind_top_btn" @click="toRulePage" v-if="defaultNoticeShow">
      <img src="https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_guize.png" alt="" class="sind_top_icon"/>
      <p class="sind_top_word">规则说明</p>
    </li>
  </ul>
