          return false
        },
        signBackBtnShow: function (curReserve) {
          if ([1, 3, 5].indexOf(curReserve.status) !== -1) {
            if ([0, 12, 14, 16, 21, 22].indexOf(this.seatConfig.qrcodeOpen) !== -1) {
              return true
            }
          }
          return false
        },
        goManagePage: function () {
          BaseUtils.addCache(pageKey, '2')
          location.href = location.origin + '' + '/front/third/apps/seat/manager/index?fidEnc=' + deptIdEnc + '&mappId=' + mappId
        },
        leaveBtnShow: function (curReserve) {
          return curReserve.status === 1 && this.seatConfig.leaveDuration !== -1
        },
        beSeatedBtnShow: function (curReserve) {
          return curReserve.status === 3 || curReserve.status === 5
        },
        goPay: function (e) {
          operateData('data/apps/seat/verify/seatreserve/status', {id: e.id}).then(function (res) {
            if (res.success) {
              location.href = e.payUrl
            } else {
              popup.alert(res.msg, '确认', function () {
                window.location.reload()
              })
            }
          })
        },
        goPayBtnShow: function (e) {
          return e.orderStatus !== undefined && e.orderStatus !== null && e.orderStatus !== 1
        }
      },
      filters: {
        format: function (value, formater) {
          return moment(value).format(formater)
        }
      },
      mounted: function () {
        if (mark != 0) {
          popup.alert('退座成功')
        }
        var _this = this
        //获取模板信息
        operateData('data/apps/seat/index', {fidEnc: deptIdEnc, r: Math.random() * 100}).then(function (json) {
          if (json.success) {
            _this.nearReserves = json.data.nearReserves
            _this.officeDomain = json.data.officeDomain
            if (json.data.seatConfig) {
              _this.seatConfig = json.data.seatConfig
              _this.hideRulePageTab = _this.seatConfig.deptId === 33483 || _this.seatConfig.deptId === 34199
              _this.showCode = [29747, 29216].indexOf(_this.seatConfig.deptId) !== -1
              _this.bjjtApp = _this.seatConfig.deptId === 24676 //北京交通大学定制
            }
            _this.openDialog = BaseUtils.dialogShow(
                json.data.openDialog,
                _this.seatConfig.openDialog,
                _this.seatConfig.dialogFrequency,
                BaseUtils.getCache(dialogKey)
            )
            BaseUtils.initEditor(_this.seatConfig.dialogContent)
            if (_this.nearReserves.length === 0) {
              _this.notNearReserves = true
            }
            if (json.data.customLoginUrl) {
              _this.customLoginUrl = json.data.customLoginUrl
              _this.hideLoginOut = !json.data.customLoginUrl.loginOutUrl;
            }
            if (_this.seatConfig.deptId === 32439) {
              _this.hideLoginOut = true
            }
            _this.curReserves = json.data.curReserves
            if (_this.curReserves.length === 0) {
              _this.notCurReserves = true
            }
            _this.curReserves.forEach(function (value) {
              if (value.status === 1 || value.status === 3 || value.status === 5) {
                _this.getCountDown(value.expireTime)
              }
            })
          }
          if (location.href.indexOf('qrresult=') > -1) {
            var url = decodeURIComponent(location.href.split('qrresult=')[1]),
                roomIdByCode = parseInt(BaseUtils.getQueryVariable('id', url.split('?')[1])) | 0,
                fid = parseInt(BaseUtils.getQueryVariable('fid', url.split('?')[1])) | 0,
                reserveId = '0', //预约记录id
                num = '',
                room = '0',
                id = '0',
                signBack = '0',
                seatNum = '0'
            if ((_this.seatConfig.isPosition == 1 || _this.seatConfig.isPosition == 0) &&
                url != undefined &&
                url != null &&
                url != '' &&
                url.indexOf('front/apps/seat/code') != -1 &&
                parseInt(room) === roomIdByCode) {
              location.href = url + '&reserveId=' + reserveId + '&num=' + num + '&room=' + room + '&fidEnc=' + deptIdEnc
            } else if ((_this.seatConfig.isPosition == 3 || _this.seatConfig.isPosition == 7) &&
                url != undefined &&
                url != null &&
                url != '' &&
                url.indexOf('front/apps/seat/unified/code') != -1) {
              location.href = url + '&reserveId=' + reserveId + '&id=' + id + '&signBack=' + signBack + '&seatNum=' + seatNum
            } else if (_this.seatConfig.isPosition == 4 &&
                url != undefined &&
                url != null &&
                url != '' &&
                url.indexOf('front/apps/seat/dynamic/code') != -1 &&
                ((roomIdByCode !== 0 && parseInt(room) === roomIdByCode) || (fid !== 0))) {
              location.href = url + '&reserveId=' + reserveId + '&signBack=' + signBack + '&seatNum=' + seatNum
            } else {
              popup.alert('请扫描正确的二维码', '确认', function () {
                location.href = location.href.split('?')[0] + '?fidEnc=' + deptIdEnc
              })
            }
          }
          if (_this.jrxyDeptList.indexOf(_this.seatConfig.deptId) !== -1) {
            var ele = document.createElement('script');
            ele.setAttribute('type', 'text/javascript');
            ele.setAttribute('src', 'https://static.campushoy.com/sdks/js/open/release/campushoy-2.0.5.js');
            document.body.appendChild(ele);
            JrxyUtils.initJrxy(_this)
          }
        })
        operateData('data/apps/seat/identity/verify', {mappId: mappId, fidEnc: deptIdEnc}).then(function (json) {
          if (json.success && (json.data.isManager || json.data.roomManager)) {
            _this.roleChangeBtnShow = true
            if (BaseUtils.getCache(pageKey) == 2) {
              location.href = location.origin + '' + '/front/third/apps/seat/manager/index?fidEnc=' + deptIdEnc + '&mappId=' + mappId
            }
          }
        })
      },
      created: function () {
        var _this = this
        wxinit.initWechatScanner(wx)
        MultiEditor.init('detail')
        operateData('data/apps/seat/entrance/config', {appType: 0, fidEnc: deptIdEnc}).then(function (json) {
          if (json.success) {
            _this.reservationEntrance.defaultReserve = json.data.defaultReserve
            _this.reservationEntrance.liveReserve = json.data.liveReserve
            _this.reservationEntrance.againReserve = json.data.againReserve
            _this.reservationEntrance.recentlyReserve = json.data.recentlyReserve
            _this.reservationEntrance.onlySupportsApiSignIn = json.data.onlySupportsApiSignIn
          }
        })
      }
    })
  })
</script>
