              if (data.isPosition === 2) {//仅判断位置
                location.href = location.origin + '/front/third/apps/seat/code?seatNum=' + data.seatNum + '&id=' + data.roomId
              } else if (data.isPosition === 0 || data.isPosition === 1) {//扫座位码
                switch (scannerType) {
                  case 0:
