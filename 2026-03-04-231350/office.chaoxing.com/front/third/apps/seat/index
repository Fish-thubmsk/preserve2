                        } else {
                          popup.alert('请扫描正确的二维码')
                        }
                      }
                    })
                    break
                  case 1:
                    location.href = 'http://sao315.com/w/api/saoyisao?redirect_uri=' + encodeURIComponent(location.href + '&seatNum=' + parseInt(data.seatNum)
                        + '&reserveId=' + data.id + '&id=' + data.roomId)
                    break
                  case 2:
                    location.href = 'https://office.chaoxing.com/api/wx/front/apps/reserve/scanner?redirect_uri=' +
                        encodeURIComponent(location.href + '&seatNum=' + parseInt(data.seatNum)
                            + '&reserveId=' + data.id + '&id=' + data.roomId)
                    break
                  case 124841:
                    thirdAppUtils.barcode.scan().then(function (res) {
                      location.href = res + '&seatNum=' + parseInt(data.seatNum) + '&reserveId=' + data.id + '&id=' + data.roomId
                    })
                    break
                  case 23677:
                    thirdAppUtils.barcode.lzcsScan().then(function (res) {
                      location.href = res + '&seatNum=' + parseInt(data.seatNum) + '&reserveId=' + data.id + '&id=' + data.roomId
                    })
                    break
                  case 33155:
