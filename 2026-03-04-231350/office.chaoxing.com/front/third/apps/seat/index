              var hour = Math.floor((t / 3600000) % 24)
              var min = Math.floor((t / 60000) % 60)
              var sec = Math.floor((t / 1000) % 60)
              hour = hour < 10 ? '0' + hour : hour
              min = min < 10 ? '0' + min : min
              sec = sec < 10 ? '0' + sec : sec
              var format = ''
              if (day > 0) {
                format = day + '天' + hour + ':' + min + ':' + sec
              }
              if (day <= 0 && hour > 0) {
                format = hour + ':' + min + ':' + sec
              }
              if (day <= 0 && hour <= 0) {
                format = min + ':' + sec
              }
              self.countDown = format
            } else {
