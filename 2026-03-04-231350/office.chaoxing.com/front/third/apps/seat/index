                  if (now.isBefore(moment(data.startTime).add(-preSignDuration, 'minutes'))) {
                    popup.alert('还未到签到时间')
                    return
                  }
                  if (now.isAfter(moment(data.endTime))) {
                    popup.alert('签到时间已过', '确认', function () {
