      <div class="s_now_cont"><span>暂无预约</span></div>
    </div>
    
    <div class="s_now" :class="{wait: curReserve.status == 0,leave:curReserve.status == 3,leave:curReserve.status == 5}" v-if="!notCurReserves" v-for="curReserve in curReserves">
      <h6 class="s_now_title">
        <span>当前预约</span>
        <span class="s_now_btn" @click.stop="toggleReserveInfo(curReserve)">出示预约信息</span>
        <span class="s_now_type" v-if="curReserve.status === 0">待履约</span>
        <span class="s_now_type" v-if="curReserve.status === 1">使用中</span>
        <span class="s_now_type" v-if="curReserve.status === 3">暂离中</span>
        <span class="s_now_type" v-if="curReserve.status === 5">被监督中</span>
      </h6>
      <dl class="s_now_cont">
        <dt>
          <h6 class="s_now_name owt1">{{curReserve.seatNum}}号座位</h6>
          <p class="s_now_addr owt1">
            {{curReserve.firstLevelName}}<span v-if="curReserve.secondLevelName">-{{curReserve.secondLevelName}}</span><span v-if="curReserve.thirdLevelName">-{{curReserve.thirdLevelName}}</span>
          </p>
          <p class="s_now_time owt1" v-if="curReserve.status === 1 || curReserve.status === 3 || curReserve.status === 5">剩余时长&nbsp;&nbsp;&nbsp;{{countDown}}</p>
          <p class="s_now_time owt1" v-else>{{curReserve.startTime |
            format('YYYY-MM-DD')}}<span>{{curReserve.startTime | format('HH:mm')}}-{{curReserve.endTime | format('HH:mm')}}</span><span>{{curReserve.duration}}小时</span></p>
        </dt>
        <dd>
