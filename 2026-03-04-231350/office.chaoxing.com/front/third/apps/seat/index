      <div class="cal_top">确定退出账号?</div>
      <div class="cal_btm">
        <span @click="logOutShow=false">取消</span>
        <span class="wait_sure" @click="logOut">确认</span>
      </div>
    </div>
  </div>
  
  <div class="reminder_pop" v-show="openDialog">
    <h6 class="rp_top" v-show="openDialogType == 0">{{seatConfig.dialogTitle}}</h6>
    <h6 class="rp_top" v-show="openDialogType == 1">{{seatConfig.noticeName}}</h6>
    <div class="rp_cont">
      <div id="rich_text"></div>
    </div>
    <div class="notice_confirm" v-show="openDialogType == 0 && seatConfig.dialogAgree == 1">
      <span class="icon_radio" :class="{'icon_check': dialogAgreeStatus}" @click="dialogAgreeStatus = !dialogAgreeStatus"></span>
      <span>我已阅读并同意相关内容</span>
    </div>
    <div class="rp_bottom">
      <span class="rp_cal" v-show="openDialogType == 0" @click="back()">取消</span>
      <span class="rp_sure" :class="{disabled: openDialogType == 0 && seatConfig.dialogAgree == 1 && !dialogAgreeStatus}" @click="start()">开始预约</span>
    </div>
  </div>
  
  <div class="screenMask" style="z-index: 3" v-if="bindSnoShow"></div>
  
  <div class="reminder_pop" style="z-index: 4" v-if="bindSnoShow">
    <h6 class="rp_top">绑定提示</h6>
    <div class="rp_cont">
      <p class="rp_cont_word">您未绑定学工号/一卡通账号，无法使用全部功能，请绑定后再预约</p>
    </div>
    <div class="rp_bottom">
      <span class="rp_cal" @click="back()">取消</span>
      <span class="rp_sure" @click="goBindSno()">去绑定</span>
    </div>
  </div>
  
  <div class="pop_wrap" v-show="qrCodeDialog.show">
    <div class="code_pop">
      
      <template v-if="showCode">
        <div class="code_pic" v-if="!qrCodeDialog.isSign">
          <img v-show="qrCodeDialog.imgShow" :src="qrCodeDialog.url" alt="">
          <span>请将二维码对准扫码设备扫描</span>
        </div>
        <div class="success_tip" v-else>
          <span class="error_pic"></span>
          <h1>签到成功</h1>
        </div>
      </template>
      
      <div class="psd_box" v-if="seatConfig.qrcodeOpen == 22">
        <span class="psd_pic"></span>
        <h1 class="psd_num">{{qrCodeDialog.password}}</h1>
        <p class="psd_txt">请在预约区域门禁设备处输入此密码</p>
      </div>
      <div class="pop_btm" @click="location.reload()">关闭</div>
    </div>
  </div>
  
  <div class="pop_wrap" v-show="unlockCodeDialog.show">
    <div class="code_pop">
      
      <div class="code_pic">
        <img v-show="unlockCodeDialog.imgShow" :src="unlockCodeDialog.url" alt="">
        <span>请将二维码对准扫码设备扫描</span>
      </div>
      <div class="pop_btm" @click="location.reload()">关闭</div>
    </div>
  </div>
  
  <transition name="model-mask">
    <div class="model-pop-mask reserve-info-pop-mask" v-if="reserveInfo.show" @click.stop="toggleReserveInfo(null)">
      <div class="model-popup reserve-info-pop-wrap" @click.stop>
        <div class="popup-title owt1">预约信息</div>
        <span class="popup-close" @click.stop="toggleReserveInfo(null)">关闭</span>
        <div class="popup-body">
          <h1 class="reserve-time">{{reserveInfo.data.startTime | format('HH:mm')}}-{{reserveInfo.data.endTime | format('HH:mm')}}</h1>
          <h2 class="reserve-date">{{reserveInfo.data.startTime | format('YYYY-MM-DD')}}</h2>
          <p class="reserve-place owt1">
            <span>{{reserveInfo.data.firstLevelName}}</span>
            <span v-if="reserveInfo.data.secondLevelName">-{{reserveInfo.data.secondLevelName}}</span>
            <span v-if="reserveInfo.data.thirdLevelName">-{{reserveInfo.data.thirdLevelName}}</span>
            <span>&nbsp;{{reserveInfo.data.seatNum}}&nbsp;号</span>
          </p>
          <h1 class="reserve-userName owt1">{{reserveInfo.data.uname}}</h1>
          <h1 class="reserve-status"
              :class="{'orange': reserveInfo.data.status==0||reserveInfo.data.status==3, 'blue': reserveInfo.data.status==1, 'red': reserveInfo.data.status==5}">
            {{reserveInfo.data.statusStr}}
          </h1>
          <p class="tip-txt">当前时间</p>
          <p class="current-time">{{reserveInfo.currentTime | format('YYYY-MM-DD HH:mm:ss')}}</p>
        </div>
      </div>
    </div>
  </transition>
  
  <div class="res_loading" v-if="loadingShow">
    <div class="res_load_cont">
      <div class="loading_iocn"></div>
      <p class="loading_info">{{tipTitle}}</p>
    </div>
  </div>
</div>
<script>
