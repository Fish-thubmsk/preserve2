      var now = moment()
      //判断是否存在未签退座位
      operateData('data/apps/seat/check/exist', {seatNum: data.seatNum, roomId: data.roomId}).then(function (json) {
        if (json.success) {
          if (json.data.existCount > 0) {
            popup.alert('您存在未签退座位，不可再次签到')
          } else {
            var scannerType = wxinit.getScannerType()
            scannerType = BaseUtils.getThirdScannerDept(_this.seatConfig.deptId, scannerType)
            if (data.status === 0 || data.status === 3 || data.status === 5) {
              if (data.status === 0) {
                var signDuration = json.data.signDuration
                var preSignDuration = json.data.preSignDuration //定制需求，弹性签到只能向后弹
