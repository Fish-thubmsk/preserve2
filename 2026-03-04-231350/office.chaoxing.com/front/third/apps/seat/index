            <li class="s_btn" v-if="leaveBtnShow(curReserve)" @click="askLeave(curReserve.id)">暂离</li>
            <li class="s_btn tz" v-if="signBackBtnShow(curReserve)" @click.stop="askSignBack(curReserve)">退座</li>
            <li class="s_btn qd" v-if="signInBtnShow(curReserve) && !goPayBtnShow(curReserve)" @click="signIn(curReserve)">签到</li>
            <li class="s_btn qd" v-if="beSeatedBtnShow(curReserve)" @click="signIn(curReserve)">落座</li>
            <li class="s_btn qd" v-if="goPayBtnShow(curReserve)" @click="goPay(curReserve)">去支付</li>
            <li class="s_btn" v-if="curReserve.status === 0" @click.stop="askCancel(curReserve.id)">取消</li>
