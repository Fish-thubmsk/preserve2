  <link rel="stylesheet" href="https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/grid/mgrid.css">
  <style>
    .container-div {
      /*border: 1px solid gray;*/
      position: relative;
      font-size: 12px;
      z-index: 1;
    }
    .container-out-div {
      width: 100%;
      overflow: auto;
      -webkit-flex: 1;
    }
    .noScrollBar{
      overflow: hidden;
    }
    .seat-div {
      position: absolute;
      z-index: 2;
      text-align: center;
    }
    .seat-number {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      z-index: -1;
      font-size: 0.2em;
    }
    .seat-inner-div {
      position: relative;
      z-index: -1;
      width: 100%;
      height: 100%;
      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/seat_canSel.png) no-repeat center / contain;
    }
    .seat-blue {
      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/seat_selected.png) no-repeat center / contain;
    }
    .seat-brown {
      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/seat_canSel.png) no-repeat center / contain;
    }
    .seat-gray {
      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/seat_unSel.png) no-repeat center / contain;
    }
    .seat-orange {
      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/seat_supervise.png) no-repeat center / contain;
    }
    .seat_font {
      text-align: center;
    }
    .container-div .cmp_icon {
      position: absolute;
      width: .19em;
      height: .19em;
      top: -.095em;
      right: -.045em;
      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/edit_cmp.png) no-repeat center;
      background-size: contain;
    }
    .container-div .pwr_icon {
      position: absolute;
      width: .19em;
      height: .19em;
      top: -.095em;
      left: -.045em;
      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/edit_pwr.png) no-repeat center;
      background-size: contain;
    }
    .container-div .no_pwr_icon {
      position: absolute;
      width: .19em;
      height: .19em;
      top: -.095em;
      left: -.045em;
      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/edit_no_pwr.png) no-repeat center;
      background-size: contain;
    }
    .container-div .win_icon {
      position: absolute;
      width: .19em;
      height: .19em;
      bottom: -.095em;
      left: -.045em;
      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/edit_win.png) no-repeat center;
      background-size: contain;
    }
    .u-layer {
      position: fixed;
      top: 50%;
      left: 53%;
      margin-top: -150px;
