      day = '2026-03-05', //目标日期
      deptIdEnc = '4a18e12602b24c8c',
      seatNum = '', // 座位号
      serverNow = new Date('2026-03-04T23:10:30.211+08:00'),// 服务器当前日期
      fidEnc = '4a18e12602b24c8c',
      uniqueDomainPath = ''
</script>
<script src="https://office-static.chaoxing.com/r/staticreserve/js/src/front/apps/seat/submit/third/seat_select_third.js?t=2026021017"></script>
