pt>\r\n        $(function () {\r\n            if ($(\"#shownotice\").val() == 1) {\r\n                showNotice($(\"#fid\").val());\r\n            }\r\n            enterSubmit(\"loginBtn\");\r\n\r\n            if (top != self) {\r\n                // $(\".default-login\").css(\"height\",\"520px\");\r\n                //$(\".default-login\").css(\"border-radius\",\"0px\");\r\n                //$(\".default-login\").css(\"box-shadow\",\"\");\r\n\r\n                $(\"body\").css(\"background\", \"none\");\r\n                $(\".lg-container\").css(\"background\", \"none\");\r\n                $(\".lg-container\").css(\"border-top\", \"none\");\r\n\r\n\r\n            }\r\n\r\n            //\u53ea\u8981\u914d\u7f6e\u4e86\u767b\u5f55\u63d0\u793a\u8bed\uff0c\u5c31\u90fd\u663e\u793a\u51fa\u6765\r\n            let loginTip = \"\";\r\n            if (loginTip != \"undefined\" && loginTip.trim() != \"\") {\r\n                $(\"#loginTip\").show();\r\n            }\r\n\r\n            if (\"https%3A%2F%2Foffice.chaoxing.com%2Ffront%2Fthird%2Fapps%2Fseat%2Findex%3FfidEnc%3D4a18e12602b24c8c\".indexOf(\"duxiu.com\") != -1 || \"https%3A%2F%2Foffice.chaoxing.com%2Ffront%2Fthird%2Fapps%2Fseat%2Findex%3FfidEnc%3D4a18e12602b24c8c\".indexOf(\"blyun.com\") != -1 || \"https%3A%2F%2Foffice.chaoxing.com%2Ffront%2Fthird%2Fapps%2Fseat%2Findex%3FfidEnc%3D4a18e12602b24c8c\".indexOf(\"zhizhen.com\") != -1) {\r\n                // $(\"#otherlogin\").hide();\r\n                $(\"#showlogintext\").html(\"\u8d26\u53f7\u767b\u5f55\");\r\n                $(\"#kf\").hide();\r\n            }\r\n            if ($(\"#showthird\").val() == \"1\") {\r\n                $(\"#thirdLogin\").show();\r\n            }\r\n\r\n            if (navigator.userAgent.indexOf(\"1000332\") != -1) {\r\n                $(\"#leftdiv\").hide();\r\n            }\r\n\r\n            if (\"https%3A%2F%2Foffice.chaoxing.com%2Ffront%2Fthird%2Fapps%2Fseat%2Findex%3FfidEnc%3D4a18e12602b24c8c\".indexOf(\"dayi100.com\") != -1) {\r\n                $(\"a[onclick='toRegister()']\").hide();\r\n            }\r\n\r\n            if (\"https%3A%2F%2Foffice.chaoxing.com%2Ffront%2Fthird%2Fapps%2Fseat%2Findex%3FfidEnc%3D4a18e12602b24c8c\".indexOf(\"mayuan.hebtu.edu.cn\") > -1) {\r\n                $('#fid').val(43350);\r\n            }\r\n\r\n            if (\"https%3A%2F%2Foffice.chaoxing.com%2Ffront%2Fthird%2Fapps%2Fseat%2Findex%3FfidEnc%3D4a18e12602b24c8c\".indexOf(\"chatfile.chaoxing.com\") != -1) {\r\n                $(\"div.dz-logo\").show();\r\n                $(\"div.lg-container\").addClass(\"lg-dz-bg\");\r\n                $(\"div.filingBox\").hide();\r\n                $(\".lg-container .main\").removeClass(\"heightCalc\")\r\n            }\r\n\r\n            if (\"https%3A%2F%2Foffice.chaoxing.com%2Ffront%2Fthird%2Fapps%2Fseat%2Findex%3FfidEnc%3D4a18e12602b24c8c\".indexOf(\"sslibrary.com\") != -1) {\r\n                $(\"div.lg-container\").addClass(\"redBodybg\");\r\n                $(\"div.filingBox\").css('border-top', 'none');\r\n                //\u7248\u6743\u6240\u6709@\u4e16\u7eaa\u8d85\u661f\u4fe1\u606f\u6280\u672f\u53d1\u5c55\u6709\u9650\u8d23\u4efb\u516c\u53f8 \u4eacICP\u5907\u6848\u53f7\uff1a10040544\u53f7-25\u4eac\u516c\u7f51\u5b89\u5907 11010802038946\u53f7\r\n                $(\"div.filingBox p\").html(\r\n                        ' <p style=\"color: white;margin-bottom: 10px;\"> \u7248\u6743\u6240\u6709@\u4e16\u7eaa\u8d85\u661f\u4fe1\u606f\u6280\u672f\u53d1\u5c55\u6709\u9650\u8d23\u4efb\u516c\u53f8 </p>' +\r\n                        '<p style=\"margin-bottom: 10px;\"> <span class=\"icpSpan\"><a class=\"col-blue\" href=\"https://beian.miit.gov.cn\" style=\"color: white;margin-right: 20px;\">\u4eacICP\u5907\u6848\u53f7\uff1a10040544\u53f7-25</a>' +\r\n                        '<i></i><a  class=\"col-blue\" style=\"color: white;\" href=\"http://www.beian.gov.cn/portal/registerSystemInfo?recordcode=11010802038946\">\u4eac\u516c\u7f51\u5b89\u5907 11010802038946\u53f7</a></span></p>'\r\n                );\r\n                // $(\"#otherlogin\").hide();\r\n                $(\".lg-container .main\").removeClass(\"heightCalc\")\r\n                $('#kf').hide();\r\n            }\r\n\r\n            var currentDomain = window.location.hostname;\r\n            if (currentDomain == \"passport2.hbqyg.cn\") {\r\n                $(\"#passportAgreement\").hide();\r\n            }\r\n            if (currentDomain == \"passport.newvar.net\") {\r\n                $(\"#kf\").hide();\r\n                $(\"#otherlogin\").hide();\r\n                $(\"#passportAgreement\").hide();\r\n                $('.filingBox').hide();\r\n            }\r\n            if (currentDomain.indexOf(\"xuexi365.net\") != -1) {\r\n                document.title = \"\u6210\u90fd\u5b66\u4e60\u901a\u7b14\u8bb0\u5206\u4eab\";\r\n            }\r\n\r\n            //\u6839\u636e\u53c2\u6570\u63a7\u5236\u662f\u5426\u663e\u793a\u5176\u5b83\u767b\u5f55\r\n            if (getURLQuery('hideOtherLogin') && getURLQuery('hideOtherLogin') == '1') {\r\n                $(\"#otherlogin\").hide();\r\n                $(\"#passportAgreement\").css('bottom', '-46px');\r\n            }\r\n\r\n            //\u6839\u636e\u53c2\u6570\u63a7\u5236\u662f\u5426\u663e\u793a \u5bc6\u7801\u773c\u775b\r\n            if (getURLQuery('hidePasswordEye') && getURLQuery('hidePasswordEye') == '1') {\r\n                $(\".icon-eye\").hide();\r\n            }\r\n\r\n            if (\"-1\" == \"328054\") {\r\n                $('#passportAgreement').contents().filter(function () {\r\n                    return this.nodeType === 3;\r\n                }).each(function () {\r\n                    this.nodeValue = this.nodeValue.replace('\u5b66\u4e60\u901a', '\u96c4\u5b89\u56fe\u4e66\u9986');\r\n                });\r\n\r\n                $('#kf').hide();\r\n\r\n                // $('#phone').attr('placeholder', function (_, oldValue) {\r\n                //     return oldValue.replace('/\u8d85\u661f\u53f7', '');\r\n                // });\r\n                //\r\n                // $('#pwd').attr('placeholder', function (_, oldValue) {\r\n                //     return oldValue.replace('/\u5b66\u4e60\u901a', '');\r\n                // });\r\n\r\n            }\r\n        });\r\n    </script>\r\n</head>\r\n<style type=\"text/css\">\r\n    .Agreement {\r\n        text-align: center;\r\n        font-size: 12px;\r\n        color: #A8A8B3;\r\n        position: relative;\r\n        left: 0px;\r\n        bottom: -40px;\r\n    }\r\n\r\n    .Agreement a {\r\n        display: inline-block;\r\n        padding: 0 5px;\r\n        color: #3A8BFF\r\n    }\r\n\r\n    .lg-title img {\r\n        display: block;\r\n        width: 254px;\r\n        height: 37px;\r\n        margin: 0 auto;\r\n    }\r\n\r\n    .lg-dz-bg {\r\n        background: url(/images/fanya/bg.png) no-repeat center;\r\n        background-size: 100% 100%;\r\n    }\r\n\r\n    .dz-logo {\r\n        width: 392px;\r\n        height: 116px;\r\n        margin: 0 auto;\r\n        margin-bottom: 25px\r\n    }\r\n\r\n    .dz-logo img {\r\n        display: inline-block;\r\n        width: 100%;\r\n        height: 100%;\r\n    }\r\n\r\n    .tjLogo {\r\n        width: 352px;\r\n        height: 51px;\r\n        margin: 0 auto;\r\n        margin-bottom: 25px\r\n    }\r\n\r\n    .tjLogo img {\r\n        display: inline-block;\r\n        width: 100%;\r\n        height: 100%;\r\n    }\r\n</style>\r\n<script>var _CP_ = '';</script>\r\n<script>\r\n    retainlogin = 2;\r\n    document.cookie = \"retainlogin=\" + (retainlogin == '3' ? '2' : retainlogin) + \";\";\r\n</script>\r\n<body>\r\n<div class=\"lg-container\">\r\n    <!--\u767b\u5f55 start -->\r\n    <div class=\"main  default-login-main \">\r\n        <div class=\"dz-logo\" hidden>\r\n            <img src=\"/images/fanya/readlogo.png\">\r\n        </div>\r\n\r\n        \r\n        <!--\u9ed8\u8ba4\u767b\u5f55 start-->\r\n        <div class=\"default-login \">\r\n\r\n                        <div class=\"lg-top fs14\">\r\n                <a\r\n                                                href=\"/v5/toCustomer\"\r\n                                                target=\"_blank\" class=\"service col-lightblue\" id=\"kf\">\u5ba2\u670d</a>\r\n            </div>\r\n            <div class=\"left\" id=\"leftdiv\" >\r\n                                    <h3 class=\"lg-title\" id=\"showlogintext\" style=\"margin-bottom: 44px\">\r\n                                                                                    \u7528\u6237\u767b\u5f55                                                                        </h3>\r\n                                <p id=\"loginTip\" style=\"display:none;padding-bottom:10px;color:#A8A8B3;font-size:12px\"></p>\r\n\r\n                                <form action=\"\">\r\n                    <input type=\"hidden\" id=\"needVcode\" name=\"needVcode\" value=\"\"/>\r\n                    <input type=\"hidden\" id=\"fid\" name=\"fid\" value=\"-1\"/>\r\n                    <input type=\"hidden\" id=\"pid\" name=\"pid\" value=\"-1\"/>\r\n                    <input type=\"hidden\" id=\"refer\" name=\"refer\" value=\"https%3A%2F%2Foffice.chaoxing.com%2Ffront%2Fthird%2Fapps%2Fseat%2Findex%3FfidEnc%3D4a18e12602b24c8c\"/>\r\n                    <input type=\"hidden\" id=\"forbidotherlogin\" name=\"forbidotherlogin\" value=\"0\"/>\r\n                    <input type=\"hidden\" id=\"t\" name=\"t\" value=\"true\"/>\r\n                    <input type=\"hidden\" id=\"_blank\" value=\"1\">\r\n                    <input type=\"hidden\" id=\"regurl\" value=\"\">\r\n                    <input type=\"hidden\" id=\"showthird\" value=\"0\">\r\n                    <input type=\"hidden\" id=\"retainlogin\" value=\"2\">\r\n                    <input type=\"hidden\" id=\"accounttip\" value=\"\">\r\n                    <input type=\"hidden\" id=\"pwdtip\" value=\"\">\r\n                    <input type=\"hidden\" id=\"quick\" value=\"0\">\r\n                    <input type=\"hidden\" id=\"showForgetPwd\" value=\"3\">\r\n                    <input type=\"hidden\" name=\"shownotice\" id=\"shownotice\" value=\"1\"/>\r\n                    <input type=\"hidden\" id=\"hidecompletephone\" name=\"hidecompletephone\" value=\"0\"/>\r\n                    <input type=\"hidden\" id=\"ebook\" name=\"ebook\" value=\"0\"/>\r\n                    <input type=\"hidden\" id=\"allowSkip\" name=\"allowSkip\" value=\"0\"/>\r\n                    <input type=\"hidden\" id=\"doubleFactorLogin\" name=\"doubleFactorLogin\" value=\"0\"/>\r\n                    <input type=\"hidden\" id=\"independentId\" name=\"independentId\" value=\"0\"/>\r\n                    <input type=\"hidden\" id=\"independentNameId\" name=\"independentNameId\" value=\"0\"/>\r\n                    <input type=\"hidden\" id=\"otherLoginUrl\" name=\"otherLoginUrl\" value=\"\"/>\r\n                    <input type=\"hidden\" id=\"topTip\" name=\"topTip\" value=\"\"/>\r\n                    <!--\u7535\u8bdd\u53f7\u7801-->\r\n                    <div class=\"lg-item icon-tel margin-btm24\">\r\n                        <input type=\"text\" class=\"ipt-tel\"\r\n                               placeholder=\"\u624b\u673a\u53f7/\u8d85\u661f\u53f7\"\r\n                                                           id=\"phone\" maxlength=\"30\">\r\n                        <p class=\"err-txt\" id=\"phoneMsg\"></p>\r\n                    </div>\r\n                    <!--\u5bc6\u7801-->\r\n                    <div class=\"lg-item item-pwd icon-pwd\">\r\n                        <input type=\"password\" class=\"ipt-pwd\"                                placeholder=\"\u5b66\u4e60\u901a\u5bc6\u7801\"  id=\"pwd\" maxlength=\"20\">\r\n                        <span class=\"pwdSpan\">\r\n                        <i class=\"icon-eye icon-eye-close\" onclick=\"initPassword(this)\"></i>\r\n                        <a href=\"javaScript:void(0)\" onclick=\"toFindPwd()\" class=\"col-lightblue pos-r24\">\u5fd8\u8bb0\u5bc6\u7801\uff1f</a>\r\n                        </span>\r\n                        <p class=\"err-txt\" id=\"pwdMsg\"></p>\r\n                    </div>\r\n                    <input type=\"hidden\" name=\"validate\" id=\"validate\"/>\r\n                    <!--\u6309\u94ae\u4e0d\u53ef\u70b9\u51fb \u52a0\u4e0aclass\uff1adisable -->\r\n                    <div class=\"btns-box\">\r\n                        <p class=\"err-tip\" id=\"err-txt\"></p>\r\n                        <button type=\"button\" class=\"btn-big-blue margin-btm24\" onclick=\"loginByPhoneAndPwd();\"\r\n                                id=\"loginBtn\">\u767b\u5f55</button>\r\n                    </div>\r\n                </form>\r\n\r\n                                                            <div class=\"clearaft fs14\">\r\n                            <div class=\"auto-lg-next col-blue fl\"><span\r\n                                    class=\"check-input \"></span>\u4e0b\u6b21\u81ea\u52a8\u767b\u5f55                                <div class=\"tips\">\r\n                                    <span class=\"tipsIc\"></span>\r\n                                    <div class=\"tipsCon\"><i></i>\u52fe\u9009\u540e\uff0c\u767b\u5f55\u72b6\u6001\u4fdd\u63017\u5929\uff1b\u5982\u4e0d\u52fe\u9009\u5219\u5173\u95ed\u6d4f\u89c8\u5668\u5373\u4e3a\u9000\u51fa</div>\r\n                                </div>\r\n                            </div>\r\n                            <div class=\"lg-opr-right fr\">\r\n                                                                    <a href=\"javaScript:void(0)\" onclick=\"toRegister()\" class=\"col-blue fl\">\r\n                                                                                    \u65b0\u7528\u6237\u6ce8\u518c                                                                            </a>\r\n                                                                            <a href=\"javaScript:void(0)\" onclick=\"otherLogin(2)\" class=\"col-blue fr\">\u9a8c\u8bc1\u7801\u767b\u5f55</a>\r\n                                                                                                </div>\r\n                        </div>\r\n                                                    <div class=\"line\">\r\n                                            <a href=\"javaScript:void(0)\" onclick=\"otherLogin(3)\" id=\"otherlogin\"\r\n                           class=\"col-lightblue fs14 icon-right\">\u5176\u5b83\u65b9\u5f0f\u767b\u5f55</a>\r\n                                    </div>\r\n                <p id=\"passportAgreement\" class=\"Agreement\" style=\"bottom: -25px\">\u6211\u5df2\u9605\u8bfb\u5e76\u540c\u610f\u5b66\u4e60\u901a<a\r\n                        href=\"https://homewh.chaoxing.com/agree/privacyPolicy?appId=900001\" target=\"_blank\">\u300a\u9690\u79c1\u653f\u7b56\u300b</a>\u548c<a\r\n                        href=\"https://homewh.chaoxing.com/agree/userAgreement?appId=900001\" target=\"_blank\">\u300a\u7528\u6237\u534f\u8bae\u300b</a></p>\r\n            </div>\r\n                            <style>\r\n\r\n    .social-login {\r\n        color: #91A0B5;\r\n        width: 100%;\r\n        position: absolute;\r\n        left: 0;\r\n        bottom: 30px;\r\n    }\r\n\r\n    .social-login span {\r\n        display: inline-block;\r\n        margin: 0 10px;\r\n    }\r\n\r\n    .social-login span i {\r\n        display: inline-block;\r\n        width: 20px;\r\n        height: 20px;\r\n        margin-right: 6px;\r\n    }\r\n\r\n    .social-login span i img {\r\n        width: 100%;\r\n        height: 100%;\r\n        vertical-align: middle;\r\n    }\r\n\r\n    .social-login span.marLeft30 {\r\n        margin-left: 30px;\r\n    }\r\n\r\n    .ewmTab {\r\n        width: 100%;\r\n        height: 60px;\r\n        margin-bottom: 14px;\r\n    }\r\n\r\n    .ewmTab li {\r\n        display: inline-block;\r\n        line-height: 60px;\r\n        position: relative;\r\n        padding: 0 23px;\r\n        font-size: 16px;\r\n        color: #474C59;\r\n        cursor: pointer;\r\n    }\r\n\r\n    .ewmTab li span {\r\n        display: inline-block;\r\n        width: 32px;\r\n        height: 4px;\r\n        border-radius: 4px;\r\n        background: #3A8BFF;\r\n        position: absolute;\r\n        left: 50%;\r\n        bottom: 0;\r\n        transform: translateX(-50%);\r\n        display: none;\r\n    }\r\n\r\n    .ewmTab li.ewmCur {\r\n        font-weight: 600;\r\n        color: #131B26\r\n    }\r\n\r\n    .ewmTab li.ewmCur span {\r\n        display: block\r\n    }\r\n\r\n    .wxtip {\r\n        line-height: 20px;\r\n        margin-top: 20px;\r\n    }\r\n</style>\r\n<div class=\"right\" id=\"rightdiv\" >\r\n        <div id=\"step1\">\r\n        <div class=\"ecode-box\" style=\"position: relative;\">\r\n            <style>\r\n                .ewmDisable {\r\n                    width: 100%;\r\n                    height: 100%;\r\n                    position: absolute;\r\n                    left: 0;\r\n                    top: 0;\r\n                    background: rgba(255, 255, 255, 0.9);\r\n                    z-index: 3;\r\n                    display: none;\r\n                }\r\n\r\n                .ewmDisable p {\r\n                    width: 100%;\r\n                    text-align: center;\r\n                    font-size: 18px;\r\n                    color: #181e33;\r\n                    margin-top: 80px;\r\n                }\r\n\r\n                .ewmDisable a {\r\n                    display: inline-block;\r\n                    width: 94px;\r\n                    height: 34px;\r\n                    background: #FFFFFF;\r\n                    border: 1px solid #3A8BFF;\r\n                    border-radius: 18px;\r\n                    margin: 0 auto;\r\n                    text-align: center;\r\n                    line-height: 34px;\r\n                    font-size: 14px;\r\n                    color: #3A8BFF;\r\n                    margin-top: 10px;\r\n                }\r\n            </style>\r\n            <div class=\"ewmDisable\">\r\n                <p>\u4e8c\u7ef4\u7801\u5df2\u5931\u6548</p>\r\n                <a href=\"javascript:void(0);\" onclick=\"refrushEwm();\">\u91cd\u65b0\u83b7\u53d6</a>\r\n            </div>\r\n            <input type=\"hidden\" value=\"0715c16082b7494dbb89db24bf4c5daf\" id=\"uuid\"/>\r\n            <input type=\"hidden\" value=\"f0a02266eb802bd926335971cd81dafe\" id=\"enc\"/>\r\n            <input type=\"hidden\" value=\"\" id=\"QRCodeTip\"/>\r\n            <img src=\"/createqr?uuid=0715c16082b7494dbb89db24bf4c5daf&fid=-1\" id=\"quickCode\">\r\n            <span id=\"ahszk_custom\"\r\n                  style=\"width: 30px;height: 30px;display:inline-block;position: absolute;left: 50%;top: 50%;margin-left: -12px;margin-top: -15px;\">\r\n                <img src=\"/images/fanya/ahszk.png\" style=\"width:30px;height:30px;\">\r\n            </span>\r\n        </div>\r\n        <p class=\"fs14 colorIn tip\" id=\"quickCodeMsg\">\u4f7f\u7528\u5b66\u4e60\u901aAPP\u626b\u7801\u767b\u5f55</p>\r\n    </div>\r\n    \r\n    <div class=\"social-login\" style=\"display: none\" id=\"thirdLogin\">\u793e\u4ea4\u8d26\u53f7\u767b\u5f55\r\n        <span onclick=\"to_third_login('weixin')\" class=\"marLeft30\" style=\" cursor: pointer; \"><i><img\r\n                src=\"/images/common/weixin.png\"/></i>\u5fae\u4fe1</span>\r\n        <span onclick=\"to_third_login('qq')\" style=\" cursor: pointer; \"><i><img\r\n                src=\"/images/common/qq.png\"/></i>QQ</span>\r\n    </div>\r\n    <div class=\"Rmain-cont\" style=\"display:none\" id=\"step2\">\r\n        <div class=\"g_code_end\">\r\n            <img src=\"\" alt=\"\" id=\"photo\"/>\r\n        </div>\r\n        <p class=\"g_code_name mt30\" id=\"shownickname\"></p>\r\n        <p class=\"g_code_over\">\u8bf7\u5728\u5b66\u4e60\u901a\u4e0a\u70b9\u51fb\u786e\u8ba4\u4ee5\u767b\u5f55</p>\r\n        <p class=\"g_code_btn\" onclick=\"changeUser();\" style=\"cursor:pointer;color: #3A8BFF;\">\u8fd4\u56de\u626b\u7801</p>\r\n    </div>\r\n</div>\r\n<script type=\"text/javascript\">\r\n    /***/\r\n    function to_third_login(type, ref) {\r\n        var fd = $(\"#fid\").val();\r\n        if (\"qq\" == type) {\r\n            window.location.href = \"/oauth2/qq?newversion=true&fid=\" + fd + \"&refer=\" + $(\"#refer\").val();\r\n        } else if (\"weixin\" == type) {\r\n            window.location.href = \"/oauth2/weixin?newversion=true&fid=\" + fd + \"&refer=\" + $(\"#refer\").val();\r\n        }\r\n    }\r\n\r\n    function hideQRcode() {\r\n        $(\".right\").hide();\r\n        $(\".default-login-main\").attr(\"class\", \"main default-login-min\");\r\n    }\r\n\r\n\r\n    function changeUser() {\r\n        window.location.reload();\r\n    }\r\n\r\n    var qrInterValObj;\r\n    var enc = $(\"#enc\").val();\r\n    var uuid = $(\"#uuid\").val();\r\n    var ref = decodeURIComponent($(\"#refer\").val());\r\n    var c = 0;\r\n\r\n    //\u8d85\u661f\u9605\u8bfb\u5668 SSREADER/4.1.6.0001 \u4e3b\u7248\u672c\u53f7\u5927\u4e8e\u7b49\u4e8e4 \u9690\u85cf\u626b\u7801\u767b\u5f55\r\n    let userAgent = navigator.userAgent;\r\n    if (userAgent.indexOf(\"SSREADER/\") > -1) {\r\n        let versionArr = userAgent.substr(0, 10).split(\"/\");\r\n        if (versionArr[1] >= 4) {\r\n            hideQRcode();\r\n        }\r\n    }\r\n\r\n    //\u5b9a\u5236\u4e0d\u663e\u793a\u4e8c\u7ef4\u7801\r\n    if (1 != 1 || 1 != 1) {\r\n        hideQRcode();\r\n    } else if (-1 == 34415) {\r\n        $(\"#quickCode\").attr(\"src\", \"images/guide/34415ewm.png\");\r\n        $(\"#quickCodeMsg\").html(\"\u626b\u4e00\u626b\u4e0b\u8f7d\u79fb\u52a8\u5ba2\u6237\u7aef\");\r\n    } else if (-1 == 9566) {\r\n        $(\"#quickCode\").attr(\"src\", \"images/guide/9566ewm.jpg\");\r\n        $(\"#quickCodeMsg\").html(\"\u626b\u4e00\u626b\u5173\u6ce8\u5fae\u4fe1\u516c\u4f17\u53f7\");\r\n    } else if (-1 == 341321) {\r\n        $(\"#quickCode\").attr(\"src\", \"https://passport2-static.chaoxing.com/images/fanya/jiaoyuxiehuibj.png\");\r\n        $(\"#quickCodeMsg\").html('\u6b22\u8fce\u5173\u6ce8\u201c\u6d59\u6c5f\u7701\u7814\u7a76\u751f\u6559\u80b2\u5b66\u4f1a\u201d\u516c\u4f17\u53f7');\r\n    } else {\r\n        qrInterValObj = window.setInterval(loopStatus, 3000); //\u542f\u52a8\u8ba1\u65f6\u5668\uff0c1\u79d2\u6267\u884c\u4e00\u6b21\r\n        if (-1 == 35014) {\r\n            $(\"#quickCodeMsg\").html(\"\u56fd\u79d1\u5927\u5728\u7ebfAPP\u626b\u7801\u767b\u5f55\");\r\n            //\u5b9a\u5236\u4e8c\u7ef4\u7801\u626b\u7801\u540e\u63d0\u793a\u8bed\u4fee\u6539\r\n            $(\"#step2 p.g_code_over\").html(\"\u8bf7\u5728\u79fb\u52a8\u7aef\u4e0a\u70b9\u51fb\u786e\u8ba4\u4ee5\u767b\u5f55\");\r\n        }\r\n    }\r\n    var QRCodeTip = $(\"#QRCodeTip\").val();\r\n    if (QRCodeTip != \"\") {\r\n        $(\"#quickCodeMsg\").html(QRCodeTip);\r\n    }\r\n\r\n    //\u91cd\u65b0\u52a0\u8f7d\u4e8c\u7ef4\u7801\r\n    function refrushEwm() {\r\n        window.location.reload();\r\n    }\r\n\r\n    function loopStatus() {\r\n\r\n        jQuery.ajax({\r\n            url: _CP_ + \"/getauthstatus/v2\",\r\n            type: 'post',\r\n            async: true,\r\n            data: {\r\n                \"enc\": enc, \"uuid\": uuid, \"doubleFactorLogin\": $('#doubleFactorLogin').val(),\r\n                \"forbidotherlogin\": $('#forbidotherlogin').val()\r\n            },\r\n            dataType: 'json',\r\n            success: function (data) {\r\n                if (c >= 50) {\r\n                    window.clearInterval(qrInterValObj);//\u505c\u6b62\u8ba1\u65f6\u5668\r\n                    $(\".ewmDisable\").show();\r\n                    //window.location.reload();\r\n                }\r\n                c++;//\u8bb0\u5f55\u5faa\u73af\u6b21\u6570\r\n                if (data.status) {\r\n                    window.clearInterval(qrInterValObj);//\u505c\u6b62\u8ba1\u65f6\u5668\r\n                    $(\"#logining\").show();\r\n                    if (ref != \"undefined\" && ref != '') {\r\n                        var url;\r\n                        if (ref == window.location.href) {\r\n                            url = \"http://i.mooc.chaoxing.com/space/index\";\r\n                        } else {\r\n                            url = ref;\r\n                        }\r\n\r\n                        if (data['containTwoFactorLogin']) {\r\n                            url = data['twoFactorLoginPCUrl'] + \"&refer=\" + encodeURIComponent(url);\r\n                        }\r\n\r\n                        if (top.location != self.location) {\r\n                            top.location = url;\r\n                        } else {\r\n                            window.location = url;\r\n                        }\r\n                    } else {\r\n                        var url = \"http://i.mooc.chaoxing.com/space/index\";\r\n\r\n                        if (data['containTwoFactorLogin']) {\r\n                            url = data['twoFactorLoginPCUrl'] + \"&_blank=\" + _blank + \"&refer=\" + encodeURIComponent(url);\r\n                        }\r\n\r\n                        if (window.parent != this.window) {\r\n                            window.open(url, \"_blank\");\r\n                        } else {\r\n                            location.href = url;\r\n                        }\r\n                    }\r\n                } else {\r\n                    if (data.type == 4) {//\r\n                        $(\"#shownickname\").html(data.nickname);\r\n                        $(\"#photo\").attr('src', \"http://photo.chaoxing.com/p/\" + data.uid + \"_160\");\r\n                        $(\"#step1\").hide();\r\n                        $(\"#step2\").show();\r\n                    } else if (data.type == 6) {//\u5ba2\u6237\u7aef\u53d6\u6d88\r\n                        location.reload();\r\n                    } else if (data.type == 7) {\r\n                        util.showMsg(true, \"err-txt\", data['mes']);\r\n                        $(\"#shownickname\").html(\"\");\r\n                        $(\"#photo\").attr('src', \"\");\r\n                        $(\"#step1\").show();\r\n                        $(\"#step2\").hide();\r\n                        refreshQRCode();\r\n                    }\r\n                }\r\n            }\r\n\r\n        });\r\n    }\r\n\r\n    if ($(\"#refer\").val().indexOf(\"ahszk.portal.chaoxing.com\") != -1) {\r\n        $(\"#quickCodeMsg\").html(\"\u4f7f\u7528\u79fb\u52a8\u7aef\u626b\u7801\u767b\u5f55\");\r\n        $(\"#ahszk_custom\").show();\r\n    } else {\r\n        $(\"#ahszk_custom\").hide();\r\n    }\r\n    if (navigator.userAgent.indexOf(\"1000332\") != -1 ||\r\n            (ref && ref.indexOf(\"xidianLoginComplete\") > -1)) {\r\n        $(\"#rightdiv\").css(\"position\", \"relative\");\r\n        $(\"#rightdiv\").css(\"margin\", \"0 auto\");\r\n        $(\"#rightdiv\").css(\"border-left\", \"0 \");\r\n        $(\"#quickCodeMsg\").html(\"\u4f7f\u7528\u5b66\u5728\u897f\u7535\u626b\u7801\u767b\u5f55\");\r\n    }\r\n\r\n    if ($(\"#refer\").val().indexOf(\"dayi100.com\") != -1) {\r\n        $(\"#quickCodeMsg\").html(\"\u4f7f\u7528\u5927\u533b\u7cbe\u8bdaAPP\u626b\u7801\u767b\u5f55\");\r\n    }\r\n\r\n    function setTab(name, cursel, n) {\r\n        for (i = 1; i <= n; i++) {\r\n            var menu = document.getElementById(name + i);\r\n            var con = document.getElementById(\"con_\" + name + \"_\" + i);\r\n            menu.className = i == cursel ? \"ewmCur\" : \"\";\r\n            con.style.display = i == cursel ? \"block\" : \"none\";\r\n        }\r\n    }\r\n\r\n    /**\r\n     * \u89e3\u51b3windows\u4e0bfont-weight=500\u65f6\u65e0\u6548\u679c\u7684\u95ee\u9898\r\n     */\r\n    if ($('.ewmCur').length > 0) {\r\n        OSnow();\r\n    }\r\n\r\n    function OSnow() {\r\n        var agent = navigator.userAgent.toLowerCase();\r\n        var isMac = /macintosh|mac os x/i.test(navigator.userAgent);\r\n        var fontCss = $('.ewmCur');//\u5b57\u4f53\u52a0\u7c97\r\n        //var letterCss = $('.letterSpace');//\u5b57\u95f4\u8ddd\r\n        if (agent.indexOf(\"win32\") >= 0 || agent.indexOf(\"wow32\") >= 0) {\r\n            fontCss.css(\"font-weight\", \"600\")\r\n        }\r\n        if (agent.indexOf(\"win64\") >= 0 || agent.indexOf(\"wow64\") >= 0) {\r\n            fontCss.css(\"font-weight\", \"600\")\r\n        }\r\n        if (isMac) {\r\n            fontCss.css(\"font-weight\", \"500\")\r\n        }\r\n    }\r\n\r\n    //\uff08\u91cd\u65b0\uff09\u52a0\u8f7d\u4e8c\u7ef4\u7801\r\n    function refreshQRCode() {\r\n        jQuery.ajax({\r\n            url: \"/refreshQRCode\",\r\n            type: 'post',\r\n            async: true,\r\n            dataType: 'json',\r\n            success: function (data) {\r\n                enc = data.enc;\r\n                uuid = data.uuid;\r\n                $('#uuid').val(uuid);\r\n                $('#enc').val(enc);\r\n                $(\".ewmDisable\").hide();\r\n                $(\"#quickCode\").attr(\"src\", \"/createqr?uuid=\" + uuid + \"&fid=-1\")\r\n            }\r\n        });\r\n    }\r\n\r\n</script>\r\n            \r\n            \r\n        </div>\r\n        <!--\u9ed8\u8ba4\u767b\u5f55 end-->\r\n        <!--\u901a\u77e5-->\r\n        <div class=\"lg-notice\" id=\"notice\" style=\"display:none;\">\r\n                            <h2 class=\"msg-title\">\u901a\u77e5</h2>\r\n                        <p id=\"noticeContent\">\r\n\r\n            </p>\r\n        </div>\r\n    </div>\r\n    <!--\u767b\u5f55 end-->\r\n            <div class=\"filingBox\">\r\n            <p>\r\n                <span>Copyright \u00a9 <t id=\"cur_year\"></t> \u5317\u4eac\u4e16\u7eaa\u8d85\u661f\u4fe1\u606f\u6280\u672f\u53d1\u5c55\u6709\u9650\u8d23\u4efb\u516c\u53f8 <a class=\"col-blue\"\r\n                                                                                                href=\"https://beian.miit.gov.cn\">\u4eacICP\u590710040544\u53f7-2</a></span>\r\n                <span class=\"icpSpan\"><i></i>\r\n                    <a class=\"col-blue\"\r\n                       href=\"http://www.beian.gov.cn/portal/registerSystemInfo?recordcode=11010802021885\">\u4eac\u516c\u7f51\u5b89\u5907 11010802021885\u53f7</a></span>\r\n            </p>\r\n        </div>\r\n    </div>\r\n\r\n\r\n<script type=\"text/javascript\" src=\"https://passport2-static.chaoxing.com/js/fanya/login.js?v=2026012301\"></script>\r\n<script>\r\n\r\n    //pc\u5b66\u4e60\u901a\u6837\u5f0f\u5904\u7406\r\n    if (isPcXxtClient()) {\r\n        pcXxtWidthHandler(1);\r\n    }\r\n\r\n    var capInstance = null;//\u5bc6\u7801\u6ed1\u52a8\u6821\u9a8c\u7528\r\n    // let twoLogincapInstance  = null;//\u53cc\u56e0\u5b50\u767b\u5f55\u6ed1\u52a8\u6821\u9a8c\u7528\r\n    $(function () {\r\n        initTelList();\r\n        let needVcode = $(\"#needVcode\").val();\r\n        if (needVcode == \"1\") {\r\n            loadSlide(null, function () {\r\n                loginByPhoneAndPwdSubmit();\r\n            });\r\n        }\r\n        try {\r\n            jsBridge.postNotification(\"CLIENT_PC_CHANGE_WINDOW_SIZE\", {\r\n                width: 420,\r\n                height: 610,\r\n            })\r\n        } catch (e) {\r\n        }\r\n\r\n    });\r\n\r\n    // \u5907\u6848\u4fe1\u606f \u6837\u5f0f\u5b9a\u5236\r\n    if ($(\".filingBox\").length > 0) {\r\n        $(\".lg-container .main\").addClass(\"heightCalc\")\r\n    } else {\r\n        $(\".lg-container .main\").removeClass(\"heightCalc\")\r\n    }\r\n\r\n    //pc\u5b66\u4e60\u901a\u6839\u636eappid\u5b9a\u5236\u663e\u793a\r\n    var pc_ua = navigator.userAgent;\r\n    if (pc_ua.indexOf(\"1000381\") > -1 || pc_ua.indexOf(\"1000397\") > -1 || pc_ua.indexOf(\"ktboard\") > -1) {\r\n        $('.automatic').hide();\r\n        $('.line-bord').hide();\r\n        $('.toRegister_a').removeClass(\"fr\").addClass(\"blackboard-reg\");\r\n        $('#kf').hide();\r\n    }\r\n\r\n    var cur_year = new Date().getFullYear();\r\n    $(\"t#cur_year\").text(cur_year);\r\n\r\n    function clickAutoLoginBox() {\r\n        $('.auto-login_check_box').toggleClass('checked');\r\n        jsBridge.bind('CLIENT_SET_AUTOLOGIN', function (object) {\r\n            console.log(object);\r\n            if (object.result == 1) {\r\n                var data = eval(\"(\" + object.data + \")\");\r\n\r\n                jsBridge.unbind('CLIENT_SET_AUTOLOGIN');\r\n            }\r\n        });\r\n        jsBridge.postNotification('CLIENT_SET_AUTOLOGIN', {enable: $('.auto-login_check_box').hasClass('checked')});\r\n    }\r\n\r\n</script>\r\n<div id=\"captcha\"></div>\r\n</body>\r\n</html>\r\n"}, "bodySize":8215, "headersSize":391, "cookies":[{"httpOnly":true, "value":"DEEBC87C2B3E948DD92903825BF4AB0E", "name":"JSESSIONID"}, {"value":"8dfd6a50c03ca82e777f66522126acd1", "name":"route"}], "statusText":"OK", "headers":[{"value":"Fri, 06 Mar 2026 04:24:37 GMT", "name":"Date"}, {"value":"text/html;charset=UTF-8", "name":"Content-Type"}, {"value":"Accept-Encoding", "name":"Vary"}, {"value":"JSESSIONID=DEEBC87C2B3E948DD92903825BF4AB0E; Path=/; HttpOnly", "name":"Set-Cookie"}, {"value":"route=8dfd6a50c03ca82e777f66522126acd1; Path=/", "name":"Set-Cookie"}, {"value":"?0", "name":"Origin-Agent-Cluster"}, {"value":"max-age=31536000; includeSubDomains", "name":"Strict-Transport-Security"}, {"value":"gzip", "name":"Content-Encoding"}, {"value":"8215", "name":"Content-Length"}], "status":200, "httpVersion":"HTTP/1.1"}, "time":76, "cache":{}, "timings":{"blocked":-1, "ssl":28.0773, "dns":0, "receive":1, "connect":48.0773, "wait":25, "send":2}, "request":{"queryString":[{"value":"true", "name":"newversion"}, {"value":"https://office.chaoxing.com/front/third/apps/seat/index?fidEnc=4a18e12602b24c8c", "name":"refer"}], "headers":[{"value":"1", "name":"upgrade-insecure-requests"}, {"value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36", "name":"user-agent"}, {"value":"text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8,application/signed-exchange;v=b3;q=0.7", "name":"accept"}, {"value":"none", "name":"sec-fetch-site"}, {"value":"navigate", "name":"sec-fetch-mode"}, {"value":"?1", "name":"sec-fetch-user"}, {"value":"document", "name":"sec-fetch-dest"}, {"value":"\"Not:A-Brand\";v=\"99\", \"Google Chrome\";v=\"145\", \"Chromium\";v=\"145\"", "name":"sec-ch-ua"}, {"value":"?0", "name":"sec-ch-ua-mobile"}, {"value":"\"Windows\"", "name":"sec-ch-ua-platform"}, {"value":"gzip, deflate, br, zstd", "name":"accept-encoding"}, {"value":"zh-CN,zh;q=0.9", "name":"accept-language"}, {"value":"u=0, i", "name":"priority"}, {"value":"passport2.chaoxing.com", "name":"host"}], "postData":{"text":"", "mimeType":""}, "bodySize":0, "headersSize":823, "cookies":[], "method":"GET", "url":"https://passport2.chaoxing.com/login?newversion=true&refer=https%3A%2F%2Foffice.chaoxing.com%2Ffront%2Fthird%2Fapps%2Fseat%2Findex%3FfidEnc%3D4a18e12602b24c8c", "httpVersion":"HTTP/2"}, "startedDateTime":"2026-03-06T12:24:36.1525014+08:00", "connection":"ClientPort:64236;EgressPort:64239", "serverIPAddress":"45.113.20.12"}, {"_publicFiddlerId":97, "response":{"redirectURL":"", "content":{"mimeType":"text/html;charset=UTF-8", "compression":46603, "size":58666, "text":"<!DOCTYPE html>\r\n<html>\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=0\">\r\n  <meta name=\"format-detection\" content=\"telephone=no\">\r\n  <title>\u5ea7\u4f4d\u9884\u7ea6</title>\r\n<base href=\"https://office.chaoxing.com/\">\r\n<script type=\"text/javascript\">\r\n  var photoUrl = 'http://photo.chaoxing.com'\r\n  var panUrl = 'http://pan-yz.chaoxing.com'\r\n  var noteUrl = 'http://noteyd.chaoxing.com'\r\n  var staticDomain = 'https://office-static.chaoxing.com/r/'\r\n  photoUrl = document.location.protocol + photoUrl.split(\":\")[1]\r\n  panUrl = document.location.protocol + panUrl.split(\":\")[1]\r\n  noteUrl = document.location.protocol + noteUrl.split(\":\")[1]\r\n  if (staticDomain !== '') {\r\n    staticDomain = document.location.protocol + staticDomain.split(\":\")[1]\r\n  }\r\n</script>\r\n\r\n<link rel=\"stylesheet\" href=\"https://office-static.chaoxing.com/r/staticreserve/style/reset.css\">\r\n<link rel=\"stylesheet\" href=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/seat.css\">\r\n<link rel=\"stylesheet\" href=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/reserve/iphonex.css\">\r\n<link rel=\"stylesheet\" href=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/reserve/reserve_mobile.css\">\r\n<script src=\"https://office-static.chaoxing.com/r/staticreserve/js/lib/jquery/jquery.min.js\"></script>\r\n<script src=\"https://office-static.chaoxing.com/r/staticreserve/js/lib/wy/YiDunProtector-Web-2.1.4.js\"></script>\r\n<script>document.write(\"<script src='https://captcha.chaoxing.com/load-d.min.js?t=\" + parseInt(Date.now()/60000) + \"'><\\/script>\");</script>\r\n<script>document.write(\"<script src='https://captcha.chaoxing.com/light.js?t=\" + parseInt(Date.now()/60000) + \"'><\\/script>\");</script>\r\n<script type=\"text/javascript\" src=\"//api.map.baidu.com/api?type=webgl&v=1.0&ak=p7HrxjMD6R1hbPFP9sNgkfHjsNZumBai\"></script>\r\n<script>document.write(\"<script src='https://cstaticdun.126.net/load.min.js?t=\" + parseInt(Date.now()/60000) + \"'><\\/script>\");</script>\r\n<script type=\"text/javascript\" src=\"https://office-static.chaoxing.com/r/staticreserve/js/lib/requirejs/require.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"https://office-static.chaoxing.com/r/staticreserve/js/src/front/apps/seat/main.js?t=2026021017\"></script>\r\n<script>requirejs.config({urlArgs: 't=2026021017'})</script>\r\n</head>\r\n<body>\r\n<div class=\"seat_index\" v-cloak>\r\n  <div class=\"page_header\">\r\n    <div class=\"user_login\">\r\n      <div class=\"user_login_info\" v-if=\"seatConfig.thirdpartLoginoutShow!=2\">\r\n        <div class=\"user_login_avatar\"><img :src=\"photoDomain + '/p/'+userInfo.uid+'_50'\" alt=\"\"/></div>\r\n        <span class=\"user_login_name\">{{userInfo.uname}}</span>\r\n      </div>\r\n      <div class=\"user_login_info\" v-else>\r\n        <span class=\"user_login_name\">{{userInfo.uname}}</span>\r\n        <span class=\"user_login_name\" style=\"margin-left: 10px; max-width: 5rem;\"> {{userInfo.sno}}</span>\r\n      </div>\r\n      <div class=\"user_login_operate\" v-if=\"seatConfig.thirdpartLoginoutShow!=2\">\r\n        <div class=\"user_login_btn\" v-if=\"roleChangeBtnShow\" @click=\"goManagePage\">\u5207\u6362\u8eab\u4efd</div>\r\n        <div class=\"user_login_btn\" v-if=\"!hideLoginOut && seatConfig.thirdpartLoginoutShow!=0\" @click=\"logOutShow=true\">\u9000\u51fa\u767b\u5f55</div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <ul class=\"sind_top\">\r\n    <li class=\"sind_top_btn\" @click=\"toSeatListPage\" v-if=\"reservationEntrance.defaultReserve\">\r\n      <img src=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_yuyue.png\" alt=\"\" class=\"sind_top_icon\"/>\r\n      <p class=\"sind_top_word\">\u9884\u7ea6\u9009\u5ea7</p>\r\n    </li>\r\n    <li class=\"sind_top_btn\" @click=\"sceneChoseSeat\" v-if=\"reservationEntrance.liveReserve\">\r\n      <img src=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_xinachang.png\" alt=\"\" class=\"sind_top_icon\"/>\r\n      <p class=\"sind_top_word\">\u5feb\u901f\u9009\u5ea7</p>\r\n    </li>\r\n    <li class=\"sind_top_btn\" @click=\"toReserveListPage\">\r\n      <img src=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_jilu.png\" alt=\"\" class=\"sind_top_icon\"/>\r\n      <p class=\"sind_top_word\">\u9884\u7ea6\u8bb0\u5f55</p>\r\n    </li>\r\n    <li class=\"sind_top_btn\" @click=\"goNotice()\" v-if=\"customNoticeShow\">\r\n      <img v-if=\"seatConfig.deptId != 23278\" src=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_xitong.png\" alt=\"\" class=\"sind_top_icon\"/>\r\n      \r\n      <img v-else src=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/icon_data.png\" alt=\"\" class=\"sind_top_icon\"/>\r\n      <p class=\"sind_top_word\">{{seatConfig.noticeName}}</p>\r\n    </li>\r\n    <li class=\"sind_top_btn\" @click=\"toRulePage\" v-if=\"defaultNoticeShow\">\r\n      <img src=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_guize.png\" alt=\"\" class=\"sind_top_icon\"/>\r\n      <p class=\"sind_top_word\">\u89c4\u5219\u8bf4\u660e</p>\r\n    </li>\r\n  </ul>\r\n  <div class=\"sind_cont\">\r\n    \r\n    <div class=\"s_now_nodata\" v-if=\"notCurReserves\">\r\n      <h6 class=\"s_now_title\">\u5f53\u524d\u9884\u7ea6</h6>\r\n      <div class=\"s_now_cont\"><span>\u6682\u65e0\u9884\u7ea6</span></div>\r\n    </div>\r\n    \r\n    <div class=\"s_now\" :class=\"{wait: curReserve.status == 0,leave:curReserve.status == 3,leave:curReserve.status == 5}\" v-if=\"!notCurReserves\" v-for=\"curReserve in curReserves\">\r\n      <h6 class=\"s_now_title\">\r\n        <span>\u5f53\u524d\u9884\u7ea6</span>\r\n        <span class=\"s_now_btn\" @click.stop=\"toggleReserveInfo(curReserve)\">\u51fa\u793a\u9884\u7ea6\u4fe1\u606f</span>\r\n        <span class=\"s_now_type\" v-if=\"curReserve.status === 0\">\u5f85\u5c65\u7ea6</span>\r\n        <span class=\"s_now_type\" v-if=\"curReserve.status === 1\">\u4f7f\u7528\u4e2d</span>\r\n        <span class=\"s_now_type\" v-if=\"curReserve.status === 3\">\u6682\u79bb\u4e2d</span>\r\n        <span class=\"s_now_type\" v-if=\"curReserve.status === 5\">\u88ab\u76d1\u7763\u4e2d</span>\r\n      </h6>\r\n      <dl class=\"s_now_cont\">\r\n        <dt>\r\n          <h6 class=\"s_now_name owt1\">{{curReserve.seatNum}}\u53f7\u5ea7\u4f4d</h6>\r\n          <p class=\"s_now_addr owt1\">\r\n            {{curReserve.firstLevelName}}<span v-if=\"curReserve.secondLevelName\">-{{curReserve.secondLevelName}}</span><span v-if=\"curReserve.thirdLevelName\">-{{curReserve.thirdLevelName}}</span>\r\n          </p>\r\n          <p class=\"s_now_time owt1\" v-if=\"curReserve.status === 1 || curReserve.status === 3 || curReserve.status === 5\">\u5269\u4f59\u65f6\u957f&nbsp;&nbsp;&nbsp;{{countDown}}</p>\r\n          <p class=\"s_now_time owt1\" v-else>{{curReserve.startTime |\r\n            format('YYYY-MM-DD')}}<span>{{curReserve.startTime | format('HH:mm')}}-{{curReserve.endTime | format('HH:mm')}}</span><span>{{curReserve.duration}}\u5c0f\u65f6</span></p>\r\n        </dt>\r\n        <dd>\r\n          <ul class=\"s_now_btns\">\r\n            <li class=\"s_btn qd\" v-if=\"unlockBtnShow\" @click=\"unlock(curReserve)\">{{unlockBtnText}}</li>\r\n            <li class=\"s_btn\" v-if=\"curReserve.status === 1 && curReserve.reserveMode === 0 && showRenewal(curReserve) \" @click=\"reReserve(curReserve.roomId,curReserve.seatNum)\">\r\n              \u7eed\u7ea6\r\n            </li>\r\n            <li class=\"s_btn\" v-if=\"leaveBtnShow(curReserve)\" @click=\"askLeave(curReserve.id)\">\u6682\u79bb</li>\r\n            <li class=\"s_btn tz\" v-if=\"signBackBtnShow(curReserve)\" @click.stop=\"askSignBack(curReserve)\">\u9000\u5ea7</li>\r\n            <li class=\"s_btn qd\" v-if=\"signInBtnShow(curReserve) && !goPayBtnShow(curReserve)\" @click=\"signIn(curReserve)\">\u7b7e\u5230</li>\r\n            <li class=\"s_btn qd\" v-if=\"beSeatedBtnShow(curReserve)\" @click=\"signIn(curReserve)\">\u843d\u5ea7</li>\r\n            <li class=\"s_btn qd\" v-if=\"goPayBtnShow(curReserve)\" @click=\"goPay(curReserve)\">\u53bb\u652f\u4ed8</li>\r\n            <li class=\"s_btn\" v-if=\"curReserve.status === 0\" @click.stop=\"askCancel(curReserve.id)\">\u53d6\u6d88</li>\r\n          </ul>\r\n        </dd>\r\n      </dl>\r\n    </div>\r\n    \r\n    <div class=\"screenMask\" v-if=\"cancelShow || signBackShow || leaveShow || logOutShow || openDialog\"></div>\r\n    <div class=\"quit_pop leave_pop\" v-if=\"cancelShow\">\r\n      <div class=\"quit_top\" style=\"text-align: center\">\u786e\u5b9a\u8981\u53d6\u6d88\u6b64\u6b21\u9884\u7ea6\u5417\uff1f</div>\r\n      <div class=\"quit_btm\">\r\n        <span @click=\"cancel(false)\">\u53d6\u6d88</span>\r\n        <span class=\"quit_sure\" @click=\"cancel(true)\">\u786e\u8ba4</span>\r\n      </div>\r\n    </div>\r\n    <div class=\"quit_pop leave_pop\" v-if=\"signBackShow\">\r\n      <div class=\"quit_top\">\u9000\u5ea7\u540e\u5ea7\u4f4d\u5c06\u88ab\u91ca\u653e\uff0c\u786e\u8ba4\u7ed3\u675f\u672c\u6b21\u4f7f\u7528</div>\r\n      <div class=\"quit_btm\">\r\n        <span @click=\"signBack(false)\">\u53d6\u6d88</span>\r\n        <span class=\"quit_sure\" @click=\"signBack(true)\">\u786e\u8ba4</span>\r\n      </div>\r\n    </div>\r\n    \r\n    <div class=\"quit_pop leave_pop\" v-if=\"leaveShow\">\r\n      <div class=\"quit_top\">\u5ea7\u4f4d\u5c06\u4e3a\u60a8\u4fdd\u7559<br/>\u4f46\u60a8\u9700\u8981\u5728\u89c4\u5b9a\u65f6\u95f4\u5185\u8fd4\u56de<br/>\u5426\u5219\u5ea7\u4f4d\u5c06\u88ab\u91ca\u653e\uff0c\u786e\u5b9a\u6682\u79bb\u5417\uff1f</div>\r\n      <div class=\"quit_btm\">\r\n        <span @click=\"leave(false)\">\u53d6\u6d88</span>\r\n        <span class=\"quit_sure\" @click=\"leave(true)\">\u786e\u8ba4</span>\r\n      </div>\r\n    </div>\r\n    <template v-if=\"reservationEntrance.recentlyReserve\">\r\n      <h6 class=\"s_near_title\">\u6700\u8fd1\u9884\u7ea6</h6>\r\n      \r\n      <div class=\"s_near_nodata\" v-if=\"notNearReserves\">\r\n        <div class=\"nera_nodata_img\"></div>\r\n        <p class=\"near_nodata_word\">\u6682\u65e0\u6700\u8fd1\u9884\u7ea6</p>\r\n      </div>\r\n      \r\n      <ul class=\"s_near_data\" v-if=\"!notNearReserves\">\r\n        <li class=\"s_near_info\" v-for=\"data in nearReserves\">\r\n          <h6 class=\"s_name\">{{data.seatNum}}\u53f7\u5ea7\u4f4d\r\n            <label class=\"s_time\"><span>{{data.startTime | format('HH:mm')}}-{{data.endTime | format('HH:mm')}}</span><span>{{data.duration}}\u5c0f\u65f6</span></label></h6>\r\n          <p class=\"s_addr\">{{data.firstLevelName}} <span class=\"s_btn\" @click=\"reReserve(data.roomId,data.seatNum)\" v-if=\"reservationEntrance.againReserve\">\u518d\u6b21\u9884\u7ea6</span></p>\r\n        </li>\r\n      </ul>\r\n    </template>\r\n    \r\n    <div class=\"cal_pop\" v-if=\"logOutShow\">\r\n      <div class=\"cal_top\">\u786e\u5b9a\u9000\u51fa\u8d26\u53f7?</div>\r\n      <div class=\"cal_btm\">\r\n        <span @click=\"logOutShow=false\">\u53d6\u6d88</span>\r\n        <span class=\"wait_sure\" @click=\"logOut\">\u786e\u8ba4</span>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  \r\n  <div class=\"reminder_pop\" v-show=\"openDialog\">\r\n    <h6 class=\"rp_top\" v-show=\"openDialogType == 0\">{{seatConfig.dialogTitle}}</h6>\r\n    <h6 class=\"rp_top\" v-show=\"openDialogType == 1\">{{seatConfig.noticeName}}</h6>\r\n    <div class=\"rp_cont\">\r\n      <div id=\"rich_text\"></div>\r\n    </div>\r\n    <div class=\"notice_confirm\" v-show=\"openDialogType == 0 && seatConfig.dialogAgree == 1\">\r\n      <span class=\"icon_radio\" :class=\"{'icon_check': dialogAgreeStatus}\" @click=\"dialogAgreeStatus = !dialogAgreeStatus\"></span>\r\n      <span>\u6211\u5df2\u9605\u8bfb\u5e76\u540c\u610f\u76f8\u5173\u5185\u5bb9</span>\r\n    </div>\r\n    <div class=\"rp_bottom\">\r\n      <span class=\"rp_cal\" v-show=\"openDialogType == 0\" @click=\"back()\">\u53d6\u6d88</span>\r\n      <span class=\"rp_sure\" :class=\"{disabled: openDialogType == 0 && seatConfig.dialogAgree == 1 && !dialogAgreeStatus}\" @click=\"start()\">\u5f00\u59cb\u9884\u7ea6</span>\r\n    </div>\r\n  </div>\r\n  \r\n  <div class=\"screenMask\" style=\"z-index: 3\" v-if=\"bindSnoShow\"></div>\r\n  \r\n  <div class=\"reminder_pop\" style=\"z-index: 4\" v-if=\"bindSnoShow\">\r\n    <h6 class=\"rp_top\">\u7ed1\u5b9a\u63d0\u793a</h6>\r\n    <div class=\"rp_cont\">\r\n      <p class=\"rp_cont_word\">\u60a8\u672a\u7ed1\u5b9a\u5b66\u5de5\u53f7/\u4e00\u5361\u901a\u8d26\u53f7\uff0c\u65e0\u6cd5\u4f7f\u7528\u5168\u90e8\u529f\u80fd\uff0c\u8bf7\u7ed1\u5b9a\u540e\u518d\u9884\u7ea6</p>\r\n    </div>\r\n    <div class=\"rp_bottom\">\r\n      <span class=\"rp_cal\" @click=\"back()\">\u53d6\u6d88</span>\r\n      <span class=\"rp_sure\" @click=\"goBindSno()\">\u53bb\u7ed1\u5b9a</span>\r\n    </div>\r\n  </div>\r\n  \r\n  <div class=\"pop_wrap\" v-show=\"qrCodeDialog.show\">\r\n    <div class=\"code_pop\">\r\n      \r\n      <template v-if=\"showCode\">\r\n        <div class=\"code_pic\" v-if=\"!qrCodeDialog.isSign\">\r\n          <img v-show=\"qrCodeDialog.imgShow\" :src=\"qrCodeDialog.url\" alt=\"\">\r\n          <span>\u8bf7\u5c06\u4e8c\u7ef4\u7801\u5bf9\u51c6\u626b\u7801\u8bbe\u5907\u626b\u63cf</span>\r\n        </div>\r\n        <div class=\"success_tip\" v-else>\r\n          <span class=\"error_pic\"></span>\r\n          <h1>\u7b7e\u5230\u6210\u529f</h1>\r\n        </div>\r\n      </template>\r\n      \r\n      <div class=\"psd_box\" v-if=\"seatConfig.qrcodeOpen == 22\">\r\n        <span class=\"psd_pic\"></span>\r\n        <h1 class=\"psd_num\">{{qrCodeDialog.password}}</h1>\r\n        <p class=\"psd_txt\">\u8bf7\u5728\u9884\u7ea6\u533a\u57df\u95e8\u7981\u8bbe\u5907\u5904\u8f93\u5165\u6b64\u5bc6\u7801</p>\r\n      </div>\r\n      <div class=\"pop_btm\" @click=\"location.reload()\">\u5173\u95ed</div>\r\n    </div>\r\n  </div>\r\n  \r\n  <div class=\"pop_wrap\" v-show=\"unlockCodeDialog.show\">\r\n    <div class=\"code_pop\">\r\n      \r\n      <div class=\"code_pic\">\r\n        <img v-show=\"unlockCodeDialog.imgShow\" :src=\"unlockCodeDialog.url\" alt=\"\">\r\n        <span>\u8bf7\u5c06\u4e8c\u7ef4\u7801\u5bf9\u51c6\u626b\u7801\u8bbe\u5907\u626b\u63cf</span>\r\n      </div>\r\n      <div class=\"pop_btm\" @click=\"location.reload()\">\u5173\u95ed</div>\r\n    </div>\r\n  </div>\r\n  \r\n  <transition name=\"model-mask\">\r\n    <div class=\"model-pop-mask reserve-info-pop-mask\" v-if=\"reserveInfo.show\" @click.stop=\"toggleReserveInfo(null)\">\r\n      <div class=\"model-popup reserve-info-pop-wrap\" @click.stop>\r\n        <div class=\"popup-title owt1\">\u9884\u7ea6\u4fe1\u606f</div>\r\n        <span class=\"popup-close\" @click.stop=\"toggleReserveInfo(null)\">\u5173\u95ed</span>\r\n        <div class=\"popup-body\">\r\n          <h1 class=\"reserve-time\">{{reserveInfo.data.startTime | format('HH:mm')}}-{{reserveInfo.data.endTime | format('HH:mm')}}</h1>\r\n          <h2 class=\"reserve-date\">{{reserveInfo.data.startTime | format('YYYY-MM-DD')}}</h2>\r\n          <p class=\"reserve-place owt1\">\r\n            <span>{{reserveInfo.data.firstLevelName}}</span>\r\n            <span v-if=\"reserveInfo.data.secondLevelName\">-{{reserveInfo.data.secondLevelName}}</span>\r\n            <span v-if=\"reserveInfo.data.thirdLevelName\">-{{reserveInfo.data.thirdLevelName}}</span>\r\n            <span>&nbsp;{{reserveInfo.data.seatNum}}&nbsp;\u53f7</span>\r\n          </p>\r\n          <h1 class=\"reserve-userName owt1\">{{reserveInfo.data.uname}}</h1>\r\n          <h1 class=\"reserve-status\"\r\n              :class=\"{'orange': reserveInfo.data.status==0||reserveInfo.data.status==3, 'blue': reserveInfo.data.status==1, 'red': reserveInfo.data.status==5}\">\r\n            {{reserveInfo.data.statusStr}}\r\n          </h1>\r\n          <p class=\"tip-txt\">\u5f53\u524d\u65f6\u95f4</p>\r\n          <p class=\"current-time\">{{reserveInfo.currentTime | format('YYYY-MM-DD HH:mm:ss')}}</p>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </transition>\r\n  \r\n  <div class=\"res_loading\" v-if=\"loadingShow\">\r\n    <div class=\"res_load_cont\">\r\n      <div class=\"loading_iocn\"></div>\r\n      <p class=\"loading_info\">{{tipTitle}}</p>\r\n    </div>\r\n  </div>\r\n</div>\r\n<script>\r\n  window.addEventListener('pageshow', function (e) {\r\n    //\u5982\u679c\u68c0\u6d4b\u5230\u9875\u9762\u662f\u4ece\u201c\u5f80\u8fd4\u7f13\u5b58\u201d\u4e2d\u8bfb\u53d6\u7684\uff0c\u5237\u65b0\u9875\u9762\r\n    if (e.persisted) {\r\n      window.location.reload()\r\n    }\r\n  })\r\n  require(['jquery', 'Vue', 'moment', 'popup', 'jweixin', 'wxinit', 'baseUtils', 'cookies', 'thirdAppUtils', 'multieditor', 'webUploader', 'sortable', 'cropper', 'clipboard',\r\n    'Viewer', 'jrxyUtils',  'sha'], function ($, Vue, moment, popup, wx, wxinit, BaseUtils, Cookies, thirdAppUtils, multieditor, WebUploader, Sortable, Cropper, Clipboard, Viewer, JrxyUtils) {\r\n    'use strict'\r\n    window['WebUploader'] = WebUploader\r\n    window['Sortable'] = Sortable\r\n    window['Cropper'] = Cropper\r\n    window['clipboard'] = Clipboard\r\n    window['Viewer'] = Viewer\r\n    var userLoginInfo = {\"userInfo\":{\"deptId\":22640,\"id\":21466273,\"inserttime\":1772636462000,\"mobile\":\"135****9492\",\"signature\":\"\",\"sno\":\"202234070149\",\"uid\":238771432,\"uname\":\"\u738b\u7ea2\u65b0\",\"updatetime\":1772636462000}}||{}\r\n    var user = userLoginInfo && userLoginInfo.userInfo\r\n    var deptIdEnc = '4a18e12602b24c8c',\r\n        mark = '0',\r\n        serverNow = new Date('2026-03-06T12:25:14.183+08:00'),\r\n        mappId = '0',\r\n        pageKey = 'seat_index_page_' + Cookies.get('oa_deptid') + '_' + Cookies.get('oa_uid'),\r\n        dialogKey = 'seat_dialog_' + Cookies.get('oa_deptid') + '_' + Cookies.get('oa_uid')\r\n    function operateData(url, data) {\r\n      return $.getJSON(url, data)\r\n    }\r\n    function signInScan(_this, data) {\r\n      var now = moment()\r\n      //\u5224\u65ad\u662f\u5426\u5b58\u5728\u672a\u7b7e\u9000\u5ea7\u4f4d\r\n      operateData('data/apps/seat/check/exist', {seatNum: data.seatNum, roomId: data.roomId}).then(function (json) {\r\n        if (json.success) {\r\n          if (json.data.existCount > 0) {\r\n            popup.alert('\u60a8\u5b58\u5728\u672a\u7b7e\u9000\u5ea7\u4f4d\uff0c\u4e0d\u53ef\u518d\u6b21\u7b7e\u5230')\r\n          } else {\r\n            var scannerType = wxinit.getScannerType()\r\n            scannerType = BaseUtils.getThirdScannerDept(_this.seatConfig.deptId, scannerType)\r\n            if (data.status === 0 || data.status === 3 || data.status === 5) {\r\n              if (data.status === 0) {\r\n                var signDuration = json.data.signDuration\r\n                var preSignDuration = json.data.preSignDuration //\u5b9a\u5236\u9700\u6c42\uff0c\u5f39\u6027\u7b7e\u5230\u53ea\u80fd\u5411\u540e\u5f39\r\n                if (signDuration === -1) {\r\n                  if (now.isBefore(moment(data.startTime).add(-preSignDuration, 'minutes'))) {\r\n                    popup.alert('\u8fd8\u672a\u5230\u7b7e\u5230\u65f6\u95f4')\r\n                    return\r\n                  }\r\n                  if (now.isAfter(moment(data.endTime))) {\r\n                    popup.alert('\u7b7e\u5230\u65f6\u95f4\u5df2\u8fc7', '\u786e\u8ba4', function () {\r\n                      location.reload()\r\n                    })\r\n                    return\r\n                  }\r\n                } else {\r\n                  if (now.isBefore(moment(data.startTime).add(-preSignDuration, 'minutes'))) {\r\n                    popup.alert('\u8fd8\u672a\u5230\u7b7e\u5230\u65f6\u95f4')\r\n                    return\r\n                  }\r\n                  if (moment(data.expireTime).isBefore(now)) {\r\n                    popup.alert('\u7b7e\u5230\u65f6\u95f4\u5df2\u8fc7', '\u786e\u8ba4', function () {\r\n                      location.reload()\r\n                    })\r\n                    return\r\n                  }\r\n                }\r\n              }\r\n              if (data.status === 3 || data.status === 5) {\r\n                if (moment(data.expireTime).isBefore(now)) {\r\n                  popup.alert('\u843d\u5ea7\u65f6\u95f4\u5df2\u8fc7')\r\n                  location.reload()\r\n                  return\r\n                }\r\n              }\r\n              if (_this.showCode) {\r\n                getQrcode(_this, data)\r\n                return\r\n              }\r\n              //\u5224\u65ad\u662f\u5426\u9700\u8981\u626b\u7801\r\n              if (data.isPosition === 2) {//\u4ec5\u5224\u65ad\u4f4d\u7f6e\r\n                location.href = location.origin + '/front/third/apps/seat/code?seatNum=' + data.seatNum + '&id=' + data.roomId\r\n              } else if (data.isPosition === 0 || data.isPosition === 1) {//\u626b\u5ea7\u4f4d\u7801\r\n                switch (scannerType) {\r\n                  case 0:\r\n                    wx.scanQRCode({\r\n                      needResult: 1,\r\n                      desc: 'scanQRCode desc',\r\n                      success: function (res) {\r\n                        var qrUrl = res.resultStr\r\n                        if (qrUrl != undefined && qrUrl != null && qrUrl != '' && qrUrl.indexOf('front/apps/seat/code') != -1) {\r\n                          location.href = qrUrl + '&num=' + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId\r\n                        } else {\r\n                          popup.alert('\u8bf7\u626b\u63cf\u6b63\u786e\u7684\u4e8c\u7ef4\u7801')\r\n                        }\r\n                      }\r\n                    })\r\n                    break\r\n                  case 1:\r\n                    location.href = 'http://sao315.com/w/api/saoyisao?redirect_uri=' + encodeURIComponent(location.href + '&num='\r\n                        + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId)\r\n                    break\r\n                  case 2:\r\n                    location.href = 'https://office.chaoxing.com/api/wx/front/apps/reserve/scanner?redirect_uri=' +\r\n                        encodeURIComponent(location.href + '&num='\r\n                            + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId)\r\n                    break\r\n                  case 124841:\r\n                    thirdAppUtils.barcode.scan().then(function (res) {\r\n                      location.href = res + '&num=' + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId\r\n                    })\r\n                    break\r\n                  case 23677:\r\n                    thirdAppUtils.barcode.lzcsScan().then(function (res) {\r\n                      location.href = res + '&num=' + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId\r\n                    })\r\n                    break\r\n                  case 33155:\r\n                    setTimeout(function () {\r\n                      if (_this.initJrxyApiSuccess) {\r\n                        JrxyUtils.scan($.Deferred()).done(function (res) {\r\n                          if (res.success) {\r\n                            location.href = res.url + '&num=' + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId\r\n                          } else {\r\n                            popup.alert('\u626b\u7801\u5931\u8d25')\r\n                          }\r\n                        })\r\n                      } else {\r\n                        popup.alert('\u4eca\u65e5\u6821\u56ed\u73af\u5883\u521d\u59cb\u5316\u5931\u8d25\uff0c\u8bf7\u5237\u65b0\u9875\u9762\u91cd\u8bd5')\r\n                      }\r\n                    }, 1000)\r\n                    break\r\n                  default:\r\n                    break\r\n                }\r\n              } else if (data.isPosition === 3 || data.isPosition === 7) {//\u626b\u7edf\u4e00\u4e8c\u7ef4\u7801\r\n                switch (scannerType) {\r\n                  case 0:\r\n                    wx.scanQRCode({\r\n                      needResult: 1,\r\n                      desc: 'scanQRCode desc',\r\n                      success: function (res) {\r\n                        var qrUrl = res.resultStr\r\n                        if (qrUrl != undefined && qrUrl != null && qrUrl != '' && qrUrl.indexOf('front/apps/seat/unified/code') != -1) {\r\n                          location.href = qrUrl + '&seatNum=' + parseInt(data.seatNum) + '&reserveId=' + data.id + '&id=' + data.roomId\r\n                        } else {\r\n                          popup.alert('\u8bf7\u626b\u63cf\u6b63\u786e\u7684\u4e8c\u7ef4\u7801')\r\n                        }\r\n                      }\r\n                    })\r\n                    break\r\n                  case 1:\r\n                    location.href = 'http://sao315.com/w/api/saoyisao?redirect_uri=' + encodeURIComponent(location.href + '&seatNum=' + parseInt(data.seatNum)\r\n                        + '&reserveId=' + data.id + '&id=' + data.roomId)\r\n                    break\r\n                  case 2:\r\n                    location.href = 'https://office.chaoxing.com/api/wx/front/apps/reserve/scanner?redirect_uri=' +\r\n                        encodeURIComponent(location.href + '&seatNum=' + parseInt(data.seatNum)\r\n                            + '&reserveId=' + data.id + '&id=' + data.roomId)\r\n                    break\r\n                  case 124841:\r\n                    thirdAppUtils.barcode.scan().then(function (res) {\r\n                      location.href = res + '&seatNum=' + parseInt(data.seatNum) + '&reserveId=' + data.id + '&id=' + data.roomId\r\n                    })\r\n                    break\r\n                  case 23677:\r\n                    thirdAppUtils.barcode.lzcsScan().then(function (res) {\r\n                      location.href = res + '&seatNum=' + parseInt(data.seatNum) + '&reserveId=' + data.id + '&id=' + data.roomId\r\n                    })\r\n                    break\r\n                  case 33155:\r\n                    setTimeout(function () {\r\n                      if (_this.initJrxyApiSuccess) {\r\n                        JrxyUtils.scan($.Deferred()).done(function (res) {\r\n                          if (res.success) {\r\n                            location.href = res.url + '&seatNum=' + parseInt(data.seatNum) + '&reserveId=' + data.id + '&id=' + data.roomId\r\n                          } else {\r\n                            popup.alert('\u626b\u7801\u5931\u8d25')\r\n                          }\r\n                        })\r\n                      } else {\r\n                        popup.alert('\u4eca\u65e5\u6821\u56ed\u73af\u5883\u521d\u59cb\u5316\u5931\u8d25\uff0c\u8bf7\u5237\u65b0\u9875\u9762\u91cd\u8bd5')\r\n                      }\r\n                    }, 1000)\r\n                    break\r\n                  default:\r\n                    break\r\n                }\r\n              } else if (data.isPosition === 4) {\r\n                switch (scannerType) {\r\n                  case 0:\r\n                    wx.scanQRCode({\r\n                      needResult: 1,\r\n                      desc: 'scanQRCode desc',\r\n                      success: function (res) {\r\n                        var qrUrl = res.resultStr\r\n                        if (qrUrl != undefined && qrUrl != null && qrUrl != '' && qrUrl.indexOf('front/apps/seat/dynamic/code') != -1) {\r\n                          location.href = qrUrl + '&seatNum=' + parseInt(data.seatNum) + '&reserveId=' + data.id + '&room=' + data.roomId\r\n                        } else {\r\n                          popup.alert('\u8bf7\u626b\u63cf\u6b63\u786e\u7684\u4e8c\u7ef4\u7801')\r\n                        }\r\n                      }\r\n                    })\r\n                    break\r\n                  case 1:\r\n                    location.href = 'http://sao315.com/w/api/saoyisao?redirect_uri=' + encodeURIComponent(location.href + '&seatNum=' + parseInt(data.seatNum)\r\n                        + '&reserveId=' + data.id + '&room=' + data.roomId)\r\n                    break\r\n                  case 2:\r\n                    location.href = 'https://office.chaoxing.com/api/wx/front/apps/reserve/scanner?redirect_uri=' +\r\n                        encodeURIComponent(location.href + '&seatNum=' + parseInt(data.seatNum)\r\n                            + '&reserveId=' + data.id + '&room=' + data.roomId)\r\n            