      text-align: center;\r\n    }\r\n    .seat-number {\r\n      position: absolute;\r\n      left: 50%;\r\n      top: 50%;\r\n      transform: translate(-50%, -50%);\r\n      z-index: -1;\r\n      font-size: 0.2em;\r\n    }\r\n    .seat-inner-div {\r\n      position: relative;\r\n      z-index: -1;\r\n      width: 100%;\r\n      height: 100%;\r\n      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/seat_canSel.png) no-repeat center / contain;\r\n    }\r\n    .seat-blue {\r\n      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/seat_selected.png) no-repeat center / contain;\r\n    }\r\n    .seat-brown {\r\n      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/seat_canSel.png) no-repeat center / contain;\r\n    }\r\n    .seat-gray {\r\n      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/seat_unSel.png) no-repeat center / contain;\r\n    }\r\n    .seat-orange {\r\n      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/seat_supervise.png) no-repeat center / contain;\r\n    }\r\n    .seat_font {\r\n      text-align: center;\r\n    }\r\n    .container-div .cmp_icon {\r\n      position: absolute;\r\n      width: .19em;\r\n      height: .19em;\r\n      top: -.095em;\r\n      right: -.045em;\r\n      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/edit_cmp.png) no-repeat center;\r\n      background-size: contain;\r\n    }\r\n    .container-div .pwr_icon {\r\n      position: absolute;\r\n      width: .19em;\r\n      height: .19em;\r\n      top: -.095em;\r\n      left: -.045em;\r\n      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/edit_pwr.png) no-repeat center;\r\n      background-size: contain;\r\n    }\r\n    .container-div .no_pwr_icon {\r\n      position: absolute;\r\n      width: .19em;\r\n      height: .19em;\r\n      top: -.095em;\r\n      left: -.045em;\r\n      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/edit_no_pwr.png) no-repeat center;\r\n      background-size: contain;\r\n    }\r\n    .container-div .win_icon {\r\n      position: absolute;\r\n      width: .19em;\r\n      height: .19em;\r\n      bottom: -.095em;\r\n      left: -.045em;\r\n      background: url(https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/edit_win.png) no-repeat center;\r\n      background-size: contain;\r\n    }\r\n    .u-layer {\r\n      position: fixed;\r\n      top: 50%;\r\n      left: 53%;\r\n      margin-top: -150px;\r\n      margin-left: -161px;\r\n      display: none;\r\n      z-index: 100000;\r\n    }\r\n  </style>\r\n</head>\r\n<body>\r\n<div class=\"order\" v-cloak>\r\n  <template v-if=\"!submitsuccess\">\r\n    <div class=\"order_top\">\r\n      <h6 class=\"o_title owt2\">{{seatRoom.firstLevelName}}\r\n        <span v-if=\"seatRoom.secondLevelName\">-{{seatRoom.secondLevelName}}</span>\r\n        <span v-if=\"seatRoom.thirdLevelName\">-{{seatRoom.thirdLevelName}}</span>\r\n        <span class=\"pic_sample_btn fr\" v-if=\"gridSampleBtnShow\" @click=\"gridSampleShow=true\">\u56fe\u4f8b</span>\r\n      </h6>\r\n      <p class=\"o_time\">{{chosedDay}}<label>\u5ea7\u4f4d</label></p>\r\n      <div class=\"o_use\">\r\n        <span v-if=\"seatConfig.reserveMode == 0\">\u9009\u62e9\u4f7f\u7528\u65f6\u95f4</span>\r\n        <span v-else>\u4f7f\u7528\u65f6\u95f4</span>\r\n        <em @click=\"openTimes\" v-if=\"dynamicChosedTimeInfo.duration == '' \">\u8bf7\u9009\u62e9</em>\r\n        <em @click=\"openTimes\" v-else>{{dynamicChosedTimeInfo.startTime}} - {{dynamicChosedTimeInfo.endTime}}</em>\r\n        <div class=\"o_use_res\">\r\n          <span v-if=\"!chosedSeatNum\">\u672a\u9009\u62e9</span>\r\n          <label v-if=\"chosedSeatNum\">{{chosedSeatNum}}</label>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div v-if=\"drawSeatMode==0\" class=\"order_cont\">\r\n      <div class=\"order_sign\">\r\n        <label><span class=\"blue\"></span>\u5df2\u9009</label>\r\n        <label><span class=\"white\"></span>\u53ef\u9009</label>\r\n        <label><span class=\"gray\"></span>\u4e0d\u53ef\u9009</label>\r\n        <label v-show=\"seatConfig.freeSupervise==1\"><span class=\"orange\"></span>\u4f7f\u7528\u4e2d</label>\r\n        <label v-for=\"data in seatLabels\"><span :class=\"{pwr_icon:data.id == 1,cmp_icon:data.id == 2,no_pwr_icon:data.id == 3,win_icon:data.id == 4}\"></span>{{data.name}}</label>\r\n      </div>\r\n      <ul class=\"order_data\">\r\n        <li class=\"order_per\" :class=\"[data.cls]\" v-for=\"(data,index) in dynamicSeatNums\" @click=\"choseSeat(data,index)\">\r\n          <span></span>\r\n          <p class=\"order_num\">{{data.seatNum}}</p>\r\n          <em :class=\"{pwr_icon:id == 1,cmp_icon:id == 2,no_pwr_icon:id == 3,win_icon:id == 4}\" v-for=\"id in data.labelIds\"></em>\r\n        </li>\r\n      </ul>\r\n    </div>\r\n    <div v-if=\"drawSeatMode>0 && !(drawSeatMode==2 && gridStyle==1)\" style=\"padding-top: 0.3rem;\">\r\n      <div class=\"order_cont\" style=\"overflow: hidden;padding-top: 0.1rem;padding-bottom: 0.1rem;\">\r\n        <div class=\"order_sign\" style=\"margin-bottom: 0\">\r\n          <label><span class=\"seat-blue\"></span>\u5df2\u9009</label>\r\n          <label><span class=\"seat-brown\"></span>\u53ef\u9009</label>\r\n          <label><span class=\"seat-gray\"></span>\u4e0d\u53ef\u9009</label>\r\n          <label v-show=\"seatConfig.freeSupervise==1\"><span class=\"seat-orange\"></span>\u4f7f\u7528\u4e2d</label>\r\n          <label v-for=\"data in seatLabels\"><span :class=\"{pwr_icon:data.id == 1,cmp_icon:data.id == 2,no_pwr_icon:data.id == 3,win_icon:data.id == 4}\"></span>{{data.name}}</label>\r\n        </div>\r\n        <div v-if=\"drawSeatMode==2\" class=\"order_sign\" style=\"margin-bottom: 0\">\r\n          <label><span class=\"gdesk\"></span>\u684c\u5b50</label>\r\n          <label><span class=\"gdoor\"></span>\u5927\u95e8</label>\r\n          <label><span class=\"gcolumn\"></span>\u67f1\u5b50</label>\r\n          <label><span class=\"gwindow\"></span>\u7a97\u6237</label>\r\n          <label><span class=\"gshelf\"></span>\u4e66\u67b6</label>\r\n          <label><span class=\"gelevator\"></span>\u7535\u68af</label>\r\n          <label><span class=\"gtoilet\"></span>\u536b\u751f\u95f4</label>\r\n          <label><span class=\"gwall\"></span>\u5899\u58c1</label>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div v-if=\"drawSeatMode==1\" id=\"draw_wrapper_out\" class=\"container-out-div\" :class=\"{noScrollBar: !proportionInitial}\">\r\n      <div class=\"container-div\" id=\"container_div\">\r\n        <div v-for=\"(data,index) in drawSeatList\" class=\"seat-div\"\r\n             v-if=\"!data.labelIds || !data.labelIds.includes(5)\"\r\n             @click=\"chooseDrawSeat($event,data,index)\"\r\n             :style=\"{left:(proportion * data.xleft)+'px',top:(proportion * data.ytop)+'px',width:(proportion * data.width)+'px',height:(proportion * data.height)+'px',lineHeight:(proportion * data.height)+'px',fontSize:(proportion * data.width)+'px'}\">\r\n          <div class=\"seat-inner-div\" :class=\"[{ 'seat-blue': data.reserveStatus==1,'seat-gray': data.reserveStatus>=-2 && data.reserveStatus<0,'seat-orange': data.reserveStatus==-3}]\" :style=\"{transform: 'rotate(' + (data.rotate || 0) + 'deg)'}\"></div>\r\n          <span class=\"seat-number\">{{data.seatNum}}</span>\r\n          <em :class=\"{pwr_icon:id == 1,cmp_icon:id == 2,no_pwr_icon:id == 3,win_icon:id == 4}\" v-for=\"id in data.labelIds\"></em>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div v-if=\"drawSeatMode==2\" id=\"wrapper_out\" class=\"container-out-div\">\r\n      <div class=\"layout_grid\" id=\"content-container\" :style=\"{width:(seatScan * proportion * gridWidth)+'px',height:(seatScan * proportion * gridHeight)+'px'}\" v-if=\"gridStyle==0\">\r\n        <div v-for=\"(data,index) in seatGridList\"\r\n             v-if=\"!data.labelIds || !data.labelIds.includes(5)\"\r\n             :class=\"['grid_cell',{'grid_checked': data.reserveStatus==1,'grid_lock': data.reserveStatus < 0 && data.reserveStatus >= -2,\r\n             'grid_seat': data.reserveStatus == 0, 'grid_supervise': data.reserveStatus == -3}]\" @click=\"chooseGridSeat($event,data,index)\"\r\n             :style=\"{transform: 'scale(' + proportion +')',left:(seatScan * proportion *  data.x)+'px',top:(seatScan * proportion *  data.y)+'px'}\">\r\n          {{data.seatNum}}\r\n          <em :class=\"{pwr_icon:id == 1,cmp_icon:id == 2,no_pwr_icon:id == 3,win_icon:id == 4}\" v-for=\"id in data.labelIds\"></em>\r\n        </div>\r\n        <div v-for=\"(data,index) in otherGridList\" :class=\"['grid_cell',{'grid_desk':data.type == 5,'grid_door':data.type == 6,'grid_column':data.type == 7,\r\n          'grid_window':data.type == 8,'grid_shelf':data.type == 9,'grid_elevator':data.type == 10,'grid_toilet':data.type == 11, 'grid_wall':data.type == 12}]\"\r\n             :style=\"{transform: 'scale(' + proportion +')',left:(seatScan * proportion * data.x)+'px',top:(seatScan * proportion * data.y)+'px'}\">\r\n          {{data.label}}<em v-show=\"!data.label\"></em>\r\n        </div>\r\n      </div>\r\n      <div class=\"layout_grid new_layout_bg\" id=\"content-container\":class=\"{post0: !Number.isInteger(proportion)}\" :style=\"{width:(proportion * (gridWidth+1))+'rem',height:(proportion * (gridHeight+1))+'rem'}\" v-else>\r\n        <div v-for=\"(data,index) in seatGridList\"\r\n             v-if=\"!data.labelIds || !data.labelIds.includes(5)\"\r\n             :class=\"['new_grid_cell','new_grid_seat',{'new_grid_checked': data.reserveStatus==1,'new_grid_lock': data.reserveStatus < 0 && data.reserveStatus >= -2,\r\n             'new_grid_supervise': data.reserveStatus==-3}]\" @click=\"chooseGridSeat($event,data,index)\"\r\n             :style=\"{transform: 'scale(' + proportion +')',left:(proportion * (data.x))+'rem',top:(proportion * (data.y))+'rem'}\">\r\n          <em></em>\r\n          <span>{{data.seatNum}}</span>\r\n          <i :class=\"{charge:id == 1,monitor:id == 2,no_charge:id == 3,window:id == 4}\" v-for=\"id in data.labelIds\"></i>\r\n        </div>\r\n        <div v-for=\"(data,index) in otherGridList\" :class=\"['new_grid_cell',{'new_grid_desk':data.type == 5,'new_grid_door':data.type == 6,'new_grid_column':data.type == 7,\r\n          'new_grid_window':data.type == 8,'new_grid_shelf':data.type == 9,'new_grid_elevator':data.type == 10,'new_grid_toilet':data.type == 11,'new_grid_wall':data.type == 12}]\"\r\n             :style=\"{transform: 'scale(' + proportion +')',left:(proportion * (data.x))+'rem',top:(proportion * (data.y))+'rem'}\">\r\n          {{data.label}}<em v-show=\"!data.label\"></em>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"order_bottom\">\r\n      <p class=\"order_submit noClick\" v-if=\"dynamicChosedTimeInfo.duration == 0 && chosedSeatNum == ''\">\u8bf7\u9009\u62e9\u65f6\u95f4\u548c\u5ea7\u4f4d</p>\r\n      <p class=\"order_submit noClick\" v-else-if=\"dynamicChosedTimeInfo.duration == 0 && chosedSeatNum != ''\">\u8bf7\u9009\u62e9\u65f6\u95f4</p>\r\n      <p class=\"order_submit noClick\" v-else-if=\"dynamicChosedTimeInfo.duration != 0 && chosedSeatNum == ''\">\u8bf7\u9009\u62e9\u5ea7\u4f4d</p>\r\n      <p class=\"order_submit\" :class=\"{noClick: dynamicChosedTimeInfo.duration == 0 || chosedSeatNum == ''}\" v-else @click=\"submit()\">\u63d0\u4ea4</p>\r\n    </div>\r\n    \r\n    <div class=\"screenMask\" v-if=\"timesShow || reserveInfo.show\" @click=\"confirmTime(0)\"></div>\r\n    \r\n    <div class=\"look_img\" v-if=\"seatPlanShow(seatRoom)\" @click=\"openSeatPlan(seatRoom)\">\u5ea7\u4f4d<br/>\u5206\u5e03</div>\r\n    \r\n    <div class=\"time_pop\" v-if=\"timesShow\">\r\n      <div class=\"time_top\">\r\n        <span class=\"time_cal\" @click=\"confirmTime(0)\">\u53d6\u6d88</span>\r\n        <em class=\"time_left\" :class=\"getNoClickClass(1)\" @click=\"subtract()\"></em>\r\n        <span style=\"color: #536fff;\">{{chosedDay}}</span>\r\n        <em class=\"time_right\" :class=\"getNoClickClass(2)\" @click=\"add()\"></em>\r\n        <span class=\"time_sure\" @click=\"confirmTime(1)\" v-if=\"chosedSeatNum == ''\">\u786e\u8ba4</span>\r\n        <span class=\"time_sure\" @click=\"confirmTime(2)\" v-else>\u63d0\u4ea4</span>\r\n      </div>\r\n      <ul class=\"time_data\">\r\n        <li class=\"time_cell\" :class=\"[data.cls, {'time_cell_split': isTimeSplit(data, dynamicTimes[index+1])}]\" v-for=\"(data,index) in dynamicTimes\" @click=\"choseTime(data,index)\">{{data.time}}</li>\r\n      </ul>\r\n      <p class=\"time_tip\" style=\"line-height:.6rem;padding:0 .3rem;font-size:.24rem;color:#999;text-align:center;\">\u70b9\u51fb\u9009\u62e9\u5f00\u59cb\u548c\u7ed3\u675f\u65f6\u95f4</p>\r\n      <div class=\"time_btm\">\r\n        <label class=\"time_area\">{{dynamicChosedTimeInfo.startTime}}<span>\u81f3</span>{{dynamicChosedTimeInfo.endTime}}</label>\r\n        <label class=\"time_tol\">\u5171<span>{{dynamicChosedTimeInfo.duration}}</span>\u5c0f\u65f6</label>\r\n        <span class=\"seat_num\" v-if=\"chosedSeatNum\">\u5ea7\u4f4d\u7f16\u53f7 {{chosedSeatNum}}</span>\r\n      </div>\r\n    </div>\r\n    \r\n    <div class=\"safety_pop\" style=\"display:none;\"></div>\r\n    \r\n    <div class=\"screenMask\" style=\"z-index: 2\" v-if=\"captchaShow\"></div>\r\n    \r\n    <div class=\"number_validator_pop\" v-show=\"captchaShow\">\r\n      <div class=\"number_validator_top\">\u8bf7\u5b8c\u6210\u5b89\u5168\u9a8c\u8bc1 <span class=\"nvp_close\" @click=\"captchaShow=false\"></span></div>\r\n      <div class=\"number_validator_cont\">\r\n        \r\n        <div class=\"nvc_area\"><img style=\"width: 100%; height: 100%\" @click=\"loadCaptcha\" v-show=\"captchaLoadSuccess\" :src=\"captchaUrl\"></div>\r\n        <div class=\"nvc_text\">\r\n          <input type=\"text\" class=\"nvc_input\" v-model=\"captcha\" placeholder=\"\u8bf7\u8f93\u5165\u4e0a\u56fe\u4e2d\u7684\u6570\u5b57\"/>\r\n          <p class=\"nvc_tip\" style=\"display: none\">\u9a8c\u8bc1\u7801\u9519\u8bef\uff0c\u8bf7\u91cd\u8bd5</p>\r\n        </div>\r\n      </div>\r\n      <div class=\"number_validator_bottom\">\r\n        <p class=\"nvb_sure\" :class=\"{noClick: $.trim(captcha).length==0}\" @click=\"captchaSubmit\">\u786e\u5b9a</p>\r\n      </div>\r\n    </div>\r\n    \r\n    <div id=\"cxCaptcha\"></div>\r\n  \r\n    \r\n    \r\n    <div class=\"make_pop\" v-show=\"reserveInfo.show && seatConfig.deptId != 24676\">\r\n      <div class=\"make_top\">\r\n        <span class=\"make_close\" @click=\"closeReserveInfo()\"></span>\r\n        <ul class=\"make_ul\">\r\n          <li class=\"make_lis\">\r\n            <span class=\"make_lis_left\">\u9884\u7ea6\u4eba</span>\r\n            <span class=\"make_lis_right blue\">***</span>\r\n          </li>\r\n          <li class=\"make_lis\">\r\n            <span class=\"make_lis_left\">\u9884\u7ea6\u65f6\u95f4</span>\r\n            <span class=\"make_lis_right\">{{reserveInfo.startTime |format('HH:mm')}} - {{reserveInfo.endTime |format('HH:mm')}}</span>\r\n          </li>\r\n          <li class=\"make_lis\">\r\n            <span class=\"make_lis_left\">\u5f53\u524d\u72b6\u6001</span>\r\n            <span class=\"make_lis_right\" style=\"color: #FFAE4E\">\u4f7f\u7528\u4e2d</span>\r\n          </li>\r\n        </ul>\r\n      </div>\r\n      <div class=\"make_btn\">\r\n        <span class=\"orange\" @click=\"toSupervise()\">\u76d1\u7763</span>\r\n      </div>\r\n    </div>\r\n    \r\n    <div class=\"supervise_pop\" v-show=\"reserveInfo.show && seatConfig.deptId == 24676\">\r\n      <div class=\"supervise_cont\">\r\n        <ul class=\"supervise_data\">\r\n          <li class=\"supervise_item\">\r\n            <span class=\"supervise_item_left\">\u9884\u7ea6\u4eba</span>\r\n            <span class=\"supervise_item_right blue\">***</span>\r\n          </li>\r\n          <li class=\"supervise_item\">\r\n            <span class=\"supervise_item_left\">\u9884\u7ea6\u65f6\u95f4</span>\r\n            <span class=\"supervise_item_right gray\">{{reserveInfo.startTime |format('HH:mm')}} - {{reserveInfo.endTime |format('HH:mm')}}</span>\r\n          </li>\r\n          <li class=\"supervise_item\">\r\n            <span class=\"supervise_item_left\">\u5f53\u524d\u72b6\u6001</span>\r\n            <span class=\"supervise_item_right yellow\">\u4f7f\u7528\u4e2d</span>\r\n          </li>\r\n        </ul>\r\n        <p class=\"supervise_tip\">\u60a8\u6b63\u5728\u76d1\u7763\u8be5\u5ea7\u4f4d\uff0c\u8bf7\u786e\u8ba4\u3002<br />\u8bf7\u52ff\u6076\u610f\u76d1\u7763\uff0c\u5426\u5219\u5c06\u88ab\u8ba1\u5165\u9ed1\u540d\u5355\u4e00\u6b21\u3002</p>\r\n      </div>\r\n      <div class=\"supervise_bottom\">\r\n        <span class=\"btn_sure\" @click=\"toSupervise()\">\u786e\u8ba4\u76d1\u7763</span>\r\n        <span class=\"btn_cal\" @click=\"closeReserveInfo()\">\u53d6\u6d88</span>\r\n      </div>\r\n    </div>\r\n  </template>\r\n  <template v-if=\"submitsuccess\">\r\n    <div class=\"success\">\r\n      <div class=\"suc_top\">\r\n        <h6 class=\"suc_time\">{{seatReserve.startTime |format('HH:mm')}}-{{seatReserve.endTime | format('HH:mm')}}<span>{{seatReserve.duration}}\u5c0f\u65f6</span></h6>\r\n        <dl class=\"suc_info\">\r\n          <dt>\r\n            <p class=\"suc_addr\">\r\n              {{seatReserve.firstLevelName}}<span v-if=\"seatReserve.secondLevelName\">-{{seatReserve.secondLevelName}}</span><span v-if=\"seatReserve.thirdLevelName\">-{{seatReserve.thirdLevelName}}</span>\r\n            </p>\r\n            <p class=\"suc_day\">{{seatReserve.startTime |format('YYYY-MM-DD')}} <span>{{getWeekStr(seatReserve.startTime)}}</span></p>\r\n          </dt>\r\n          <dd>\r\n            <p class=\"suc_code\">\u5ea7\u4f4d\u7f16\u53f7</p>\r\n            <p class=\"suc_num\">{{seatReserve.seatNum}}</p>\r\n          </dd>\r\n        </dl>\r\n      </div>\r\n      <div class=\"suc_cont\">\r\n        <div class=\"suc_icon\"></div>\r\n        <p class=\"suc_type_word\">\u9884\u7ea6\u6210\u529f</p>\r\n        <p class=\"suc_type_info\" v-if=\"seatConfig.reserveMode === 0\">\r\n          <template v-if=\"reserveCurrent == 0\">\r\n            \u8bf7\u5728<span>{{lessSignTime |format('HH:mm')}}</span>\u81f3<span>{{lastSignTime |format('HH:mm')}}</span>\u65f6\u95f4\u5185\u5b8c\u6210\u7b7e\u5230\uff0c\u5426\u5219\u5c06\u88ab\u8bb0\u5f55\u8fdd\u7ea6\r\n          </template>\r\n          <template v-else>\r\n            \u8bf7\u5728<span>{{lastSignTime |format('HH:mm')}}</span>\u524d\u5b8c\u6210\u7b7e\u5230\uff0c\u5426\u5219\u5c06\u88ab\u8bb0\u5f55\u8fdd\u7ea6\r\n          </template>\r\n        </p>\r\n        <p class=\"suc_type_info\" v-else>\u8bf7\u5728\u95ed\u9986\u524d\u5b8c\u6210\u7b7e\u5230,\u7b7e\u5230\u540e\u5982\u9700\u79bb\u5f00\u53ef\u968f\u65f6\u626b\u7801\u9000\u5ea7</p>\r\n      </div>\r\n      <div class=\"suc_btm\">\r\n        <p class=\"suc_btn\" @click=\"know\">\u6211\u77e5\u9053\u4e86</p>\r\n      </div>\r\n    </div>\r\n  </template>\r\n  <div class=\"screenMask\" style=\"z-index: 2\" @click=\"gridSampleShow=false\" v-if=\"gridSampleShow\"></div>\r\n  <div class=\"img_desc_info\" style=\"z-index: 3\" v-if=\"gridSampleShow\">\r\n    <h2 class=\"img_desc_title\">\u56fe\u4f8b\u8bf4\u660e</h2>\r\n    <ul class=\"img_info_list\">\r\n      <li class=\"img_item_info\" v-for=\"pic in picSample\">\r\n        <div class=\"item_pic\" :class=\"pic.class\" ><span v-if=\"pic.class.includes('seat')\">001</span></div>\r\n        <span class=\"pic_desc\">{{pic.name}}</span>\r\n      </li>\r\n    </ul>\r\n  </div>\r\n  <ul id=\"viewerImg\" style=\"width:0;height:0;\">\r\n    <li><img id=\"img\" :src=\"viewerObj.planUrl\" width=\"0\" height=\"0\"/></li>\r\n  </ul>\r\n  \r\n  <div class=\"res_loading\" v-if=\"loadingShow\">\r\n    <div class=\"res_load_cont\">\r\n      <div class=\"loading_iocn\"></div>\r\n      <p class=\"loading_info\">\u52aa\u529b\u9884\u7ea6\u4e2d\uff0c\u8bf7\u7a0d\u7a0d\u7b49\u5f85\u7247\u523b</p>\r\n    </div>\r\n  </div>\r\n  <input type=\"hidden\" id=\"submit_enc\" value=\"baea60c55f554ce7ab3c43f952228d7e_238771432\"/>\r\n</div>\r\n<script src=\"https://office-static.chaoxing.com/r/staticreserve/js/lib/alloyfinger/alloy_finger.js\"></script>\r\n<script src=\"https://office-static.chaoxing.com/r/staticreserve/js/lib/alloyfinger/transform.js\"></script>\r\n<script>\r\n  var id = '13481', //\u6559\u5ba4ID\r\n      day = '2026-03-06', //\u76ee\u6807\u65e5\u671f\r\n      deptIdEnc = '4a18e12602b24c8c',\r\n      seatNum = '', // \u5ea7\u4f4d\u53f7\r\n      serverNow = new Date('2026-03-06T12:25:49.671+08:00'),// \u670d\u52a1\u5668\u5f53\u524d\u65e5\u671f\r\n      fidEnc = '4a18e12602b24c8c',\r\n      uniqueDomainPath = ''\r\n</script>\r\n<script src=\"https://office-static.chaoxing.com/r/staticreserve/js/src/front/apps/seat/submit/third/seat_select_third.js?t=2026021017\"></script>\r\n<script type=\"text/javascript\">\r\n  require(['lever', 'ratio'], function (AlloyLever) {\r\n    'use strict'\r\n    AlloyLever.config({cdn: 'https://office-static.chaoxing.com/r/staticreserve/js/lib/lever/vconsole.min.js'})\r\n  })\r\n</script>\r\n</body>\r\n</html>\r\n"}, "bodySize":5471, "headersSize":271, "cookies":[], "statusText":"200", "headers":[{"value":"Fri, 06 Mar 2026 04:25:49 GMT", "name":"Date"}, {"value":"text/html;charset=UTF-8", "name":"Content-Type"}, {"value":"Accept-Encoding", "name":"Vary"}, {"value":"zh-CN", "name":"Content-Language"}, {"value":"?0", "name":"Origin-Agent-Cluster"}, {"value":"max-age=0; includeSubDomains", "name":"Strict-Transport-Security"}, {"value":"gzip", "name":"Content-Encoding"}, {"value":"5471", "name":"Content-Length"}], "status":200, "httpVersion":"HTTP/1.1"}, "time":157, "cache":{},