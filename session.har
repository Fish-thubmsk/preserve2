, "name":"accept-encoding"}, {"value":"zh-CN,zh;q=0.9", "name":"accept-language"}, {"value":"u=1, i", "name":"priority"}, {"value":"BAIDUID_BFESS=2346F26C176C88CC3819BDD57D359CE7:FG=1; ab_jid=56174db7bd79324c61a1c24b840c99679deb; ab_bid=56174db7bd79324c61a1c24b840c99679deb; ab_sr=1.0.1_YzRmMTgzN2NmYzU0MDI4ZWY0ZjI1OTFkZGRjOGZkODY2NjhhMDdlZTllOWEyNzhlZDcwZmViNTFmODhlNDhkMzBiZjYyZGFlMjY4ZjNkZjAzOWVmZmRiNGQ5OTUxMzdkZTc0NGMyZTA4ZDAwMjRjMTdiN2IwYjdmNDg0MWM5MTc0NTczOTMwZTM5ZDMwNjJkMmU2MDc0YjhmMDQ1YWFhYw==; ab_jid_BFESS=56174db7bd79324c61a1c24b840c99679deb", "name":"cookie"}, {"value":"miao.baidu.com", "name":"host"}], "postData":{"text":"{\"data\":\"\",\"key_id\":\"35191cdfa1bf4721\",\"enc\":2}", "mimeType":"text/plain"}, "bodySize":2287, "headersSize":1143, "cookies":[{"value":"2346F26C176C88CC3819BDD57D359CE7:FG=1", "name":"BAIDUID_BFESS"}, {"value":"56174db7bd79324c61a1c24b840c99679deb", "name":"ab_jid"}, {"value":"56174db7bd79324c61a1c24b840c99679deb", "name":"ab_bid"}, {"value":"1.0.1_YzRmMTgzN2NmYzU0MDI4ZWY0ZjI1OTFkZGRjOGZkODY2NjhhMDdlZTllOWEyNzhlZDcwZmViNTFmODhlNDhkMzBiZjYyZGFlMjY4ZjNkZjAzOWVmZmRiNGQ5OTUxMzdkZTc0NGMyZTA4ZDAwMjRjMTdiN2IwYjdmNDg0MWM5MTc0NTczOTMwZTM5ZDMwNjJkMmU2MDc0YjhmMDQ1YWFhYw==", "name":"ab_sr"}, {"value":"56174db7bd79324c61a1c24b840c99679deb", "name":"ab_jid_BFESS"}], "method":"POST", "url":"https://miao.baidu.com/abdr?_o=https%3A%2F%2Foffice.chaoxing.com", "httpVersion":"HTTP/2"}, "startedDateTime":"2026-03-06T12:25:29.9350155+08:00", "connection":"ClientPort:11395;EgressPort:19350", "serverIPAddress":"223.109.81.208"}, {"_publicFiddlerId":234, "response":{"redirectURL":"", "content":{"mimeType":"text/html;charset=UTF-8", "compression":25374, "size":32017, "text":"<!DOCTYPE html>\r\n<html>\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=0\">\r\n  <meta name=\"format-detection\" content=\"telephone=no\">\r\n  <title>\u5ea7\u4f4d\u9884\u7ea6</title>\r\n<base href=\"https://office.chaoxing.com/\">\r\n<script type=\"text/javascript\">\r\n  var photoUrl = 'http://photo.chaoxing.com'\r\n  var panUrl = 'http://pan-yz.chaoxing.com'\r\n  var noteUrl = 'http://noteyd.chaoxing.com'\r\n  var staticDomain = 'https://office-static.chaoxing.com/r/'\r\n  photoUrl = document.location.protocol + photoUrl.split(\":\")[1]\r\n  panUrl = document.location.protocol + panUrl.split(\":\")[1]\r\n  noteUrl = document.location.protocol + noteUrl.split(\":\")[1]\r\n  if (staticDomain !== '') {\r\n    staticDomain = document.location.protocol + staticDomain.split(\":\")[1]\r\n  }\r\n</script>\r\n\r\n<link rel=\"stylesheet\" href=\"https://office-static.chaoxing.com/r/staticreserve/style/reset.css\">\r\n<link rel=\"stylesheet\" href=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/seat.css\">\r\n<link rel=\"stylesheet\" href=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/reserve/iphonex.css\">\r\n<link rel=\"stylesheet\" href=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/reserve/reserve_mobile.css\">\r\n<script src=\"https://office-static.chaoxing.com/r/staticreserve/js/lib/jquery/jquery.min.js\"></script>\r\n<script src=\"https://office-static.chaoxing.com/r/staticreserve/js/lib/wy/YiDunProtector-Web-2.1.4.js\"></script>\r\n<script>document.write(\"<script src='https://captcha.chaoxing.com/load-d.min.js?t=\" + parseInt(Date.now()/60000) + \"'><\\/script>\");</script>\r\n<script>document.write(\"<script src='https://captcha.chaoxing.com/light.js?t=\" + parseInt(Date.now()/60000) + \"'><\\/script>\");</script>\r\n<script type=\"text/javascript\" src=\"//api.map.baidu.com/api?type=webgl&v=1.0&ak=p7HrxjMD6R1hbPFP9sNgkfHjsNZumBai\"></script>\r\n<script>document.write(\"<script src='https://cstaticdun.126.net/load.min.js?t=\" + parseInt(Date.now()/60000) + \"'><\\/script>\");</script>\r\n<script type=\"text/javascript\" src=\"https://office-static.chaoxing.com/r/staticreserve/js/lib/requirejs/require.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"https://office-static.chaoxing.com/r/staticreserve/js/src/front/apps/seat/main.js?t=2026021017\"></script>\r\n<script>requirejs.config({urlArgs: 't=2026021017'})</script>\r\n</head>\r\n<body>\r\n<div class=\"screen\" v-cloak>\r\n  <div class=\"scr_top\">\r\n    <div class=\"scr_time\" id=\"scr_time\">\r\n      <ul class='mTabul'>\r\n        <li :class=\"{active: data.checked}\" v-for=\"(data,index) in screenTimes\" @click=\"choseTime(data.day,index)\">\r\n          <div class=\"mtab_info\">\r\n            <h6 class=\"mtab_time\">{{data.time}}</h6>\r\n            <p class=\"mtab_eng\">{{data.week}}</p>\r\n          </div>\r\n        </li>\r\n      </ul>\r\n    </div>\r\n    <div class=\"scr_icon\" @click=\"$choseLevel(0, null, 0, false)\"><span></span></div>\r\n  </div>\r\n  <ul class=\"scr_cont\" v-if=\"!isNotExistData\">\r\n    <li class=\"scr_list\" v-for=\"data in seatRoomList\" v-if=\"data.authShow\">\r\n      <h6 class=\"scr_title owt1\">\r\n        {{data.firstLevelName}}<span v-if=\"data.secondLevelName\">-{{data.secondLevelName}}</span><span v-if=\"data.thirdLevelName\">-{{data.thirdLevelName}}</span></h6>\r\n      <p class=\"scr_open\">\u5f00\u653e\u65f6\u95f4\r\n        <span v-if=\"data.startTime && data.endTime\">{{data.startTime | format('HH:mm')}}-{{data.endTime | format('HH:mm')}}</span>\r\n        <span v-else>\u6682\u672a\u5f00\u653e</span>\r\n      </p>\r\n      <p class=\"scr_use\">\r\n        \u5ea7\u4f4d\u6570<span>{{data.capacity}}</span>\r\n        <template v-if=\"curusedShow\">\r\n          <label style=\"margin-left: 10px\">\u5f53\u524d\u5269\u4f59\u6570<span>{{data.capacity > data.curUsedCount ? (data.capacity - data.curUsedCount) : 0}}</span></label>\r\n        </template>\r\n      </p>\r\n      <span class=\"scr_sch\" @click=\"toChoseSeat(data)\"></span>\r\n    </li>\r\n    \r\n    <div></div>\r\n  </ul>\r\n  <div class=\"noData\" v-if=\"isNotExistData\">\r\n    <div class=\"nera_nodata_img\"></div>\r\n    <p class=\"near_nodata_word\">\u6682\u65e0\u6570\u636e</p>\r\n  </div>\r\n  \r\n  <div class=\"screenMask\" v-if=\"levelShow || initListPopShow\" @click=\"cancel\"></div>\r\n  \r\n  <div class=\"look_img\" v-if=\"seatPlanShow(seatConfig)\" @click=\"openSeatPlan(seatConfig)\">\u533a\u57df<br/>\u5206\u5e03</div>\r\n  \r\n  <div class=\"gscreen\" v-if=\"levelShow\">\r\n    <h6 class=\"gsc_tel\">\u7b5b\u9009\u6761\u4ef6</h6>\r\n    <div class=\"gsc_area\">\r\n      <div class=\"gsc_cont\">\r\n        <div class=\"gsc_data\" v-if=\"firstLevels.length > 0\">\r\n          <h6 class=\"gsc_title\">{{seatConfig.roomFirstLevelDict}}</h6>\r\n          <ul class=\"gsc_list\">\r\n            <li class=\"gsc_type\" :class=\"{select: data.checked}\" v-for=\"(data,index) in firstLevels\" @click=\"$choseLevel(index,data.firstLevelName,1)\">{{data.firstLevelName}}</li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"gsc_data\" v-if=\"secondLevels.length > 0\">\r\n          <h6 class=\"gsc_title\">{{seatConfig.roomSecondLevelDict}}</h6>\r\n          <ul class=\"gsc_list\">\r\n            <li class=\"gsc_type\" :class=\"{select: data.checked}\" v-for=\"(data,index) in secondLevels\" @click=\"$choseLevel(index,data.secondLevelName,2)\">{{data.secondLevelName}}\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"gsc_data\" v-if=\"thirdLevels.length > 0\">\r\n          <h6 class=\"gsc_title\">{{seatConfig.roomThirdLevelDict}}</h6>\r\n          <ul class=\"gsc_list\">\r\n            <li class=\"gsc_type\" :class=\"{select: data.checked}\" v-for=\"(data,index) in thirdLevels\" @click=\"$choseLevel(index,data.thirdLevelName,3)\">{{data.thirdLevelName}}</li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"gsc_btns\">\r\n      <span class=\"gsc_cal\" @click=\"reChose\">\u91cd\u7f6e</span>\r\n      <span class=\"gsc_sure\" @click=\"confirm\">\u7b5b\u9009</span>\r\n    </div>\r\n  </div>\r\n  <div class=\"reserve-common__pop\" v-if=\"initListPopShow\">\r\n    <div class=\"reserve-common__header\">\u9009\u62e9\u5bf9\u8c61<i class=\"icon-close\" @click=\"initListPopShow=false\"></i></div>\r\n    <div class=\"reserve-common__content\" empty-text=\"\u6682\u65e0\u7b5b\u9009\u6807\u7b7e\">\r\n      <div class=\"option__wrapper\" v-if=\"firstLevels.length > 0\">\r\n        <h2 class=\"option__title\">{{seatConfig.roomFirstLevelDict}}</h2>\r\n        <div class=\"option__cont\">\r\n          <ul class=\"select-label__list\">\r\n            <li class=\"select-label__item\" :class=\"{'select-label__item--active': data.checked}\" v-for=\"(data,index) in firstLevels\" @click=\"$choseLevel(index,data.firstLevelName,1)\">{{data.firstLevelName}}</li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n      <div class=\"option__wrapper\" v-if=\"secondLevels.length > 0\">\r\n        <h2 class=\"option__title\">{{seatConfig.roomSecondLevelDict}}</h2>\r\n        <div class=\"option__cont\">\r\n          <ul class=\"select-label__list\">\r\n            <li class=\"select-label__item\" :class=\"{'select-label__item--active': data.checked}\" v-for=\"(data,index) in secondLevels\" @click=\"$choseLevel(index,data.secondLevelName,2)\">{{data.secondLevelName}}</li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n      <div class=\"option__wrapper\" v-if=\"thirdLevels.length > 0\">\r\n        <h2 class=\"option__title\">{{seatConfig.roomThirdLevelDict}}</h2>\r\n        <div class=\"option__cont\">\r\n          <ul class=\"select-label__list\">\r\n            <li class=\"select-label__item\" :class=\"{'select-label__item--active': data.checked}\" v-for=\"(data,index) in thirdLevels\" @click=\"$choseLevel(index,data.thirdLevelName,3)\">{{data.thirdLevelName}}</li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"reserve-common__footer\">\r\n      <button class=\"reserve-common__button\" @click=\"confirm\">\u7b5b\u9009</button>\r\n    </div>\r\n  </div>\r\n  <ul id=\"viewerImg\" style=\"width:0;height:0;\">\r\n    <li><img id=\"img\" :src=\"viewerObj.planUrl\" width=\"0\" height=\"0\"/></li>\r\n  </ul>\r\n</div>\r\n<script>\r\n  require(['jquery', 'Vue', 'appUtils', 'moment', 'popup', 'viewer', 'seatBaseUtils', 'baseUtils', 'iscroll', 'dropload'], function ($, Vue, AppUtils, moment, popup, Viewer,\r\n      seatBaseUtils, baseUtils) {\r\n    'use strict'\r\n    var deptIdEnc = '4a18e12602b24c8c',\r\n        serverNow = new Date('2026-03-06T12:25:32.285+08:00')// \u670d\u52a1\u5668\u5f53\u524d\u65e5\u671f\r\n    function loadData(url, data) {\r\n      return $.getJSON(url, data)\r\n    }\r\n    function loadSeatRoomList(vm) {\r\n      var droploadOpt = {\r\n        time: '',\r\n        cpage: 1,\r\n        pageSize: 100,\r\n        firstLevelName: vm.firstLevelName,\r\n        secondLevelName: vm.secondLevelName,\r\n        thirdLevelName: vm.thirdLevelName,\r\n        day: vm.choseDay.getFullYear() + '-' + baseUtils.twoDigits(vm.choseDay.getMonth() + 1) + '-' + baseUtils.twoDigits(vm.choseDay.getDate()),\r\n        deptIdEnc: deptIdEnc\r\n      }\r\n      var _this = vm\r\n      var dropload = $('.scr_cont').dropload({\r\n        scrollArea: $('.scr_cont'),\r\n        threshold: 200,\r\n        domDown: {\r\n          domClass: 'isbottom',\r\n          domNoData: ''\r\n        },\r\n        loadDownFn: function (me) {\r\n          loadData('data/apps/seat/room/list', droploadOpt).then(function (json) {\r\n            var seatRoomList = json.data.seatRoomList\r\n            seatRoomList = reLoadData(seatRoomList, _this.choseDay, _this)\r\n            _this.seatRoomList = _this.seatRoomList.concat(seatRoomList)\r\n            if (_this.seatRoomList.length === 0) {\r\n              _this.isNotExistData = true\r\n            }\r\n            //\u7528\u4e8e\u5224\u65ad\u5f53\u6570\u636e\u53ea\u6709\u4e00\u9875\u60c5\u51b5\u4e0b\u9690\u85cf\u6570\u636e\u7ed3\u5c3e\u63d0\u793a\u5e76\u9501\u5b9a\u6570\u636e\r\n            if (json.data.totalPage === 1) {\r\n              $('.isbottom').hide()\r\n            } else {\r\n              $('.isbottom').show()\r\n            }\r\n            droploadOpt.cpage = droploadOpt.cpage + 1\r\n            if (json.data.seatRoomList.length < droploadOpt.pageSize || droploadOpt.cpage > json.data.totalPage) {\r\n              // \u9501\u5b9a\r\n              me.lock()\r\n              // \u65e0\u6570\u636e\r\n              me.noData()\r\n            }\r\n            vm.$nextTick(function () {\r\n              me.delayResetload()\r\n            })\r\n          })\r\n        }\r\n      })\r\n      return {\r\n        dropload: dropload,\r\n        droploadOpt: droploadOpt\r\n      }\r\n    }\r\n    //\u91cd\u65b0\u6784\u9020\u533a\u57df\u5217\u8868\u6570\u636e\r\n    function reLoadData(seatRoomList, date, _this) {\r\n      var year = '1970/01/01 '\r\n      var ymd = '1970-01-01 '\r\n      var weekDay = date.getDay()\r\n      seatRoomList.forEach(function (value) {\r\n        value.isOpen = 0\r\n        //1. \u8fc7\u6ee4\u7279\u6b8a\u5f00\u653e\u65f6\u95f4\r\n        if (_this.seatConfig.timeType === 0) {\r\n          if (value.seatSpecialTime) {\r\n            switch (weekDay) {\r\n              case 0:\r\n                value.startTime = new Date(year + value.seatSpecialTime.sunStartTime)\r\n                value.endTime = new Date(year + value.seatSpecialTime.sunEndTime)\r\n                value.isOpen = value.seatSpecialTime.sunOpen\r\n                break\r\n              case 1:\r\n                value.startTime = new Date(year + value.seatSpecialTime.monStartTime)\r\n                value.endTime = new Date(year + value.seatSpecialTime.monEndTime)\r\n                value.isOpen = value.seatSpecialTime.monOpen\r\n                break\r\n              case 2:\r\n                value.startTime = new Date(year + value.seatSpecialTime.tuesStartTime)\r\n                value.endTime = new Date(year + value.seatSpecialTime.tuesEndTime)\r\n                value.isOpen = value.seatSpecialTime.tuesOpen\r\n                break\r\n              case 3:\r\n                value.startTime = new Date(year + value.seatSpecialTime.wedStartTime)\r\n                value.endTime = new Date(year + value.seatSpecialTime.wedEndTime)\r\n                value.isOpen = value.seatSpecialTime.wedOpen\r\n                break\r\n              case 4:\r\n                value.startTime = new Date(year + value.seatSpecialTime.thurStartTime)\r\n                value.endTime = new Date(year + value.seatSpecialTime.thurEndTime)\r\n                value.isOpen = value.seatSpecialTime.thurOpen\r\n                break\r\n              case 5:\r\n                value.startTime = new Date(year + value.seatSpecialTime.friStartTime)\r\n                value.endTime = new Date(year + value.seatSpecialTime.friEndTime)\r\n                value.isOpen = value.seatSpecialTime.friOpen\r\n                break\r\n              case 6:\r\n                value.startTime = new Date(year + value.seatSpecialTime.satStartTime)\r\n                value.endTime = new Date(year + value.seatSpecialTime.satEndTime)\r\n                value.isOpen = value.seatSpecialTime.satOpen\r\n                break\r\n              default:\r\n                break\r\n            }\r\n          }\r\n          if (value.seatHoildayTime && value.seatHoildays) {\r\n            if (baseUtils.hoilday(moment(date), value.seatHoildays)) {\r\n              switch (weekDay) {\r\n                case 0:\r\n                  value.startTime = new Date(year + value.seatHoildayTime.sunStartTime)\r\n                  value.endTime = new Date(year + value.seatHoildayTime.sunEndTime)\r\n                  value.isOpen = value.seatHoildayTime.sunOpen\r\n                  break\r\n                case 1:\r\n                  value.startTime = new Date(year + value.seatHoildayTime.monStartTime)\r\n                  value.endTime = new Date(year + value.seatHoildayTime.monEndTime)\r\n                  value.isOpen = value.seatHoildayTime.monOpen\r\n                  break\r\n                case 2:\r\n                  value.startTime = new Date(year + value.seatHoildayTime.tuesStartTime)\r\n                  value.endTime = new Date(year + value.seatHoildayTime.tuesEndTime)\r\n                  value.isOpen = value.seatHoildayTime.tuesOpen\r\n                  break\r\n                case 3:\r\n                  value.startTime = new Date(year + value.seatHoildayTime.wedStartTime)\r\n                  value.endTime = new Date(year + value.seatHoildayTime.wedEndTime)\r\n                  value.isOpen = value.seatHoildayTime.wedOpen\r\n                  break\r\n                case 4:\r\n                  value.startTime = new Date(year + value.seatHoildayTime.thurStartTime)\r\n                  value.endTime = new Date(year + value.seatHoildayTime.thurEndTime)\r\n                  value.isOpen = value.seatHoildayTime.thurOpen\r\n                  break\r\n                case 5:\r\n                  value.startTime = new Date(year + value.seatHoildayTime.friStartTime)\r\n                  value.endTime = new Date(year + value.seatHoildayTime.friEndTime)\r\n                  value.isOpen = value.seatHoildayTime.friOpen\r\n                  break\r\n                case 6:\r\n                  value.startTime = new Date(year + value.seatHoildayTime.satStartTime)\r\n                  value.endTime = new Date(year + value.seatHoildayTime.satEndTime)\r\n                  value.isOpen = value.seatHoildayTime.satOpen\r\n                  break\r\n                default:\r\n                  break\r\n              }\r\n            }\r\n          }\r\n        }\r\n        if (_this.seatConfig.timeType === 1) {\r\n          weekDay = weekDay === 0 ? 7 : weekDay\r\n          var seatIntervalList\r\n          if (value.hoildayIntervalMap && baseUtils.hoilday(moment(date), value.seatHoildays)) {\r\n            seatIntervalList = value.hoildayIntervalMap[weekDay] || []\r\n          } else {\r\n            seatIntervalList = value.intervalMap[weekDay] || []\r\n          }\r\n          if (seatIntervalList.length > 0) {\r\n            value.startTime = new Date(year + seatIntervalList[0].startTime)\r\n            value.endTime = new Date(year + seatIntervalList[seatIntervalList.length - 1].endTime)\r\n          } else {\r\n            value.isOpen = 1\r\n            value.startTime = ''\r\n            value.endTime = ''\r\n          }\r\n        }\r\n        //2. \u8fc7\u6ee4\u6682\u505c\u5f00\u653e\u65e5\u671f\r\n        if (value.seatPauseDate && value.seatPauseDate.dateJson) {\r\n          var dateJson = JSON.parse(value.seatPauseDate.dateJson)\r\n          dateJson.forEach(function (d) {\r\n            if (_this.seatConfig.timeType === 0) {\r\n              var sDate = new Date(d.startDate)\r\n              var eDate = new Date(d.endDate)\r\n              if (date.getTime() >= sDate.getTime() && date.getTime() <= eDate.getTime()) {\r\n                value.isOpen = 1\r\n              }\r\n            } else {\r\n              weekDay = weekDay === 0 ? 7 : weekDay\r\n              var seatIntervalList = value.intervalMap[weekDay] || []\r\n              var startTimeStop = moment(d.startDate)\r\n              var endTimeStop = moment(d.endDate)\r\n              var stopNum = 0;\r\n              for (var i = 0; i < seatIntervalList.length; i++) {\r\n                var temp = seatIntervalList[i]\r\n                if (!(endTimeStop.isBefore(moment(ymd + temp.startTime)) || startTimeStop.isAfter(moment(ymd + temp.endTime)))) {\r\n                  stopNum++\r\n                }\r\n              }\r\n              if (stopNum === seatIntervalList.length) {\r\n                value.isOpen = 1\r\n              }\r\n            }\r\n          })\r\n        }\r\n      })\r\n      seatBaseUtils.filterRolePermission(_this, seatRoomList)\r\n      return seatRoomList\r\n    }\r\n    function getTimeByWeek(reserveBeforeDay) {\r\n      var dateArr = []\r\n      var now = moment(serverNow)\r\n      var weekArr = ['Sun', 'Mon', 'Tue', 'Wed', 'Thur', 'Fri', 'Sat']\r\n      for (var y = 0; y < reserveBeforeDay; y++) {\r\n        var date = now.clone().add(y, 'days')\r\n        dateArr.push({\r\n          day: moment(date).format('YYYY-MM-DD'),\r\n          time: moment(date).format('MM-DD'),\r\n          week: weekArr[date.day()],\r\n          checked: y == 0 ? true : false\r\n        })\r\n      }\r\n      return dateArr\r\n    }\r\n    new Vue({\r\n      el: '.screen',\r\n      data: function () {\r\n        return {\r\n          seatConfig: {},//\u57fa\u7840\u914d\u7f6e\r\n          seatRoomList: [],\r\n          firstLevels: [],\r\n          secondLevels: [],\r\n          thirdLevels: [],\r\n          firstLevelName: '',\r\n          secondLevelName: '',\r\n          thirdLevelName: '',\r\n          screenCondition: {firstLevelName: '', secondLevelName: '', thirdLevelName: ''},\r\n          levelShow: false,\r\n          showAddItem: false,\r\n          isNotExistData: false,\r\n          screenTimes: [],\r\n          viewerObj: {\r\n            viewer: null,\r\n            planUrl: ''\r\n          },\r\n          choseDay: new Date(moment(serverNow).format('YYYY-MM-DD')),\r\n          roleListSelf: [], //\u7528\u6237\u6240\u5c5e\u89d2\u8272\r\n          officeDomain: '',\r\n          curusedShow: false, //\u662f\u5426\u663e\u793a\u5269\u4f59\u5ea7\u4f4d\u6570\r\n          initListPopShow: false\r\n        }\r\n      },\r\n      methods: {\r\n        choseTime: function (day, index) {\r\n          var _this = this\r\n          for (var i = 0; i < this.screenTimes.length; i++) {\r\n            if (index == i) {\r\n              this.screenTimes[index].checked = true\r\n            } else {\r\n              this.screenTimes[i].checked = false\r\n            }\r\n          }\r\n          _this.choseDay = new Date(day)\r\n          _this.droploader.droploadOpt.cpage = 1\r\n          _this.droploader.droploadOpt.day = _this.choseDay.getFullYear() + '-' + baseUtils.twoDigits(_this.choseDay.getMonth() + 1) + '-' + baseUtils.twoDigits(_this.choseDay.getDate())\r\n          _this.seatRoomList = []\r\n          _this.$nextTick(function () {\r\n            _this.droploader.dropload.unlock()\r\n            _this.droploader.dropload.noData(false)\r\n            _this.droploader.dropload.resetload()\r\n          })\r\n        },\r\n        toChoseSeat: function (data) {\r\n          if (data.isOpen === 1) {\r\n            popup.alert('\u8be5\u533a\u57df\u4eca\u65e5\u6682\u505c\u9884\u7ea6')\r\n            return\r\n          }\r\n          var day = ''\r\n          for (var i = 0; i < this.screenTimes.length; i++) {\r\n            if (this.screenTimes[i].checked) {\r\n              day = this.screenTimes[i].day\r\n              break\r\n            } else {\r\n              this.screenTimes[i].checked = false\r\n            }\r\n          }\r\n          if (moment().valueOf() < data.beforeOpenTimeStamp) {\r\n            popup.alert('\u6682\u672a\u5f00\u653e')\r\n            return\r\n          }\r\n          if (day != '') {\r\n            /**\r\n             * \u6b64\u5904\u955c\u50cf\u4f7f\u7528\u6ce8\u91ca\u7684\u8df3\u8f6c \u4e0d\u7528officeDomain \u5426\u5219\u53ef\u80fd\u62a5\u9519\r\n             */\r\n            location.href = this.officeDomain + '/front/third/apps/seat/select?deptIdEnc=' + deptIdEnc\r\n                + '&id=' + data.id\r\n                + '&day=' + day\r\n                + '&backLevel=2'\r\n                + '&fidEnc=' + deptIdEnc\r\n            // location.href = location.origin + '' + '/front/third/apps/seat/select?deptIdEnc=' + deptIdEnc\r\n            //     + '&id=' + data.id\r\n            //     + '&day=' + day\r\n            //     + '&backLevel=2'\r\n            //     + '&fidEnc=' + deptIdEnc\r\n          } else {\r\n            popup.alert('\u8bf7\u9009\u62e9\u65e5\u671f')\r\n          }\r\n        },\r\n        $choseLevel: function (index, name, type, initFilter) {\r\n          var _this = this\r\n          if (type == 0) {\r\n            //\u5224\u65ad\u4e8c\u4e09\u7ea7\u5206\u7c7b\u540d\u96c6\u5408\u662f\u5426\u9700\u8981\u6e05\u7a7a\r\n            if (_this.screenCondition.firstLevelName == '') {\r\n              _this.secondLevels = []\r\n              _this.thirdLevels = []\r\n            } else {\r\n              if (_this.secondLevels.length < 1) {\r\n                loadData('data/apps/seat/levels', {deptIdEnc: deptIdEnc, type: 1, firstLevelName: _this.firstLevelName}).then(function (json) {\r\n                  if (json.success && json.data.levels.length > 0) {\r\n                    _this.secondLevels = json.data.levels\r\n                    for (var i = 0; i < _this.secondLevels.length; i++) {\r\n                      _this.secondLevels[i]['checked'] = false\r\n                    }\r\n                  }\r\n                })\r\n              }\r\n            }\r\n            if (_this.screenCondition.secondLevelName == '') {\r\n              _this.thirdLevels = []\r\n            } else {\r\n              if (_this.thirdLevels.length < 1) {\r\n                loadData('data/apps/seat/levels', {deptIdEnc: deptIdEnc, type: 2, firstLevelName: _this.firstLevelName, secondLevelName: _this.secondLevelName})\r\n                    .then(function (json) {\r\n                      if (json.success && json.data.levels.length > 0) {\r\n                        _this.thirdLevels = json.data.levels\r\n                        for (var i = 0; i < _this.thirdLevels.length; i++) {\r\n                          _this.thirdLevels[i]['checked'] = false\r\n                        }\r\n                      }\r\n                    })\r\n              }\r\n            }\r\n            if (!initFilter) {\r\n              _this.levelShow = true\r\n            }\r\n            if (_this.firstLevels.length < 1) {//\u4e00\u7ea7\u5206\u7c7b\u4e0b\u6709\u6570\u636e\u5219\u4e0d\u9700\u8981\u91cd\u65b0\u8bf7\u6c42\r\n              loadData('data/apps/seat/levels', {deptIdEnc: deptIdEnc, type: type}).then(function (json) {\r\n                if (json.success && json.data.levels.length > 0) {\r\n                  _this.firstLevels = json.data.levels\r\n                  for (var i = 0; i < _this.firstLevels.length; i++) {\r\n                    _this.firstLevels[i]['checked'] = false\r\n                  }\r\n                }\r\n              })\r\n            }\r\n          }\r\n          if (type == 1) {//\u6839\u636e\u4e00\u7ea7\u540d\u8054\u52a8\u4e8c\u7ea7\r\n            var levels = _this.firstLevels\r\n            for (var i = 0; i < levels.length; i++) {\r\n              if (i == index) {\r\n                levels[index].checked = !levels[index].checked\r\n              } else {\r\n                levels[i].checked = false\r\n              }\r\n            }\r\n            if (levels[index].checked) {\r\n              _this.firstLevelName = name\r\n              _this.thirdLevels = []\r\n              loadData('data/apps/seat/levels', {deptIdEnc: deptIdEnc, type: type, firstLevelName: _this.firstLevelName}).then(function (json) {\r\n                if (json.success && json.data.levels.length > 0) {\r\n                  _this.secondLevels = json.data.levels\r\n                  for (var i = 0; i < _this.secondLevels.length; i++) {\r\n                    _this.secondLevels[i]['checked'] = false\r\n                  }\r\n                }\r\n              })\r\n            } else {\r\n              _this.secondLevels = []\r\n              _this.thirdLevels = []\r\n            }\r\n            _this.$forceUpdate()\r\n          }\r\n          if (type == 2) {//\u6839\u636e\u4e8c\u7ea7\u540d\u8054\u52a8\u4e09\u7ea7\r\n            var levels = _this.secondLevels\r\n            for (var i = 0; i < levels.length; i++) {\r\n              if (i == index) {\r\n                levels[index].checked = !levels[index].checked\r\n              } else {\r\n                levels[i].checked = false\r\n              }\r\n            }\r\n            if (levels[index].checked) {\r\n              _this.secondLevelName = name\r\n              loadData('data/apps/seat/levels', {deptIdEnc: deptIdEnc, type: type, firstLevelName: _this.firstLevelName, secondLevelName: _this.secondLevelName})\r\n                  .then(function (json) {\r\n                    if (json.success && json.data.levels.length > 0) {\r\n                      _this.thirdLevels = json.data.levels\r\n                      for (var i = 0; i < _this.thirdLevels.length; i++) {\r\n                        _this.thirdLevels[i]['checked'] = false\r\n                      }\r\n                    }\r\n                  })\r\n            } else {\r\n              _this.thirdLevels = []\r\n            }\r\n            _this.$forceUpdate()\r\n          }\r\n          if (type == 3) {\r\n            var levels = _this.thirdLevels\r\n            for (var i = 0; i < levels.length; i++) {\r\n              if (i == index) {\r\n                levels[index].checked = !levels[index].checked\r\n              } else {\r\n                levels[i].checked = false\r\n              }\r\n            }\r\n            if (levels[index].checked) {\r\n              _this.thirdLevelName = name\r\n            }\r\n            _this.$forceUpdate()\r\n          }\r\n        },\r\n        confirm: function () {\r\n          this.levelShow = false\r\n          this.initListPopShow = false\r\n          this.droploader.droploadOpt.cpage = 1\r\n          this.screenCondition.firstLevelName = ''\r\n          for (var i = 0; i < this.firstLevels.length; i++) {\r\n            if (this.firstLevels[i].checked) {\r\n              this.screenCondition.firstLevelName = this.firstLevels[i].firstLevelName\r\n            }\r\n          }\r\n          this.screenCondition.secondLevelName = ''\r\n          for (var i = 0; i < this.secondLevels.length; i++) {\r\n            if (this.secondLevels[i].checked) {\r\n              this.screenCondition.secondLevelName = this.secondLevels[i].secondLevelName\r\n            }\r\n          }\r\n          this.screenCondition.thirdLevelName = ''\r\n          for (var i = 0; i < this.thirdLevels.length; i++) {\r\n            if (this.thirdLevels[i].checked) {\r\n              this.screenCondition.thirdLevelName = this.thirdLevels[i].thirdLevelName\r\n              break\r\n            }\r\n          }\r\n          this.loadSeatRoomListData(this.screenCondition)\r\n        },\r\n        cancel: function () {\r\n          if (this.levelShow) {\r\n            for (var i = 0; i < this.firstLevels.length; i++) {\r\n              this.firstLevels[i].checked = false\r\n              if (this.firstLevels[i].firstLevelName == this.screenCondition.firstLevelName) {\r\n                this.firstLevels[i].checked = true\r\n              }\r\n            }\r\n            for (var i = 0; i < this.secondLevels.length; i++) {\r\n              this.secondLevels[i].checked = false\r\n              if (this.secondLevels[i].secondLevelName == this.screenCondition.secondLevelName) {\r\n                this.secondLevels[i].checked = true\r\n              }\r\n            }\r\n            for (var i = 0; i < this.thirdLevels.length; i++) {\r\n              this.thirdLevels[i].checked = false\r\n              if (this.thirdLevels[i].thirdLevelName == this.screenCondition.thirdLevelName) {\r\n                this.thirdLevels[i].checked = true\r\n              }\r\n            }\r\n            this.confirm()\r\n            this.levelShow = false\r\n          }\r\n        },\r\n        reChose: function () {\r\n          for (var i = 0; i < this.firstLevels.length; i++) {\r\n            if (this.firstLevels[i].checked) {\r\n              this.firstLevels[i].checked = false\r\n            }\r\n          }\r\n          for (var i = 0; i < this.secondLevels.length; i++) {\r\n            if (this.secondLevels[i].checked) {\r\n              this.secondLevels[i].checked = false\r\n            }\r\n          }\r\n          for (var i = 0; i < this.thirdLevels.length; i++) {\r\n            if (this.thirdLevels[i].checked) {\r\n              this.thirdLevels[i].checked = false\r\n            }\r\n          }\r\n          this.$forceUpdate()\r\n        },\r\n        loadSeatRoomListData: function (screenCondition) {\r\n          var _this = this\r\n          _this.searched = true\r\n          _this.droploader.droploadOpt.firstLevelName = screenCondition.firstLevelName\r\n          _this.droploader.droploadOpt.secondLevelName = screenCondition.secondLevelName\r\n          _this.droploader.droploadOpt.thirdLevelName = screenCondition.thirdLevelName\r\n          _this.seatRoomList = []\r\n          _this.$nextTick(function () {\r\n            _this.droploader.dropload.unlock()\r\n            _this.droploader.dropload.noData(false)\r\n            _this.droploader.dropload.resetload()\r\n          })\r\n        },\r\n        seatPlanShow: function (e) {\r\n          if (e.planUrl) {\r\n            return true\r\n          }\r\n          return false\r\n        },\r\n        openSeatPlan: function (e) {\r\n          this.viewerObj.planUrl = e.planUrl\r\n          this.$nextTick(function () {\r\n            if (this.viewerObj.viewer !== null) {\r\n              this.viewerObj.viewer.update()\r\n            }\r\n            document.getElementById('img').click()\r\n          })\r\n        }\r\n      },\r\n      filters: {\r\n        format: function (value, formater) {\r\n          return moment(value).format(formater)\r\n        }\r\n      },\r\n      mounted: function () {\r\n        if (this.viewerObj.viewer === null) {\r\n          this.viewerObj.viewer = new Viewer(document.getElementById('viewerImg'))\r\n        }\r\n        var _this = this\r\n        loadData('data/apps/seat/config', {fidEnc: '4a18e12602b24c8c'}).then(function (json) {\r\n          if (json.success && json.data.seatConfig != null) {\r\n            _this.seatConfig = json.data.seatConfig\r\n            if (_this.seatConfig.initListPop === 1) {\r\n              _this.initListPopShow = true\r\n              _this.$choseLevel(0, null, 0, true)\r\n            }\r\n            _this.officeDomain = json.data.officeDomain\r\n            //\u5904\u7406\u53ef\u9884\u7ea6\u65e5\u671f\u6ed1\u52a8\u533a\u57df\u6570\u636e\r\n            var reserveBeforeDay = _this.seatConfig.reserveBeforeDay\r\n            var serverTime = serverNow.getHours() + serverNow.getMinutes() / 60\r\n            var configTime = parseInt(_this.seatConfig.reserveBeforeTime.split(':')[0]) + parseInt(_this.seatConfig.reserveBeforeTime.split(':')[1]) / 60\r\n            if (serverTime >= configTime) {\r\n              reserveBeforeDay = reserveBeforeDay + 1\r\n            }\r\n            _this.screenTimes = getTimeByWeek(reserveBeforeDay)//\u6240\u6709\u5468\u671f\u6570\u7ec4\r\n            loadData('data/apps/seat/person/role', {fidEnc: deptIdEnc}).then(function (res) {\r\n              if (json.success) {\r\n                _this.roleListSelf = res.data.roleListSelf\r\n                _this.droploader = loadSeatRoomList(_this)\r\n                $('.mTabul').css('width', _this.screenTimes.length * 1.16 + .88 + 'rem')\r\n                //\u65f6\u95f4\u6ed1\u52a8\r\n                var myscroll = new iScroll('scr_time', {\r\n                  scrollX: true,\r\n                  scrollY: false,\r\n                  hScrollbar: false,\r\n                  vScrollbar: false,\r\n                  vScroll: false\r\n                })\r\n              }\r\n            })\r\n          } else {\r\n            popup.alert('\u83b7\u53d6\u4fe1\u606f\u5931\u8d25')\r\n          }\r\n        })\r\n        loadData('data/apps/seat/curusedshow', {fidEnc: '4a18e12602b24c8c'}).then(function (json) {\r\n          _this.curusedShow = json.data.curusedShow\r\n        })\r\n      }\r\n    })\r\n  })\r\n</script>\r\n<script type=\"text/javascript\">\r\n  require(['lever', 'ratio'], 