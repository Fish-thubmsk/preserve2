e = [29747, 29216].indexOf(_this.seatConfig.deptId) !== -1\r\n              _this.bjjtApp = _this.seatConfig.deptId === 24676 //\u5317\u4eac\u4ea4\u901a\u5927\u5b66\u5b9a\u5236\r\n            }\r\n            _this.openDialog = BaseUtils.dialogShow(\r\n                json.data.openDialog,\r\n                _this.seatConfig.openDialog,\r\n                _this.seatConfig.dialogFrequency,\r\n                BaseUtils.getCache(dialogKey)\r\n            )\r\n            BaseUtils.initEditor(_this.seatConfig.dialogContent)\r\n            if (_this.nearReserves.length === 0) {\r\n              _this.notNearReserves = true\r\n            }\r\n            if (json.data.customLoginUrl) {\r\n              _this.customLoginUrl = json.data.customLoginUrl\r\n              _this.hideLoginOut = !json.data.customLoginUrl.loginOutUrl;\r\n            }\r\n            if (_this.seatConfig.deptId === 32439) {\r\n              _this.hideLoginOut = true\r\n            }\r\n            _this.curReserves = json.data.curReserves\r\n            if (_this.curReserves.length === 0) {\r\n              _this.notCurReserves = true\r\n            }\r\n            _this.curReserves.forEach(function (value) {\r\n              if (value.status === 1 || value.status === 3 || value.status === 5) {\r\n                _this.getCountDown(value.expireTime)\r\n              }\r\n            })\r\n          }\r\n          if (location.href.indexOf('qrresult=') > -1) {\r\n            var url = decodeURIComponent(location.href.split('qrresult=')[1]),\r\n                roomIdByCode = parseInt(BaseUtils.getQueryVariable('id', url.split('?')[1])) | 0,\r\n                fid = parseInt(BaseUtils.getQueryVariable('fid', url.split('?')[1])) | 0,\r\n                reserveId = '0', //\u9884\u7ea6\u8bb0\u5f55id\r\n                num = '',\r\n                room = '0',\r\n                id = '0',\r\n                signBack = '0',\r\n                seatNum = '0'\r\n            if ((_this.seatConfig.isPosition ==