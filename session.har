)\r\n            //\u5982\u679c\u5b58\u5728\u7279\u6b8a\u533a\u57df\u914d\u7f6e\uff0c\u4f18\u5148\u6309\u7167\u7279\u6b8a\u533a\u57df\u89c4\u5219\u5904\u7406\r\n            if (curReserve && curReserve.hasOwnProperty('signBackPhoto')) {\r\n              signBackPhoto = curReserve.signBackPhoto\r\n            }\r\n            if (signBackPhoto === 1) { //\u5f00\u542f\u7b7e\u9000\u62cd\u7167\r\n              wx.chooseImage({\r\n                count: 1, // \u9ed8\u8ba49\r\n                sizeType: ['compressed'], //\u538b\u7f29\u56fe\r\n                sourceType: ['camera'], // \u6307\u5b9a\u6765\u6e90\u662f\u76f8\u673a\r\n                success: function (res1) {\r\n                  wx.getLocalImgData({\r\n                    localId: res1.localIds[0], // \u56fe\u7247\u7684localID\r\n                    success: function (res2) {\r\n                      var formData = new FormData()\r\n                      formData.append('file', BaseUtils.base64ToFile(res2.localData, new Date().getTime()))\r\n                      $.ajax({\r\n                        type: 'POST',\r\n                        url: 'data/filedata/apps/reservepc/web/file/upload',\r\n                        data: formData,\r\n                        contentType: false,\r\n                        processData: false,\r\n                        enctype: 'multipart/form-data',\r\n                        async: false,\r\n                        success: function (res3) {\r\n                          if (res3.success) {\r\n                            doRequestSignBack(_this, reserveId, res3.data.result.objectId)\r\n                          }\r\n                        }\r\n                      })\r\n                    }\r\n                  })\r\n                }\r\n              })\r\n            } else {\r\n              doRequestSignBack(_this, reserveId)\r\n            }\r\n          }\r\n          _this.itemId = ''\r\n          _this.signBackShow = false\r\n        },\r\n        askLeave: function (id) {\r\n          var _this = this\r\n          _this.leaveShow = true\r\n          _this.itemId = id\r\n        },\r\n        leave: function (flag) {\r\n          var _this = this\r\n          if (flag) {\r\n            operateData('data/apps/seat/leave', {id: _this.itemId}).then(function (json) {\r\n              if (json.success) {\r\n                popup.alert('\u6682\u79bb\u6210\u529f', '\u6211\u77e5\u9053\u4e86', function () {\r\n                  location.reload()\r\n                })\r\n              } else {\r\n                popup.alert(json.msg, '\u6211\u77e5\u9053\u4e86', function () {\r\n                  location.reload()\r\n                })\r\n              }\r\n            })\r\n          }\r\n          _this.itemId = ''\r\n          _this.leaveShow = false\r\n        },\r\n        signIn: function (data) {\r\n          var _this = this\r\n          signInScan(_this, data)\r\n        },\r\n        reReserve: function (roomId, seatNum) {\r\n          var _this = this\r\n          //\u5224\u65ad\u8be5\u533a\u57df\u662f\u5426\u53ef\u4ee5\u9884\u7ea6\r\n          operateData('data/apps/seat/room/info', {id: roomId, fidEnc: '4a18e12602b24c8c'}).then(function (json) {\r\n            if (json.success && json.data.seatRoom) {\r\n              var seatConfig = json.data.seatConfig\r\n              var serverTime = serverNow.getHours() + serverNow.getMinutes() / 60\r\n              var configTime = parseInt(seatConfig.reserveBeforeTime.split(':')[0]) + parseInt(seatConfig.reserveBeforeTime.split(':')[1]) / 60\r\n              //\u5047\u5982\u8bbe\u7f6e\u63d0\u524d\u9884\u7ea6\u65e5\u671f\u4e3a\u5f53\u5929\uff0c\u4e14\u5f53\u524d\u65f6\u95f4\u5c0f\u4e8e\u63d0\u524d\u9884\u7ea6\u65f6\u95f4\uff0c\u5219\u65e0\u6cd5\u8fdb\u5165\u5feb\u901f\u9009\u5ea7\u754c\u9762\r\n              if (seatConfig.reserveBeforeDay === 0 && serverTime < configTime) {\r\n                popup.alert(seatConfig.reserveBeforeTime + '\u540e\u53ef\u9884\u7ea6')\r\n                return\r\n              }\r\n              var seatRoom = json.data.seatRoom\r\n              if (seatRoom.status == 1) {\r\n                popup.alert('\u8be5\u533a\u57df\u5df2\u6682\u505c\u9884\u7ea6')\r\n                return\r\n              }\r\n              if (seatRoom.isShow == 1) {\r\n                popup.alert('\u8be5\u533a\u57df\u4ec5\u652f\u6301\u73b0\u573a\u9884\u7ea6')\r\n                return\r\n              }\r\n              if (seatRoom.isOpen == 1) {\r\n                popup.alert('\u8be5\u533a\u57df\u5df2\u6682\u505c\u9884\u7ea6')\r\n                return\r\n              }\r\n              if (seatRoom.startSeatNum > parseInt(seatNum)) {\r\n                popup.alert('\u8be5\u5ea7\u4f4d\u5df2\u88ab\u79fb\u9664')\r\n                return\r\n              }\r\n              var seatAttributes = json.data.seatAttributes\r\n              for (var i = 0; i < seatAttributes.length; i++) {\r\n                var seat = seatAttributes[i]\r\n                if (seat.isReserve == 0 && seatNum == seat.seatNum) {\r\n                  popup.alert('\u8be5\u5ea7\u4f4d\u5df2\u6682\u505c\u9884\u7ea6')\r\n                  return\r\n                }\r\n              }\r\n              /**\r\n               * \u6b64\u5904\u955c\u50cf\u4f7f\u7528\u6ce8\u91ca\u7684\u8df3\u8f6c \u4e0d\u7528officeDomain \u5426\u5219\u53ef\u80fd\u62a5\u9519\r\n               */\r\n              location.href = _this.officeDomain + '/front/third/apps/seat/select?id=' + roomId + '&day=' + moment(new Date())\r\n                  .format('YYYY-MM-DD') + '&seatNum=' + seatNum + '&backLevel=1&fidEnc=' + deptIdEnc\r\n              // location.href = location.origin + '' + '/front/third/apps/seat/select?id=' + roomId + '&day=' + moment(new Date())\r\n              //     .format('YYYY-MM-DD') + '&seatNum=' + seatNum + '&backLevel=1'\r\n            } else {\r\n              popup.alert(json.msg)\r\n            }\r\n          })\r\n        },\r\n        getCountDown: function (timestamp) {\r\n          var self = this\r\n          var learnTimer = setInterval(function () {\r\n            var nowTime = new Date()\r\n            var endTime = new Date(new Date(timestamp))\r\n            var t = endTime.getTime() - nowTime.getTime()\r\n            if (t > 0) {\r\n              var day = Math.floor(t / 86400000)\r\n              var hour = Math.floor((t / 3600000) % 24)\r\n              var min = Math.floor((t / 60000) % 60)\r\n              var sec = Math.floor((t / 1000) % 60)\r\n              hour = hour < 10 ? '0' + hour : hour\r\n              min = min < 10 ? '0' + min : min\r\n              sec = sec < 10 ? '0' + sec : sec\r\n              var format = ''\r\n              if (day > 0) {\r\n                format = day + '\u5929' + hour + ':' + min + ':' + sec\r\n              }\r\n              if (day <= 0 && hour > 0) {\r\n                format = hour + ':' + min + ':' + sec\r\n              }\r\n              if (day <= 0 && hour <= 0) {\r\n                format = min + ':' + sec\r\n              }\r\n              self.countDown = format\r\n            } else {\r\n              clearInterval(learnTimer)\r\n            }\r\n          }, 1000)\r\n        },\r\n        back: function () {\r\n          var _this = this\r\n          if (BaseUtils.thirdScannerVerify(_this.seatConfig.deptId)) {\r\n            location.href = 'http://www.close.com/'\r\n          } else {\r\n            WeixinJSBridge.call('closeWindow')\r\n          }\r\n        },\r\n        start: function () {\r\n          var _this = this\r\n          if (_this.openDialogType === 0 && _this.seatConfig.dialogAgree === 1 && !_this.dialogAgreeStatus) {\r\n            BaseUtils.showMoblieBtmTips('\u8bf7\u786e\u8ba4\u5df2\u9605\u8bfb\u5e76\u540c\u610f\u76f8\u5173\u5185\u5bb9\u540e\u518d\u7ee7\u7eed')\r\n            return\r\n          }\r\n          if (_this.openDialogType === 0) {\r\n            operateData('data/apps/seat/dialog', {dialogAgreeStatus: _this.dialogAgreeStatus}).then(function (json) {\r\n              if (!json.success) {\r\n                popup.alert(json.msg)\r\n                return\r\n              }\r\n              if (_this.seatConfig.openDialog === 1 && _this.seatConfig.dialogFrequency === 1) {\r\n                BaseUtils.addCache(dialogKey, new Date().getTime())\r\n              }\r\n              _this.openDialog = false\r\n            })\r\n          } else {\r\n            _this.openDialog = false\r\n          }\r\n        },\r\n        goBindSno: function () {\r\n          var _this = this\r\n          location.href = _this.bindSnoUrl\r\n        },\r\n        toggleReserveInfo: function (e) {\r\n          var _this = this\r\n          if (e) {\r\n            _this.reserveInfo.data = $.extend(true, {}, e)\r\n            if (e.status === 0) {\r\n              _this.reserveInfo.data['statusStr'] = '\u5f85\u5c65\u7ea6'\r\n            }\r\n            if (e.status === 1) {\r\n              _this.reserveInfo.data['statusStr'] = '\u4f7f\u7528\u4e2d'\r\n            }\r\n            if (e.status === 5) {\r\n              _this.reserveInfo.data['statusStr'] = '\u88ab\u76d1\u7763\u4e2d'\r\n            }\r\n            if (e.status === 3) {\r\n              _this.reserveInfo.data['statusStr'] = '\u6682\u79bb\u4e2d'\r\n            }\r\n          }\r\n          clearInterval(_this.reserveInfo.currentTimeObj)\r\n          _this.reserveInfo.currentTime = moment()\r\n          _this.reserveInfo.currentTimeObj = setInterval(function () {\r\n            _this.reserveInfo.currentTime = moment()\r\n          }, 1000)\r\n          _this.reserveInfo.show = !_this.reserveInfo.show\r\n          if (!_this.reserveInfo.show) {\r\n            clearInterval(_this.reserveInfo.currentTimeObj)\r\n          }\r\n        },\r\n        unlock: function (data) {\r\n          var _this = this\r\n          var now = moment()\r\n          var qrCodeOpen = _this.seatConfig.qrcodeOpen\r\n          var signDuration = _this.seatConfig.signDuration\r\n          var preSignDuration = _this.seatConfig.preSignDuration\r\n          if (signDuration === -1) {\r\n            if (now.isBefore(moment(data.startTime).add(-30, 'minutes'))) {\r\n              popup.alert('\u672a\u5230\u7b7e\u5230\u65f6\u95f4')\r\n              return\r\n            }\r\n            if (qrCodeOpen === 12 && now.isAfter(moment(data.endTime))) {\r\n              popup.alert('\u7b7e\u5230\u65f6\u95f4\u5df2\u8fc7')\r\n              return\r\n            }\r\n          } else {\r\n            if (now.isBefore(moment(data.startTime).add(-preSignDuration, 'minutes'))) {\r\n              popup.alert('\u8fd8\u672a\u5230\u7b7e\u5230\u65f6\u95f4')\r\n              return\r\n            }\r\n            if (qrCodeOpen === 12 &&\r\n                moment(data.inserttime).isAfter(moment(data.startTime)) &&\r\n                moment(data.inserttime).add(signDuration, 'minutes').isBefore(now)) {\r\n              popup.alert('\u7b7e\u5230\u65f6\u95f4\u5df2\u8fc7')\r\n              return\r\n            }\r\n            if (qrCodeOpen === 12 &&\r\n                moment(data.inserttime).isBefore(moment(data.startTime)) &&\r\n                moment(data.startTime).add(signDuration, 'minutes').isBefore(now)) {\r\n              popup.alert('\u7b7e\u5230\u65f6\u95f4\u5df2\u8fc7')\r\n              return\r\n            }\r\n          }\r\n          //\u9879\u76ee\u56e2\u961f\u5bf9\u63a5\u5f00\u9501\r\n          if (qrCodeOpen === 12) {\r\n            operateData('data/apps/seat/unlocking', {\r\n              deptId: _this.seatConfig.deptId,\r\n              reserveUserId: data.id,\r\n              roomId: data.roomId,\r\n              seatNum: data.seatNum\r\n            }).then(function (json) {\r\n              if (!json.success) {\r\n                popup.alert(json.msg)\r\n                return\r\n              }\r\n              popup.alert('\u5f00\u9501\u6210\u529f')\r\n            })\r\n            return\r\n          }\r\n          switch (qrCodeOpen) {\r\n            case 13:\r\n            case 14:\r\n            case 15:\r\n            case 16:\r\n            case 21:\r\n              operateData('data/apps/seat/unlock/qrcode', {reserveId: data.id, fidEnc: deptIdEnc}).then(function (json) {\r\n                if (!json.success) {\r\n                  popup.alert(json.msg)\r\n                  return\r\n                }\r\n                _this.unlockCodeDialog.url = json.data.url\r\n                _this.unlockCodeDialog.imgShow = true\r\n                _this.unlockCodeDialog.show = true\r\n              })\r\n              break\r\n            case 22:\r\n              _this.qrCodeDialog.password = data.uid.toString().slice(-6)\r\n              _this.qrCodeDialog.show = true\r\n              break\r\n            default:\r\n              break\r\n          }\r\n        },\r\n        // \u5224\u65ad\u7eed\u7ea6\u6309\u94ae\u662f\u5426\u663e\u793a\r\n        showRenewal: function (curReserve) {\r\n          if (curReserve && curReserve.hasOwnProperty('renewal')) {\r\n            return curReserve.renewal != 0 //\u5982\u679c\u914d\u7f6e\u6709\u7279\u6b8a\u89c4\uff0c\u5219\u4f18\u5148\u4f7f\u7528\r\n          }\r\n          return this.seatConfig.renewal != 0\r\n        },\r\n        signInBtnShow: function (curReserve) {\r\n          if (curReserve.status === 0) {\r\n            if ([0, 12, 14, 15, 21, 22].indexOf(this.seatConfig.qrcodeOpen) !== -1 && this.reservationEntrance.onlySupportsApiSignIn) {\r\n              return true\r\n            }\r\n          }\r\n          return false\r\n        },\r\n        signBackBtnShow: function (curReserve) {\r\n          if ([1, 3, 5].indexOf(curReserve.status) !== -1) {\r\n            if ([0, 12, 14, 16, 21, 22].indexOf(this.seatConfig.qrcodeOpen) !== -1) {\r\n              return true\r\n            }\r\n          }\r\n          return false\r\n        },\r\n        goManagePage: function () {\r\n          BaseUtils.addCache(pageKey, '2')\r\n          location.href = l