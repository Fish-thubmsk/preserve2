\"\",\"key_id\":\"35191cdfa1bf4721\",\"enc\":2}", "mimeType":"text/plain"}, "bodySize":2287, "headersSize":1143, "cookies":[{"value":"2346F26C176C88CC3819BDD57D359CE7:FG=1", "name":"BAIDUID_BFESS"}, {"value":"56174db7bd79324c61a1c24b840c99679deb", "name":"ab_jid"}, {"value":"56174db7bd79324c61a1c24b840c99679deb", "name":"ab_jid_BFESS"}, {"value":"79324c61a1c24b840c99679dec420339a3a8", "name":"ab_bid"}, {"value":"1.0.1_ZDNlMjEzMDhhM2MzNDVjN2M5YzZmYTkxZmRjM2RhOTUzZDAwOWRmYjA0NTM0NGU1NTI4YjVhNWRmNjc4MmI5YWFiZTc3ODUyY2U0MTFhODFlYjgwZjA3NTJlZWNjOTYyYWMwZmFiYTM1NTc2MmE2OWJhY2E1MTA2ZWVlY2I1MjNmMWE5MTY4OTRlYTU5YWJmZjI1NGRlNGZjNGY3M2FkNA==", "name":"ab_sr"}], "method":"POST", "url":"https://miao.baidu.com/abdr?_o=https%3A%2F%2Foffice.chaoxing.com", "httpVersion":"HTTP/2"}, "startedDateTime":"2026-03-06T12:26:32.7335257+08:00", "connection":"ClientPort:11395;EgressPort:13711", "serverIPAddress":"223.109.81.208"}, {"_publicFiddlerId":381, "response":{"redirectURL":"", "content":{"mimeType":"text/html;charset=UTF-8", "compression":46603, "size":58666, "text":"<!DOCTYPE html>\r\n<html>\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=0\">\r\n  <meta name=\"format-detection\" content=\"telephone=no\">\r\n  <title>\u5ea7\u4f4d\u9884\u7ea6</title>\r\n<base href=\"https://office.chaoxing.com/\">\r\n<script type=\"text/javascript\">\r\n  var photoUrl = 'http://photo.chaoxing.com'\r\n  var panUrl = 'http://pan-yz.chaoxing.com'\r\n  var noteUrl = 'http://noteyd.chaoxing.com'\r\n  var staticDomain = 'https://office-static.chaoxing.com/r/'\r\n  photoUrl = document.location.protocol + photoUrl.split(\":\")[1]\r\n  panUrl = document.location.protocol + panUrl.split(\":\")[1]\r\n  noteUrl = document.location.protocol + noteUrl.split(\":\")[1]\r\n  if (staticDomain !== '') {\r\n    staticDomain = document.location.protocol + staticDomain.split(\":\")[1]\r\n  }\r\n</script>\r\n\r\n<link rel=\"stylesheet\" href=\"https://office-static.chaoxing.com/r/staticreserve/style/reset.css\">\r\n<link rel=\"stylesheet\" href=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/seat.css\">\r\n<link rel=\"stylesheet\" href=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/reserve/iphonex.css\">\r\n<link rel=\"stylesheet\" href=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/reserve/reserve_mobile.css\">\r\n<script src=\"https://office-static.chaoxing.com/r/staticreserve/js/lib/jquery/jquery.min.js\"></script>\r\n<script src=\"https://office-static.chaoxing.com/r/staticreserve/js/lib/wy/YiDunProtector-Web-2.1.4.js\"></script>\r\n<script>document.write(\"<script src='https://captcha.chaoxing.com/load-d.min.js?t=\" + parseInt(Date.now()/60000) + \"'><\\/script>\");</script>\r\n<script>document.write(\"<script src='https://captcha.chaoxing.com/light.js?t=\" + parseInt(Date.now()/60000) + \"'><\\/script>\");</script>\r\n<script type=\"text/javascript\" src=\"//api.map.baidu.com/api?type=webgl&v=1.0&ak=p7HrxjMD6R1hbPFP9sNgkfHjsNZumBai\"></script>\r\n<script>document.write(\"<script src='https://cstaticdun.126.net/load.min.js?t=\" + parseInt(Date.now()/60000) + \"'><\\/script>\");</script>\r\n<script type=\"text/javascript\" src=\"https://office-static.chaoxing.com/r/staticreserve/js/lib/requirejs/require.min.js\"></script>\r\n<script type=\"text/javascript\" src=\"https://office-static.chaoxing.com/r/staticreserve/js/src/front/apps/seat/main.js?t=2026021017\"></script>\r\n<script>requirejs.config({urlArgs: 't=2026021017'})</script>\r\n</head>\r\n<body>\r\n<div class=\"seat_index\" v-cloak>\r\n  <div class=\"page_header\">\r\n    <div class=\"user_login\">\r\n      <div class=\"user_login_info\" v-if=\"seatConfig.thirdpartLoginoutShow!=2\">\r\n        <div class=\"user_login_avatar\"><img :src=\"photoDomain + '/p/'+userInfo.uid+'_50'\" alt=\"\"/></div>\r\n        <span class=\"user_login_name\">{{userInfo.uname}}</span>\r\n      </div>\r\n      <div class=\"user_login_info\" v-else>\r\n        <span class=\"user_login_name\">{{userInfo.uname}}</span>\r\n        <span class=\"user_login_name\" style=\"margin-left: 10px; max-width: 5rem;\"> {{userInfo.sno}}</span>\r\n      </div>\r\n      <div class=\"user_login_operate\" v-if=\"seatConfig.thirdpartLoginoutShow!=2\">\r\n        <div class=\"user_login_btn\" v-if=\"roleChangeBtnShow\" @click=\"goManagePage\">\u5207\u6362\u8eab\u4efd</div>\r\n        <div class=\"user_login_btn\" v-if=\"!hideLoginOut && seatConfig.thirdpartLoginoutShow!=0\" @click=\"logOutShow=true\">\u9000\u51fa\u767b\u5f55</div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  <ul class=\"sind_top\">\r\n    <li class=\"sind_top_btn\" @click=\"toSeatListPage\" v-if=\"reservationEntrance.defaultReserve\">\r\n      <img src=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_yuyue.png\" alt=\"\" class=\"sind_top_icon\"/>\r\n      <p class=\"sind_top_word\">\u9884\u7ea6\u9009\u5ea7</p>\r\n    </li>\r\n    <li class=\"sind_top_btn\" @click=\"sceneChoseSeat\" v-if=\"reservationEntrance.liveReserve\">\r\n      <img src=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_xinachang.png\" alt=\"\" class=\"sind_top_icon\"/>\r\n      <p class=\"sind_top_word\">\u5feb\u901f\u9009\u5ea7</p>\r\n    </li>\r\n    <li class=\"sind_top_btn\" @click=\"toReserveListPage\">\r\n      <img src=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_jilu.png\" alt=\"\" class=\"sind_top_icon\"/>\r\n      <p class=\"sind_top_word\">\u9884\u7ea6\u8bb0\u5f55</p>\r\n    </li>\r\n    <li class=\"sind_top_btn\" @click=\"goNotice()\" v-if=\"customNoticeShow\">\r\n      <img v-if=\"seatConfig.deptId != 23278\" src=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_xitong.png\" alt=\"\" class=\"sind_top_icon\"/>\r\n      \r\n      <img v-else src=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/icon_data.png\" alt=\"\" class=\"sind_top_icon\"/>\r\n      <p class=\"sind_top_word\">{{seatConfig.noticeName}}</p>\r\n    </li>\r\n    <li class=\"sind_top_btn\" @click=\"toRulePage\" v-if=\"defaultNoticeShow\">\r\n      <img src=\"https://office-static.chaoxing.com/r/staticreserve/style/apps/seat/images/ind_guize.png\" alt=\"\" class=\"sind_top_icon\"/>\r\n      <p class=\"sind_top_word\">\u89c4\u5219\u8bf4\u660e</p>\r\n    </li>\r\n  </ul>\r\n  <div class=\"sind_cont\">\r\n    \r\n    <div class=\"s_now_nodata\" v-if=\"notCurReserves\">\r\n      <h6 class=\"s_now_title\">\u5f53\u524d\u9884\u7ea6</h6>\r\n      <div class=\"s_now_cont\"><span>\u6682\u65e0\u9884\u7ea6</span></div>\r\n    </div>\r\n    \r\n    <div class=\"s_now\" :class=\"{wait: curReserve.status == 0,leave:curReserve.status == 3,leave:curReserve.status == 5}\" v-if=\"!notCurReserves\" v-for=\"curReserve in curReserves\">\r\n      <h6 class=\"s_now_title\">\r\n        <span>\u5f53\u524d\u9884\u7ea6</span>\r\n        <span class=\"s_now_btn\" @click.stop=\"toggleReserveInfo(curReserve)\">\u51fa\u793a\u9884\u7ea6\u4fe1\u606f</span>\r\n        <span class=\"s_now_type\" v-if=\"curReserve.status === 0\">\u5f85\u5c65\u7ea6</span>\r\n        <span class=\"s_now_type\" v-if=\"curReserve.status === 1\">\u4f7f\u7528\u4e2d</span>\r\n        <span class=\"s_now_type\" v-if=\"curReserve.status === 3\">\u6682\u79bb\u4e2d</span>\r\n        <span class=\"s_now_type\" v-if=\"curReserve.status === 5\">\u88ab\u76d1\u7763\u4e2d</span>\r\n      </h6>\r\n      <dl class=\"s_now_cont\">\r\n        <dt>\r\n          <h6 class=\"s_now_name owt1\">{{curReserve.seatNum}}\u53f7\u5ea7\u4f4d</h6>\r\n          <p class=\"s_now_addr owt1\">\r\n            {{curReserve.firstLevelName}}<span v-if=\"curReserve.secondLevelName\">-{{curReserve.secondLevelName}}</span><span v-if=\"curReserve.thirdLevelName\">-{{curReserve.thirdLevelName}}</span>\r\n          </p>\r\n          <p class=\"s_now_time owt1\" v-if=\"curReserve.status === 1 || curReserve.status === 3 || curReserve.status === 5\">\u5269\u4f59\u65f6\u957f&nbsp;&nbsp;&nbsp;{{countDown}}</p>\r\n          <p class=\"s_now_time owt1\" v-else>{{curReserve.startTime |\r\n            format('YYYY-MM-DD')}}<span>{{curReserve.startTime | format('HH:mm')}}-{{curReserve.endTime | format('HH:mm')}}</span><span>{{curReserve.duration}}\u5c0f\u65f6</span></p>\r\n        </dt>\r\n        <dd>\r\n          <ul class=\"s_now_btns\">\r\n            <li class=\"s_btn qd\" v-if=\"unlockBtnShow\" @click=\"unlock(curReserve)\">{{unlockBtnText}}</li>\r\n            <li class=\"s_btn\" v-if=\"curReserve.status === 1 && curReserve.reserveMode === 0 && showRenewal(curReserve) \" @click=\"reReserve(curReserve.roomId,curReserve.seatNum)\">\r\n              \u7eed\u7ea6\r\n            </li>\r\n            <li class=\"s_btn\" v-if=\"leaveBtnShow(curReserve)\" @click=\"askLeave(curReserve.id)\">\u6682\u79bb</li>\r\n            <li class=\"s_btn tz\" v-if=\"signBackBtnShow(curReserve)\" @click.stop=\"askSignBack(curReserve)\">\u9000\u5ea7</li>\r\n            <li class=\"s_btn qd\" v-if=\"signInBtnShow(curReserve) && !goPayBtnShow(curReserve)\" @click=\"signIn(curReserve)\">\u7b7e\u5230</li>\r\n            <li class=\"s_btn qd\" v-if=\"beSeatedBtnShow(curReserve)\" @click=\"signIn(curReserve)\">\u843d\u5ea7</li>\r\n            <li class=\"s_btn qd\" v-if=\"goPayBtnShow(curReserve)\" @click=\"goPay(curReserve)\">\u53bb\u652f\u4ed8</li>\r\n            <li class=\"s_btn\" v-if=\"curReserve.status === 0\" @click.stop=\"askCancel(curReserve.id)\">\u53d6\u6d88</li>\r\n          </ul>\r\n        </dd>\r\n      </dl>\r\n    </div>\r\n    \r\n    <div class=\"screenMask\" v-if=\"cancelShow || signBackShow || leaveShow || logOutShow || openDialog\"></div>\r\n    <div class=\"quit_pop leave_pop\" v-if=\"cancelShow\">\r\n      <div class=\"quit_top\" style=\"text-align: center\">\u786e\u5b9a\u8981\u53d6\u6d88\u6b64\u6b21\u9884\u7ea6\u5417\uff1f</div>\r\n      <div class=\"quit_btm\">\r\n        <span @click=\"cancel(false)\">\u53d6\u6d88</span>\r\n        <span class=\"quit_sure\" @click=\"cancel(true)\">\u786e\u8ba4</span>\r\n      </div>\r\n    </div>\r\n    <div class=\"quit_pop leave_pop\" v-if=\"signBackShow\">\r\n      <div class=\"quit_top\">\u9000\u5ea7\u540e\u5ea7\u4f4d\u5c06\u88ab\u91ca\u653e\uff0c\u786e\u8ba4\u7ed3\u675f\u672c\u6b21\u4f7f\u7528</div>\r\n      <div class=\"quit_btm\">\r\n        <span @click=\"signBack(false)\">\u53d6\u6d88</span>\r\n        <span class=\"quit_sure\" @click=\"signBack(true)\">\u786e\u8ba4</span>\r\n      </div>\r\n    </div>\r\n    \r\n    <div class=\"quit_pop leave_pop\" v-if=\"leaveShow\">\r\n      <div class=\"quit_top\">\u5ea7\u4f4d\u5c06\u4e3a\u60a8\u4fdd\u7559<br/>\u4f46\u60a8\u9700\u8981\u5728\u89c4\u5b9a\u65f6\u95f4\u5185\u8fd4\u56de<br/>\u5426\u5219\u5ea7\u4f4d\u5c06\u88ab\u91ca\u653e\uff0c\u786e\u5b9a\u6682\u79bb\u5417\uff1f</div>\r\n      <div class=\"quit_btm\">\r\n        <span @click=\"leave(false)\">\u53d6\u6d88</span>\r\n        <span class=\"quit_sure\" @click=\"leave(true)\">\u786e\u8ba4</span>\r\n      </div>\r\n    </div>\r\n    <template v-if=\"reservationEntrance.recentlyReserve\">\r\n      <h6 class=\"s_near_title\">\u6700\u8fd1\u9884\u7ea6</h6>\r\n      \r\n      <div class=\"s_near_nodata\" v-if=\"notNearReserves\">\r\n        <div class=\"nera_nodata_img\"></div>\r\n        <p class=\"near_nodata_word\">\u6682\u65e0\u6700\u8fd1\u9884\u7ea6</p>\r\n      </div>\r\n      \r\n      <ul class=\"s_near_data\" v-if=\"!notNearReserves\">\r\n        <li class=\"s_near_info\" v-for=\"data in nearReserves\">\r\n          <h6 class=\"s_name\">{{data.seatNum}}\u53f7\u5ea7\u4f4d\r\n            <label class=\"s_time\"><span>{{data.startTime | format('HH:mm')}}-{{data.endTime | format('HH:mm')}}</span><span>{{data.duration}}\u5c0f\u65f6</span></label></h6>\r\n          <p class=\"s_addr\">{{data.firstLevelName}} <span class=\"s_btn\" @click=\"reReserve(data.roomId,data.seatNum)\" v-if=\"reservationEntrance.againReserve\">\u518d\u6b21\u9884\u7ea6</span></p>\r\n        </li>\r\n      </ul>\r\n    </template>\r\n    \r\n    <div class=\"cal_pop\" v-if=\"logOutShow\">\r\n      <div class=\"cal_top\">\u786e\u5b9a\u9000\u51fa\u8d26\u53f7?</div>\r\n      <div class=\"cal_btm\">\r\n        <span @click=\"logOutShow=false\">\u53d6\u6d88</span>\r\n        <span class=\"wait_sure\" @click=\"logOut\">\u786e\u8ba4</span>\r\n      </div>\r\n    </div>\r\n  </div>\r\n  \r\n  <div class=\"reminder_pop\" v-show=\"openDialog\">\r\n    <h6 class=\"rp_top\" v-show=\"openDialogType == 0\">{{seatConfig.dialogTitle}}</h6>\r\n    <h6 class=\"rp_top\" v-show=\"openDialogType == 1\">{{seatConfig.noticeName}}</h6>\r\n    <div class=\"rp_cont\">\r\n      <div id=\"rich_text\"></div>\r\n    </div>\r\n    <div class=\"notice_confirm\" v-show=\"openDialogType == 0 && seatConfig.dialogAgree == 1\">\r\n      <span class=\"icon_radio\" :class=\"{'icon_check': dialogAgreeStatus}\" @click=\"dialogAgreeStatus = !dialogAgreeStatus\"></span>\r\n      <span>\u6211\u5df2\u9605\u8bfb\u5e76\u540c\u610f\u76f8\u5173\u5185\u5bb9</span>\r\n    </div>\r\n    <div class=\"rp_bottom\">\r\n      <span class=\"rp_cal\" v-show=\"openDialogType == 0\" @click=\"back()\">\u53d6\u6d88</span>\r\n      <span class=\"rp_sure\" :class=\"{disabled: openDialogType == 0 && seatConfig.dialogAgree == 1 && !dialogAgreeStatus}\" @click=\"start()\">\u5f00\u59cb\u9884\u7ea6</span>\r\n    </div>\r\n  </div>\r\n  \r\n  <div class=\"screenMask\" style=\"z-index: 3\" v-if=\"bindSnoShow\"></div>\r\n  \r\n  <div class=\"reminder_pop\" style=\"z-index: 4\" v-if=\"bindSnoShow\">\r\n    <h6 class=\"rp_top\">\u7ed1\u5b9a\u63d0\u793a</h6>\r\n    <div class=\"rp_cont\">\r\n      <p class=\"rp_cont_word\">\u60a8\u672a\u7ed1\u5b9a\u5b66\u5de5\u53f7/\u4e00\u5361\u901a\u8d26\u53f7\uff0c\u65e0\u6cd5\u4f7f\u7528\u5168\u90e8\u529f\u80fd\uff0c\u8bf7\u7ed1\u5b9a\u540e\u518d\u9884\u7ea6</p>\r\n    </div>\r\n    <div class=\"rp_bottom\">\r\n      <span class=\"rp_cal\" @click=\"back()\">\u53d6\u6d88</span>\r\n      <span class=\"rp_sure\" @click=\"goBindSno()\">\u53bb\u7ed1\u5b9a</span>\r\n    </div>\r\n  </div>\r\n  \r\n  <div class=\"pop_wrap\" v-show=\"qrCodeDialog.show\">\r\n    <div class=\"code_pop\">\r\n      \r\n      <template v-if=\"showCode\">\r\n        <div class=\"code_pic\" v-if=\"!qrCodeDialog.isSign\">\r\n          <img v-show=\"qrCodeDialog.imgShow\" :src=\"qrCodeDialog.url\" alt=\"\">\r\n          <span>\u8bf7\u5c06\u4e8c\u7ef4\u7801\u5bf9\u51c6\u626b\u7801\u8bbe\u5907\u626b\u63cf</span>\r\n        </div>\r\n        <div class=\"success_tip\" v-else>\r\n          <span class=\"error_pic\"></span>\r\n          <h1>\u7b7e\u5230\u6210\u529f</h1>\r\n        </div>\r\n      </template>\r\n      \r\n      <div class=\"psd_box\" v-if=\"seatConfig.qrcodeOpen == 22\">\r\n        <span class=\"psd_pic\"></span>\r\n        <h1 class=\"psd_num\">{{qrCodeDialog.password}}</h1>\r\n        <p class=\"psd_txt\">\u8bf7\u5728\u9884\u7ea6\u533a\u57df\u95e8\u7981\u8bbe\u5907\u5904\u8f93\u5165\u6b64\u5bc6\u7801</p>\r\n      </div>\r\n      <div class=\"pop_btm\" @click=\"location.reload()\">\u5173\u95ed</div>\r\n    </div>\r\n  </div>\r\n  \r\n  <div class=\"pop_wrap\" v-show=\"unlockCodeDialog.show\">\r\n    <div class=\"code_pop\">\r\n      \r\n      <div class=\"code_pic\">\r\n        <img v-show=\"unlockCodeDialog.imgShow\" :src=\"unlockCodeDialog.url\" alt=\"\">\r\n        <span>\u8bf7\u5c06\u4e8c\u7ef4\u7801\u5bf9\u51c6\u626b\u7801\u8bbe\u5907\u626b\u63cf</span>\r\n      </div>\r\n      <div class=\"pop_btm\" @click=\"location.reload()\">\u5173\u95ed</div>\r\n    </div>\r\n  </div>\r\n  \r\n  <transition name=\"model-mask\">\r\n    <div class=\"model-pop-mask reserve-info-pop-mask\" v-if=\"reserveInfo.show\" @click.stop=\"toggleReserveInfo(null)\">\r\n      <div class=\"model-popup reserve-info-pop-wrap\" @click.stop>\r\n        <div class=\"popup-title owt1\">\u9884\u7ea6\u4fe1\u606f</div>\r\n        <span class=\"popup-close\" @click.stop=\"toggleReserveInfo(null)\">\u5173\u95ed</span>\r\n        <div class=\"popup-body\">\r\n          <h1 class=\"reserve-time\">{{reserveInfo.data.startTime | format('HH:mm')}}-{{reserveInfo.data.endTime | format('HH:mm')}}</h1>\r\n          <h2 class=\"reserve-date\">{{reserveInfo.data.startTime | format('YYYY-MM-DD')}}</h2>\r\n          <p class=\"reserve-place owt1\">\r\n            <span>{{reserveInfo.data.firstLevelName}}</span>\r\n            <span v-if=\"reserveInfo.data.secondLevelName\">-{{reserveInfo.data.secondLevelName}}</span>\r\n            <span v-if=\"reserveInfo.data.thirdLevelName\">-{{reserveInfo.data.thirdLevelName}}</span>\r\n            <span>&nbsp;{{reserveInfo.data.seatNum}}&nbsp;\u53f7</span>\r\n          </p>\r\n          <h1 class=\"reserve-userName owt1\">{{reserveInfo.data.uname}}</h1>\r\n          <h1 class=\"reserve-status\"\r\n              :class=\"{'orange': reserveInfo.data.status==0||reserveInfo.data.status==3, 'blue': reserveInfo.data.status==1, 'red': reserveInfo.data.status==5}\">\r\n            {{reserveInfo.data.statusStr}}\r\n          </h1>\r\n          <p class=\"tip-txt\">\u5f53\u524d\u65f6\u95f4</p>\r\n          <p class=\"current-time\">{{reserveInfo.currentTime | format('YYYY-MM-DD HH:mm:ss')}}</p>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </transition>\r\n  \r\n  <div class=\"res_loading\" v-if=\"loadingShow\">\r\n    <div class=\"res_load_cont\">\r\n      <div class=\"loading_iocn\"></div>\r\n      <p class=\"loading_info\">{{tipTitle}}</p>\r\n    </div>\r\n  </div>\r\n</div>\r\n<script>\r\n  window.addEventListener('pageshow', function (e) {\r\n    //\u5982\u679c\u68c0\u6d4b\u5230\u9875\u9762\u662f\u4ece\u201c\u5f80\u8fd4\u7f13\u5b58\u201d\u4e2d\u8bfb\u53d6\u7684\uff0c\u5237\u65b0\u9875\u9762\r\n    if (e.persisted) {\r\n      window.location.reload()\r\n    }\r\n  })\r\n  require(['jquery', 'Vue', 'moment', 'popup', 'jweixin', 'wxinit', 'baseUtils', 'cookies', 'thirdAppUtils', 'multieditor', 'webUploader', 'sortable', 'cropper', 'clipboard',\r\n    'Viewer', 'jrxyUtils',  'sha'], function ($, Vue, moment, popup, wx, wxinit, BaseUtils, Cookies, thirdAppUtils, multieditor, WebUploader, Sortable, Cropper, Clipboard, Viewer, JrxyUtils) {\r\n    'use strict'\r\n    window['WebUploader'] = WebUploader\r\n    window['Sortable'] = Sortable\r\n    window['Cropper'] = Cropper\r\n    window['clipboard'] = Clipboard\r\n    window['Viewer'] = Viewer\r\n    var userLoginInfo = {\"userInfo\":{\"deptId\":22640,\"id\":21466273,\"inserttime\":1772636462000,\"mobile\":\"135****9492\",\"signature\":\"\",\"sno\":\"202234070149\",\"uid\":238771432,\"uname\":\"\u738b\u7ea2\u65b0\",\"updatetime\":1772636462000}}||{}\r\n    var user = userLoginInfo && userLoginInfo.userInfo\r\n    var deptIdEnc = '4a18e12602b24c8c',\r\n        mark = '0',\r\n        serverNow = new Date('2026-03-06T12:26:50.170+08:00'),\r\n        mappId = '0',\r\n        pageKey = 'seat_index_page_' + Cookies.get('oa_deptid') + '_' + Cookies.get('oa_uid'),\r\n        dialogKey = 'seat_dialog_' + Cookies.get('oa_deptid') + '_' + Cookies.get('oa_uid')\r\n    function operateData(url, data) {\r\n      return $.getJSON(url, data)\r\n    }\r\n    function signInScan(_this, data) {\r\n      var now = moment()\r\n      //\u5224\u65ad\u662f\u5426\u5b58\u5728\u672a\u7b7e\u9000\u5ea7\u4f4d\r\n      operateData('data/apps/seat/check/exist', {seatNum: data.seatNum, roomId: data.roomId}).then(function (json) {\r\n        if (json.success) {\r\n          if (json.data.existCount > 0) {\r\n            popup.alert('\u60a8\u5b58\u5728\u672a\u7b7e\u9000\u5ea7\u4f4d\uff0c\u4e0d\u53ef\u518d\u6b21\u7b7e\u5230')\r\n          } else {\r\n            var scannerType = wxinit.getScannerType()\r\n            scannerType = BaseUtils.getThirdScannerDept(_this.seatConfig.deptId, scannerType)\r\n            if (data.status === 0 || data.status === 3 || data.status === 5) {\r\n              if (data.status === 0) {\r\n                var signDuration = json.data.signDuration\r\n                var preSignDuration = json.data.preSignDuration //\u5b9a\u5236\u9700\u6c42\uff0c\u5f39\u6027\u7b7e\u5230\u53ea\u80fd\u5411\u540e\u5f39\r\n                if (signDuration === -1) {\r\n                  if (now.isBefore(moment(data.startTime).add(-preSignDuration, 'minutes'))) {\r\n                    popup.alert('\u8fd8\u672a\u5230\u7b7e\u5230\u65f6\u95f4')\r\n                    return\r\n                  }\r\n                  if (now.isAfter(moment(data.endTime))) {\r\n                    popup.alert('\u7b7e\u5230\u65f6\u95f4\u5df2\u8fc7', '\u786e\u8ba4', function () {\r\n                      location.reload()\r\n                    })\r\n                    return\r\n                  }\r\n                } else {\r\n                  if (now.isBefore(moment(data.startTime).add(-preSignDuration, 'minutes'))) {\r\n                    popup.alert('\u8fd8\u672a\u5230\u7b7e\u5230\u65f6\u95f4')\r\n                    return\r\n                  }\r\n                  if (moment(data.expireTime).isBefore(now)) {\r\n                    popup.alert('\u7b7e\u5230\u65f6\u95f4\u5df2\u8fc7', '\u786e\u8ba4', function () {\r\n                      location.reload()\r\n                    })\r\n                    return\r\n                  }\r\n                }\r\n              }\r\n              if (data.status === 3 || data.status === 5) {\r\n                if (moment(data.expireTime).isBefore(now)) {\r\n                  popup.alert('\u843d\u5ea7\u65f6\u95f4\u5df2\u8fc7')\r\n                  location.reload()\r\n                  return\r\n                }\r\n              }\r\n              if (_this.showCode) {\r\n                getQrcode(_this, data)\r\n                return\r\n              }\r\n              //\u5224\u65ad\u662f\u5426\u9700\u8981\u626b\u7801\r\n              if (data.isPosition === 2) {//\u4ec5\u5224\u65ad\u4f4d\u7f6e\r\n                location.href = location.origin + '/front/third/apps/seat/code?seatNum=' + data.seatNum + '&id=' + data.roomId\r\n              } else if (data.isPosition === 0 || data.isPosition === 1) {//\u626b\u5ea7\u4f4d\u7801\r\n                switch (scannerType) {\r\n                  case 0:\r\n                    wx.scanQRCode({\r\n                      needResult: 1,\r\n                      desc: 'scanQRCode desc',\r\n                      success: function (res) {\r\n                        var qrUrl = res.resultStr\r\n                        if (qrUrl != undefined && qrUrl != null && qrUrl != '' && qrUrl.indexOf('front/apps/seat/code') != -1) {\r\n                          location.href = qrUrl + '&num=' + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId\r\n                        } else {\r\n                          popup.alert('\u8bf7\u626b\u63cf\u6b63\u786e\u7684\u4e8c\u7ef4\u7801')\r\n                        }\r\n                      }\r\n                    })\r\n                    break\r\n                  case 1:\r\n                    location.href = 'http://sao315.com/w/api/saoyisao?redirect_uri=' + encodeURIComponent(location.href + '&num='\r\n                        + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId)\r\n                    break\r\n                  case 2:\r\n                    location.href = 'https://office.chaoxing.com/api/wx/front/apps/reserve/scanner?redirect_uri=' +\r\n                        encodeURIComponent(location.href + '&num='\r\n                            + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId)\r\n                    break\r\n                  case 124841:\r\n                    thirdAppUtils.barcode.scan().then(function (res) {\r\n                      location.href = res + '&num=' + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId\r\n                    })\r\n                    break\r\n                  case 23677:\r\n                    thirdAppUtils.barcode.lzcsScan().then(function (res) {\r\n                      location.href = res + '&num=' + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId\r\n                    })\r\n                    break\r\n                  case 33155:\r\n                    setTimeout(function () {\r\n                      if (_this.initJrxyApiSuccess) {\r\n                        JrxyUtils.scan($.Deferred()).done(function (res) {\r\n                          if (res.success) {\r\n                            location.href = res.url + '&num=' + data.seatNum + '&reserveId=' + data.id + '&room=' + data.roomId\r\n                          } else {\r\n                            popup.alert('\u626b\u7801\u5931\u8d25')\r\n                          }\r\n                        })\r\n                      } else {\r\n                        popup.alert('\u4eca\u65e5\u6821\u56ed\u73af\u5883\u521d\u59cb\u5316\u5931\u8d25\uff0c\u8bf7\u5237\u65b0\u9875\u9762\u91cd\u8bd5')\r\n                      }\r\n                    }, 1000)\r\n                    break\r\n                  default:\r\n                    break\r\n                }\r\n              } else if (data.isPosition === 3 || data.isPosition === 7) {//\u626b\u7edf\u4e00\u4e8c\u7ef4\u7801\r\n                switch (scannerType) {\r\n                  case 0:\r\n                    wx.scanQRCode({\r\n                      needResult: 1,\r\n                      desc: 'scanQRCode desc',\r\n                      success: function (res) {\r\n                        var qrUrl = res.resultStr\r\n                        if (qrUrl != undefined && qrUrl != null && qrUrl != '' && qrUrl.indexOf('front/apps/seat/unified/code') != -1) {\r\n                          location.href = qrUrl + '&seatNum=' + parseInt(data.seatNum) + '&reserveId=' + data.id + '&id=' + data.roomId\r\n                        } else {\r\n                          popup.alert('\u8bf7\u626b\u63cf\u6b63\u786e\u7684\u4e8c\u7ef4\u7801')\r\n                        }\r\n                      }\r\n                    })\r\n                    break\r\n                  case 1:\r\n                    location.href = 'http://sao315.com/w/api/saoyisao?redirect_uri=' + encodeURIComponent(location.href + '&seatNum=' + parseInt(data.seatNum)\r\n                        + '&reserveId=' + data.id + '&id=' + data.roomId)\r\n                    break\r\n                  case 2:\r\n                    location.href = 'https://office.chaoxing.com/api/wx/front/apps/reserve/scanner?redirect_uri=' +\r\n                        encodeURIComponent(location.href + '&seatNum=' + parseInt(data.seatNum)\r\n                            + '&reserveId=' + data.id + '&id=' + data.roomId)\r\n                    break\r\n                  case 124841:\r\n                    thirdAppUtils.barcode.scan().then(function (res) {\r\n                      location.href = res + '&seatNum=' + parseInt(data.seatNum) + '&reserveId=' + data.id + '&id=' + data.roomId\r\n                    })\r\n                    break\r\n                  case 23677:\r\n                    thirdAppUtils.barcode.lzcsScan().then(function (res) {\r\n                      location.href = res + '&seatNum=' + parseInt(data.seatNum) + '&reserveId=' + data.id + '&id=' + data.roomId\r\n                    })\r\n                    break\r\n                  case 33155:\r\n                    setTimeout(function () {\r\n                      if (_this.initJrxyApiSuccess) {\r\n                        JrxyUtils.scan($.Deferred()).done(function (res) {\r\n                          if (res.success) {\r\n                            location.href = res.url + '&seatNum=' + parseInt(data.seatNum) + '&reserveId=' + data.id + '&id=' + data.roomId\r\n                          } else {\r\n                            popup.alert('\u626b\u7801\u5931\u8d25')\r\n                          }\r\n                        })\r\n                      } else {\r\n                        popup.alert('\u4eca\u65e5\u6821\u56ed\u73af\u5883\u521d\u59cb\u5316\u5931\u8d25\uff0c\u8bf7\u5237\u65b0\u9875\u9762\u91cd\u8bd5')\r\n                      }\r\n                    }, 1000)\r\n                    break\r\n                  default:\r\n                    break\r\n                }\r\n              } else if (data.isPosition === 4) {\r\n                switch (scannerType) {\r\n                  case 0:\r\n                    wx.scanQRCode({\r\n                      needResult: 1,\r\n                      desc: 'scanQRCode desc',\r\n                      success: function (res) {\r\n                        var qrUrl = res.resultStr\r\n                        if (qrUrl != undefined && qrUrl != null && qrUrl != '' && qrUrl.indexOf('front/apps/seat/dynamic/code') != -1) {\r\n                          location.href = qrUrl + '&seatNum=' + parseInt(data.seatNum) + '&reserveId=' + data.id + '&room=' + data.roomId\r\n                        } else {\r\n                          popup.alert('\u8bf7\u626b\u63cf\u6b63\u786e\u7684\u4e8c\u7ef4\u7801')\r\n                        }\r\n                      }\r\n                    })\r\n                    break\r\n                  case 1:\r\n                    location.href = 'http://sao315.com/w/api/saoyisao?redirect_uri=' + encodeURIComponent(location.href + '&seatNum=' + parseInt(data.seatNum)\r\n                        + '&reserveId=' + data.id + '&room=' + data.roomId)\r\n                    break\r\n                  case 2:\r\n                    location.href = 'https://office.chaoxing.com/api/wx/front/apps/reserve/scanner?redirect_uri=' +\r\n                        encodeURIComponent(location.href + '&seatNum=' + parseInt(data.seatNum)\r\n                            + '&reserveId=' + data.id + '&room=' + data.roomId)\r\n                    break\r\n                  case 124841:\r\n                    thirdAppUtils.barcode.scan().then(function (res) {\r\n                      location.href = res + '&seatNum=' + parseInt(data.seatNum) + '&reserveId